# Patch: Create pyproject.toml (upstream has none)
#
# The upstream jenicek/asmk repo uses only setup.py with no pyproject.toml.
# We add one with modern setuptools backend and empty dependencies, since
# faiss comes from conda and numpy/pyaml from the pixi environment.
#
# The "--- /dev/null" header tells the patch tool this is a new file.
--- /dev/null
+++ b/pyproject.toml
@@ -0,0 +1,15 @@
+[build-system]
+requires = ["setuptools"]
+build-backend = "setuptools.build_meta"
+
+[project]
+name = "asmk"
+version = "0.1"
+authors = [{ name = "Tomas Jenicek" }, { name = "Giorgos Tolias" }]
+description = "ASMK Python implementation for ECCV'20 paper \"Learning and aggregating deep local descriptors for instance-level recognition\""
+# faiss is provided by conda; numpy and pyaml by the pixi environment
+dependencies = []
+
+
+[tool.setuptools]
+packages = { find = { where = ["."], include = ["asmk"], namespaces = false } }
