 172: __forceinline__ __device__ float huber(float r) {
 173:   const float r_abs = fabs(r);
 174:   return r_abs < 1.345 ? 1.0 : 1.345 / r_abs;
 175: }
 176: 
 177: // Returns qi * qj
 178: __device__ void 
 179: quat_comp(const float *qi, const float *qj, float *out) {
 180:   out[0] = qi[3] * qj[0] + qi[0] * qj[3] + qi[1] * qj[2] - qi[2] * qj[1];
 181:   out[1] = qi[3] * qj[1] - qi[0] * qj[2] + qi[1] * qj[3] + qi[2] * qj[0];
 182:   out[2] = qi[3] * qj[2] + qi[0] * qj[1] - qi[1] * qj[0] + qi[2] * qj[3];
 183:   out[3] = qi[3] * qj[3] - qi[0] * qj[0] - qi[1] * qj[1] - qi[2] * qj[2];
 184: }
 185: 
 186: // Inverts quat
 187: __device__ void 
 188: quat_inv(const float *q, float *out) {
 189:   out[0] = -q[0];
 190:   out[1] = -q[1];
 191:   out[2] = -q[2];
 192:   out[3] =  q[3];
 193: }
 194: 
 195: __device__ void
 196: actSO3(const float *q, const float *X, float *Y) {
 197:   float uv[3];
 198:   uv[0] = 2.0 * (q[1]*X[2] - q[2]*X[1]);
 199:   uv[1] = 2.0 * (q[2]*X[0] - q[0]*X[2]);
 200:   uv[2] = 2.0 * (q[0]*X[1] - q[1]*X[0]);
 201: 
 202:   Y[0] = X[0] + q[3]*uv[0] + (q[1]*uv[2] - q[2]*uv[1]);
 203:   Y[1] = X[1] + q[3]*uv[1] + (q[2]*uv[0] - q[0]*uv[2]);
 204:   Y[2] = X[2] + q[3]*uv[2] + (q[0]*uv[1] - q[1]*uv[0]);
 205: }
 206: 
 207: __device__  void
 208: actSim3(const float *t, const float *q, const float *s, const float *X, float *Y) {
 209:   // Rotation
 210:   actSO3(q, X, Y);
 211:   // Scale
 212:   Y[0] *= s[0];
 213:   Y[1] *= s[0];
 214:   Y[2] *= s[0];
 215:   // Translation
 216:   Y[0] += t[0];
 217:   Y[1] += t[1];
 218:   Y[2] += t[2];
 219: }
 220: 
 221: // Inverts quat
 222: __device__ void 
 223: scale_vec3_inplace(float *t, float s) {
 224:   t[0] *= s;
 225:   t[1] *= s;
 226:   t[2] *= s;
 227: }
 228: 
 229: __device__ void
 230: crossInplace(const float* a, float *b) {
 231:   float x[3] = {
 232:     a[1]*b[2] - a[2]*b[1],
 233:     a[2]*b[0] - a[0]*b[2],
 234:     a[0]*b[1] - a[1]*b[0], 
 235:   };
 236: 
 237:   b[0] = x[0];
 238:   b[1] = x[1];
 239:   b[2] = x[2];
 240: }
 241: 
 242: __forceinline__ __device__ float
 243: dot3(const float *t, const float *s) {
 244:   return t[0]*s[0] + t[1]*s[1] + t[2]*s[2];
 245: }
 246: 
 247: __forceinline__ __device__ float
 248: squared_norm3(const float *v) {
 249:   return v[0]*v[0] + v[1]*v[1] + v[2]*v[2];
 250: }
 251: 
 252: __device__ void 
 253: relSim3(const float *ti, const float *qi, const float* si,
 254:         const float *tj, const float *qj, const float* sj,
 255:         float *tij, float *qij, float *sij) {
 256:   
 257:   // 1. Setup scale
 258:   float si_inv = 1.0/si[0];
 259:   sij[0] = si_inv * sj[0];
 260: 
 261:   // 2. Relative rotation
 262:   float qi_inv[4];
 263:   quat_inv(qi, qi_inv);
 264:   quat_comp(qi_inv, qj, qij);
 265: 
 266:   // 3. Translation
 267:   tij[0] = tj[0] - ti[0];
 268:   tij[1] = tj[1] - ti[1];
 269:   tij[2] = tj[2] - ti[2];
 270:   actSO3(qi_inv, tij, tij);
 271:   scale_vec3_inplace(tij, si_inv);
 272: }
 273: 
 274: // Order of X,Y is tau, omega, s 
 275: // NOTE: This is applying adj inv on the right to a row vector on the left,
 276: // The equivalent is transposing the adjoint and multiplying a column vector
 277: __device__ void
 278: apply_Sim3_adj_inv(const float *t, const float *q, const float *s, const float *X, float *Y) {
 279:   // float qinv[4] = {-q[0], -q[1], -q[2], q[3]};
 280:   const float s_inv = 1.0/s[0];
 281: 
 282:   // First component = s_inv R a
 283:   float Ra[3];
 284:   actSO3(q, &X[0], Ra);
 285:   Y[0] = s_inv * Ra[0];
 286:   Y[1] = s_inv * Ra[1];
 287:   Y[2] = s_inv * Ra[2];
 288:   
 289:   // Second component = s_inv [t]x Ra + Rb
 290:   actSO3(q, &X[3], &Y[3]); // Init to Rb
 291:   Y[3] += s_inv*(t[1]*Ra[2] - t[2]*Ra[1]);
 292:   Y[4] += s_inv*(t[2]*Ra[0] - t[0]*Ra[2]);
 293:   Y[5] += s_inv*(t[0]*Ra[1] - t[1]*Ra[0]);
 294: 
 295:   // Third component = s_inv t^T R a + c
 296:   Y[6] = X[6] + ( s_inv * dot3(t, Ra) );
 297: }
