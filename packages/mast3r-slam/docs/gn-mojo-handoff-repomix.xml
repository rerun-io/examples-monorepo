316:         24,
317:         Scalar[DType.float32],
318:         address_space=AddressSpace.SHARED,
319:     ]()
320:     if tid < 8:
321:         pose_shared[tid] = twc[pi + tid]
322:     if tid < 8:
323:         pose_shared[tid + 8] = twc[pj + tid]
324:     barrier()
325:     var ti0 = pose_shared[0][0]
326:     var ti1 = pose_shared[1][0]
327:     var ti2 = pose_shared[2][0]
328:     var qi0 = pose_shared[3][0]
329:     var qi1 = pose_shared[4][0]
330:     var qi2 = pose_shared[5][0]
331:     var qi3 = pose_shared[6][0]
332:     var si0 = pose_shared[7][0]
333:     var tj0 = pose_shared[8][0]
334:     var tj1 = pose_shared[9][0]
335:     var tj2 = pose_shared[10][0]
336:     var qj0 = pose_shared[11][0]
337:     var qj1 = pose_shared[12][0]
338:     var qj2 = pose_shared[13][0]
339:     var qj3 = pose_shared[14][0]
340:     var sj0 = pose_shared[15][0]
341: 
342:     if tid == 0:
343:         var rel_once = rel_sim3_components(
344:             ti0, ti1, ti2,
345:             qi0, qi1, qi2, qi3,
346:             si0,
347:             tj0, tj1, tj2,
348:             qj0, qj1, qj2, qj3,
349:             sj0,
350:         )
351:         for r in range(8):
352:             pose_shared[16 + r] = rel_once[r]
353:     barrier()
354:     var rel0 = pose_shared[16][0]
355:     var rel1 = pose_shared[17][0]
356:     var rel2 = pose_shared[18][0]
357:     var rel3 = pose_shared[19][0]
358:     var rel4 = pose_shared[20][0]
359:     var rel5 = pose_shared[21][0]
360:     var rel6 = pose_shared[22][0]
361:     var rel7 = pose_shared[23][0]
