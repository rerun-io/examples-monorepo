1178: def refine_matches_kernel(
1179:     D11: UnsafePointer[Float32, MutAnyOrigin],
1180:     D21: UnsafePointer[Float32, MutAnyOrigin],
1181:     p1: UnsafePointer[Int64, MutAnyOrigin],
1182:     p1_new: UnsafePointer[Int64, MutAnyOrigin],
1183:     h: Int,
1184:     w: Int,
1185:     num_pts: Int,
1186:     fdim: Int,
1187:     radius: Int,
1188:     dilation_max: Int,
1189: ):
1190:     """Descriptor-based match refinement kernel (float32 path)."""
1191:     var n: UInt = block_idx.x * block_dim.x + thread_idx.x
1192:     var b: UInt = block_idx.y
1193: 
1194:     if n >= UInt(num_pts):
1195:         return
1196: 
1197:     var d11_stride_b: Int = h * w * fdim
1198:     var d11_stride_v: Int = w * fdim
1199:     var d21_stride_b: Int = num_pts * fdim
1200:     var p_stride_b: Int = num_pts * 2
1201: 
1202:     var p_base: Int = Int(b) * p_stride_b + Int(n) * 2
1203:     var u0: Int = Int(p1[p_base + 0])
1204:     var v0: Int = Int(p1[p_base + 1])
1205: 
1206:     # Pre-compute query descriptor base (loop-invariant)
1207:     var d21_base: Int = Int(b) * d21_stride_b + Int(n) * fdim
1208: 
1209:     var max_score: Float32 = -3.4028235e+38
1210:     var u_new: Int = u0
1211:     var v_new: Int = v0
1212: 
1213:     for d in range(dilation_max, 0, -1):
1214:         var rd: Int = radius * d
1215:         var diam: Int = 2 * rd + 1
1216:         var i: Int = 0
1217:         while i < diam:
1218:             var j: Int = 0
1219:             while j < diam:
1220:                 var u_cand: Int = u0 - rd + i
1221:                 var v_cand: Int = v0 - rd + j
1222: 
1223:                 if v_cand >= 0 and v_cand < h and u_cand >= 0 and u_cand < w:
1224:                     var score: Float32 = 0.0
1225:                     var d11_base: Int = Int(b) * d11_stride_b + v_cand * d11_stride_v + u_cand * fdim
1226:                     # SIMD-4 vectorized dot product
1227:                     var k: Int = 0
1228:                     while k + 4 <= fdim:
1229:                         var v21 = D21.load[width=4](d21_base + k)
1230:                         var v11 = D11.load[width=4](d11_base + k)
1231:                         score += (v21 * v11).reduce_add()
1232:                         k += 4
1233:                     # Scalar remainder
1234:                     while k < fdim:
1235:                         score += D21[d21_base + k] * D11[d11_base + k]
1236:                         k += 1
1237: 
1238:                     if score > max_score:
1239:                         max_score = score
1240:                         u_new = u_cand
1241:                         v_new = v_cand
1242: 
1243:                 j += d
1244:             i += d
1245: 
1246:         u0 = u_new
1247:         v0 = v_new
1248: 
1249:     p1_new[p_base + 0] = Int64(u_new)
1250:     p1_new[p_base + 1] = Int64(v_new)
1251: 
1252: 
1253: def refine_matches_kernel_f16(
1254:     D11: UnsafePointer[Float16, MutAnyOrigin],
1255:     D21: UnsafePointer[Float16, MutAnyOrigin],
1256:     p1: UnsafePointer[Int64, MutAnyOrigin],
1257:     p1_new: UnsafePointer[Int64, MutAnyOrigin],
1258:     h: Int,
1259:     w: Int,
1260:     num_pts: Int,
1261:     fdim: Int,
1262:     radius: Int,
1263:     dilation_max: Int,
1264: ):
1265:     """Descriptor-based match refinement kernel (float16 path).
1266: 
1267:     Reads float16 descriptors directly, accumulates dot products in float32.
1268:     """
1269:     var n: UInt = block_idx.x * block_dim.x + thread_idx.x
1270:     var b: UInt = block_idx.y
1271: 
1272:     if n >= UInt(num_pts):
1273:         return
1274: 
1275:     var d11_stride_b: Int = h * w * fdim
1276:     var d11_stride_v: Int = w * fdim
1277:     var d21_stride_b: Int = num_pts * fdim
1278:     var p_stride_b: Int = num_pts * 2
1279: 
1280:     var p_base: Int = Int(b) * p_stride_b + Int(n) * 2
1281:     var u0: Int = Int(p1[p_base + 0])
1282:     var v0: Int = Int(p1[p_base + 1])
1283: 
1284:     var d21_base: Int = Int(b) * d21_stride_b + Int(n) * fdim
1285: 
1286:     var max_score: Float32 = -3.4028235e+38
1287:     var u_new: Int = u0
1288:     var v_new: Int = v0
1289: 
1290:     for d in range(dilation_max, 0, -1):
1291:         var rd: Int = radius * d
1292:         var diam: Int = 2 * rd + 1
1293:         var i: Int = 0
1294:         while i < diam:
1295:             var j: Int = 0
1296:             while j < diam:
1297:                 var u_cand: Int = u0 - rd + i
1298:                 var v_cand: Int = v0 - rd + j
1299: 
1300:                 if v_cand >= 0 and v_cand < h and u_cand >= 0 and u_cand < w:
1301:                     # SIMD-8 vectorized dot product (8 × f16 = 128 bits),
1302:                     # accumulated in float32 for precision.
1303:                     var score: Float32 = 0.0
1304:                     var d11_base: Int = Int(b) * d11_stride_b + v_cand * d11_stride_v + u_cand * fdim
1305:                     var k: Int = 0
1306:                     while k + 8 <= fdim:
1307:                         var v21 = D21.load[width=8](d21_base + k)
1308:                         var v11 = D11.load[width=8](d11_base + k)
1309:                         score += (v21.cast[DType.float32]() * v11.cast[DType.float32]()).reduce_add()
1310:                         k += 8
1311:                     # Scalar remainder
1312:                     while k < fdim:
1313:                         score += Float32(D21[d21_base + k]) * Float32(D11[d11_base + k])
1314:                         k += 1
1315: 
1316:                     if score > max_score:
1317:                         max_score = score
1318:                         u_new = u_cand
1319:                         v_new = v_cand
1320: 
1321:                 j += d
1322:             i += d
1323: 
1324:         u0 = u_new
1325:         v0 = v_new
1326: 
1327:     p1_new[p_base + 0] = Int64(u_new)
1328:     p1_new[p_base + 1] = Int64(v_new)
1329: 
1330: 
1331: def refine_matches_kernel_f16_cached[
1332:     FDIM: Int,
1333:     BLOCK_SIZE: Int,
1334: ](
1335:     D11: UnsafePointer[Float16, MutAnyOrigin],
1336:     D21: UnsafePointer[Float16, MutAnyOrigin],
1337:     p1: UnsafePointer[Int64, MutAnyOrigin],
1338:     p1_new: UnsafePointer[Int64, MutAnyOrigin],
1339:     h: Int,
1340:     w: Int,
1341:     num_pts: Int,
1342: ):
1343:     """Specialized f16 refinement kernel for the common radius=2, dilation=2 case.
1344: 
1345:     Each thread copies its query descriptor into shared memory once, then reuses
1346:     it across all candidate scores. This reduces repeated global reads of D21.
1347:     """
1348:     var n: UInt = block_idx.x * block_dim.x + thread_idx.x
1349:     var b: UInt = block_idx.y
1350: 
1351:     if n >= UInt(num_pts):
1352:         return
1353: 
1354:     comptime CHUNKS = FDIM // 8
1355: 
1356:     var q_shared = stack_allocation[
1357:         BLOCK_SIZE * CHUNKS,
1358:         SIMD[DType.float16, 8],
1359:         address_space=AddressSpace.SHARED,
1360:     ]()
1361: 
1362:     var d11_stride_b: Int = h * w * FDIM
1363:     var d11_stride_v: Int = w * FDIM
1364:     var d21_stride_b: Int = num_pts * FDIM
1365:     var p_stride_b: Int = num_pts * 2
1366: 
1367:     var p_base: Int = Int(b) * p_stride_b + Int(n) * 2
1368:     var u0: Int = Int(p1[p_base + 0])
1369:     var v0: Int = Int(p1[p_base + 1])
1370:     var d21_base: Int = Int(b) * d21_stride_b + Int(n) * FDIM
1371:     var q_shared_base: Int = Int(thread_idx.x) * CHUNKS
1372: 
1373:     comptime for chunk in range(CHUNKS):
1374:         q_shared[q_shared_base + chunk] = D21.load[width=8](
1375:             d21_base + chunk * 8
1376:         )
1377:     barrier()
1378: 
1379:     var max_score: Float32 = -3.4028235e+38
1380:     var u_new: Int = u0
1381:     var v_new: Int = v0
1382: 
1383:     for d in range(2, 0, -1):
1384:         var rd: Int = 2 * d
1385:         var diam: Int = 2 * rd + 1
1386:         var i: Int = 0
1387:         while i < diam:
1388:             var j: Int = 0
1389:             while j < diam:
1390:                 var u_cand: Int = u0 - rd + i
1391:                 var v_cand: Int = v0 - rd + j
1392: 
1393:                 if v_cand >= 0 and v_cand < h and u_cand >= 0 and u_cand < w:
1394:                     var score: Float32 = 0.0
1395:                     var d11_base: Int = Int(b) * d11_stride_b + v_cand * d11_stride_v + u_cand * FDIM
1396:                     comptime for chunk in range(CHUNKS):
1397:                         var q = q_shared[q_shared_base + chunk]
1398:                         var v11 = D11.load[width=8](
1399:                             d11_base + chunk * 8
1400:                         )
1401:                         score += (
1402:                             q.cast[DType.float32]() * v11.cast[DType.float32]()
1403:                         ).reduce_add()
1404: 
1405:                     if score > max_score:
1406:                         max_score = score
1407:                         u_new = u_cand
1408:                         v_new = v_cand
1409: 
1410:                 j += d
1411:             i += d
1412: 
1413:         u0 = u_new
1414:         v0 = v_new
1415: 
1416:     p1_new[p_base + 0] = Int64(u_new)
1417:     p1_new[p_base + 1] = Int64(v_new)
1418: 
1419: 
1420: # ─── Python-facing wrapper functions ──────────────────────────────────────────
1421: 
1422: def iter_proj_py(
1423:     rays_img_obj: PythonObject,
1424:     pts_3d_norm_obj: PythonObject,
1425:     p_init_obj: PythonObject,
1426:     max_iter_obj: PythonObject,
1427:     lambda_init_obj: PythonObject,
1428:     cost_thresh_obj: PythonObject,
1429: ) raises -> PythonObject:
1430:     """Drop-in replacement for mast3r_slam_backends.iter_proj."""
1431:     var torch = Python.import_module("torch")
1432: 
1433:     # Ensure inputs are contiguous
1434:     var rays_img: PythonObject = rays_img_obj.contiguous()
1435:     var pts_3d_norm: PythonObject = pts_3d_norm_obj.contiguous()
1436:     var p_init: PythonObject = p_init_obj.contiguous()
1437: 
1438:     # Extract shapes
1439:     var batch: Int = Int(py=rays_img.shape[0])
1440:     var h: Int = Int(py=rays_img.shape[1])
1441:     var w: Int = Int(py=rays_img.shape[2])
1442:     var num_pts: Int = Int(py=pts_3d_norm.shape[1])
1443:     var max_iter: Int = Int(py=max_iter_obj)
1444:     var lambda_init: Float64 = Float64(py=lambda_init_obj)
1445:     var cost_thresh: Float64 = Float64(py=cost_thresh_obj)
1446: 
1447:     # No torch.cuda.synchronize() — CUDA stream ordering handles dependencies.
1448: 
1449:     # Allocate output tensors via torch.empty (kernel writes all positions)
1450:     var p_new: PythonObject = torch.empty(
1451:         Python.list(batch, num_pts, 2),
1452:         device=rays_img.device,
1453:         dtype=torch.float32,
1454:     )
1455:     # Allocate directly as bool — PyTorch stores bool as uint8 internally,
1456:     # so the kernel can write UInt8 (0/1) to it without a .to(bool) cast.
1457:     var converged: PythonObject = torch.empty(
1458:         Python.list(batch, num_pts),
1459:         device=rays_img.device,
1460:         dtype=torch.bool,
1461:     )
1462: 
1463:     # Get raw CUDA pointers
1464:     var rays_ptr: Int = Int(py=rays_img.data_ptr())
1465:     var pts_ptr: Int = Int(py=pts_3d_norm.data_ptr())
1466:     var pinit_ptr: Int = Int(py=p_init.data_ptr())
1467:     var pnew_ptr: Int = Int(py=p_new.data_ptr())
1468:     var conv_ptr: Int = Int(py=converged.data_ptr())
1469: 
1470:     var rays_uptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=rays_ptr)
1471:     var pts_uptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=pts_ptr)
1472:     var pinit_uptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=pinit_ptr)
1473:     var pnew_uptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=pnew_ptr)
1474:     var conv_uptr = UnsafePointer[UInt8, MutAnyOrigin](unsafe_from_address=conv_ptr)
1475: 
1476:     var ctx_ptr = get_cached_context_ptr()
1477:     var block_size: Int = choose_iter_proj_block(num_pts)
1478:     var num_blocks_x: Int = ceildiv(num_pts, block_size)
1479:     ctx_ptr[].enqueue_function[iter_proj_kernel, iter_proj_kernel](
1480:         rays_uptr,
1481:         pts_uptr,
1482:         pinit_uptr,
1483:         pnew_uptr,
1484:         conv_uptr,
1485:         h,
1486:         w,
1487:         num_pts,
1488:         max_iter,
1489:         Float32(lambda_init),
1490:         Float32(cost_thresh),
1491:         grid_dim=(num_blocks_x, batch),
1492:         block_dim=block_size,
1493:     )
1494:     # Device-wide sync to ensure Mojo's kernel completes before PyTorch's
1495:     # caching allocator can recycle the output buffer on a subsequent call.
1496:     Python.import_module("torch").cuda.synchronize()
1497:     # PyTorch ops on the same default stream will wait automatically.
1498: 
1499:     return Python.tuple(p_new, converged)
1500: 
1501: 
1502: def refine_matches_py(
1503:     D11_obj: PythonObject,
1504:     D21_obj: PythonObject,
1505:     p1_obj: PythonObject,
1506:     radius_obj: PythonObject,
1507:     dilation_max_obj: PythonObject,
1508: ) raises -> PythonObject:
1509:     """Drop-in replacement for mast3r_slam_backends.refine_matches."""
1510:     var torch = Python.import_module("torch")
1511: 
1512:     var p1: PythonObject = p1_obj.contiguous()
1513: 
1514:     # Shapes from original (possibly half) inputs
1515:     var batch: Int = Int(py=D11_obj.shape[0])
1516:     var h: Int = Int(py=D11_obj.shape[1])
1517:     var w: Int = Int(py=D11_obj.shape[2])
1518:     var fdim: Int = Int(py=D11_obj.shape[3])
1519:     var num_pts: Int = Int(py=p1.shape[1])
1520:     var radius: Int = Int(py=radius_obj)
1521:     var dilation_max: Int = Int(py=dilation_max_obj)
1522: 
1523:     # Allocate output
1524:     var p1_new: PythonObject = torch.empty(
1525:         Python.list(batch, num_pts, 2),
1526:         device=p1.device,
1527:         dtype=p1.dtype,
1528:     )
1529: 
1530:     var p1_ptr: Int = Int(py=p1.data_ptr())
1531:     var p1_new_ptr: Int = Int(py=p1_new.data_ptr())
1532:     var p1_uptr = UnsafePointer[Int64, MutAnyOrigin](unsafe_from_address=p1_ptr)
1533:     var p1_new_uptr = UnsafePointer[Int64, MutAnyOrigin](unsafe_from_address=p1_new_ptr)
1534: 
1535:     var ctx_ptr = get_cached_context_ptr()
1536:     var block_size: Int = choose_refine_block(num_pts, fdim)
1537:     var num_blocks_x: Int = ceildiv(num_pts, block_size)
1538: 
1539:     # Dispatch float16 vs float32 to avoid half→float copy overhead (~7 µs)
1540:     var is_half: Bool = Bool(D11_obj.dtype == torch.float16)
1541: 
1542:     if is_half:
1543:         var D11: PythonObject = D11_obj.contiguous()
1544:         var D21: PythonObject = D21_obj.contiguous()
1545:         var d11_ptr: Int = Int(py=D11.data_ptr())
1546:         var d21_ptr: Int = Int(py=D21.data_ptr())
1547:         var d11_uptr = UnsafePointer[Float16, MutAnyOrigin](unsafe_from_address=d11_ptr)
1548:         var d21_uptr = UnsafePointer[Float16, MutAnyOrigin](unsafe_from_address=d21_ptr)
1549: 
1550:         # Specialize the hot MASt3R-SLAM path so the compiler can unroll the
1551:         # inner dot product and we only read each query descriptor once.
1552:         if radius == 2 and dilation_max == 2 and block_size == 8 and fdim == 16:
1553:             comptime kernel = refine_matches_kernel_f16_cached[16, 8]
1554:             ctx_ptr[].enqueue_function[kernel, kernel](
1555:                 d11_uptr,
1556:                 d21_uptr,
1557:                 p1_uptr,
1558:                 p1_new_uptr,
1559:                 h, w, num_pts,
1560:                 grid_dim=(num_blocks_x, batch),
1561:                 block_dim=block_size,
1562:             )
1563:         elif radius == 2 and dilation_max == 2 and block_size == 16 and fdim == 128:
1564:             comptime kernel = refine_matches_kernel_f16_cached[128, 16]
1565:             ctx_ptr[].enqueue_function[kernel, kernel](
1566:                 d11_uptr,
1567:                 d21_uptr,
1568:                 p1_uptr,
1569:                 p1_new_uptr,
1570:                 h, w, num_pts,
1571:                 grid_dim=(num_blocks_x, batch),
1572:                 block_dim=block_size,
1573:             )
1574:         else:
1575:             ctx_ptr[].enqueue_function[refine_matches_kernel_f16, refine_matches_kernel_f16](
1576:                 d11_uptr,
1577:                 d21_uptr,
1578:                 p1_uptr,
1579:                 p1_new_uptr,
1580:                 h, w, num_pts, fdim, radius, dilation_max,
1581:                 grid_dim=(num_blocks_x, batch),
1582:                 block_dim=block_size,
1583:             )
1584:     else:
1585:         var D11: PythonObject = D11_obj.contiguous().float()
1586:         var D21: PythonObject = D21_obj.contiguous().float()
1587:         var d11_ptr: Int = Int(py=D11.data_ptr())
1588:         var d21_ptr: Int = Int(py=D21.data_ptr())
1589:         var d11_uptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=d11_ptr)
1590:         var d21_uptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=d21_ptr)
1591: 
1592:         ctx_ptr[].enqueue_function[refine_matches_kernel, refine_matches_kernel](
1593:             d11_uptr,
1594:             d21_uptr,
1595:             p1_uptr,
1596:             p1_new_uptr,
1597:             h, w, num_pts, fdim, radius, dilation_max,
1598:             grid_dim=(num_blocks_x, batch),
1599:             block_dim=block_size,
1600:         )
1601: 
1602:     # Device-wide sync to ensure Mojo's kernel completes before PyTorch's
1603:     # caching allocator can recycle the output buffer on a subsequent call.
1604:     Python.import_module("torch").cuda.synchronize()
1605:     return Python.tuple(p1_new)
