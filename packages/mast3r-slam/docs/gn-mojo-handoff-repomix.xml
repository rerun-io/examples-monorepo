279:     var rb = act_so3_components(qx, qy, qz, qw, x3, x4, x5)
280:     out[3] = rb[0] + s_inv * (ty * ra[2] - tz * ra[1])
281:     out[4] = rb[1] + s_inv * (tz * ra[0] - tx * ra[2])
282:     out[5] = rb[2] + s_inv * (tx * ra[1] - ty * ra[0])
