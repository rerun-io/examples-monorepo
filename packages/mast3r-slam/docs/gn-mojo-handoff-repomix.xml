119: @always_inline
120: def exp_sim3_components(
121:     xi0: Float32, xi1: Float32, xi2: Float32, xi3: Float32, xi4: Float32, xi5: Float32, xi6: Float32,
122: ) -> InlineArray[Float32, 8]:
123:     var tau0: Float32 = xi0
124:     var tau1: Float32 = xi1
125:     var tau2: Float32 = xi2
126:     var phi0: Float32 = xi3
127:     var phi1: Float32 = xi4
128:     var phi2: Float32 = xi5
129:     var sigma: Float32 = xi6
130: 
131:     var scale = exp(sigma)
132:     var q = exp_so3_components(phi0, phi1, phi2)
133: 
134:     var theta_sq = phi0 * phi0 + phi1 * phi1 + phi2 * phi2
135:     var theta = sqrt(theta_sq)
136: 
137:     var A: Float32
138:     var B: Float32
139:     var C: Float32
140:     if abs(sigma) < 1e-6:
141:         C = 1.0
142:         if abs(theta) < 1e-6:
143:             A = 0.5
144:             B = 1.0 / 6.0
145:         else:
146:             A = (1.0 - cos(theta)) / theta_sq
147:             B = (theta - sin(theta)) / (theta_sq * theta)
148:     else:
149:         C = (scale - 1.0) / sigma
150:         if abs(theta) < 1e-6:
151:             var sigma_sq = sigma * sigma
152:             A = ((sigma - 1.0) * scale + 1.0) / sigma_sq
153:             B = (scale * 0.5 * sigma_sq + scale - 1.0 - sigma * scale) / (sigma_sq * sigma)
154:         else:
155:             var a = scale * sin(theta)
156:             var b = scale * cos(theta)
157:             var c = theta_sq + sigma * sigma
158:             A = (a * sigma + (1.0 - b) * theta) / (theta * c)
159:             B = (C - (((b - 1.0) * sigma + a * theta) / c)) / theta_sq
160: 
161:     var out = InlineArray[Float32, 8](fill=0.0)
162:     out[0] = C * tau0
163:     out[1] = C * tau1
164:     out[2] = C * tau2
165: 
166:     var cx0: Float32 = phi1 * tau2 - phi2 * tau1
167:     var cx1: Float32 = phi2 * tau0 - phi0 * tau2
168:     var cx2: Float32 = phi0 * tau1 - phi1 * tau0
169:     out[0] += A * cx0
170:     out[1] += A * cx1
171:     out[2] += A * cx2
172: 
173:     var c2x0: Float32 = phi1 * cx2 - phi2 * cx1
174:     var c2x1: Float32 = phi2 * cx0 - phi0 * cx2
175:     var c2x2: Float32 = phi0 * cx1 - phi1 * cx0
176:     out[0] += B * c2x0
177:     out[1] += B * c2x1
178:     out[2] += B * c2x2
179:     out[3] = q[0]
180:     out[4] = q[1]
181:     out[5] = q[2]
182:     out[6] = q[3]
183:     out[7] = scale
184:     return out^
