 415: __global__ void pose_retr_kernel(
 416:     torch::PackedTensorAccessor32<float,2,torch::RestrictPtrTraits> poses,
 417:     const torch::PackedTensorAccessor32<float,2,torch::RestrictPtrTraits> dx,
 418:     const int num_fix) 
 419: {
 420:   const int num_poses = poses.size(0);
 421: 
 422:   for (int k=num_fix+threadIdx.x; k<num_poses; k+=blockDim.x) {
 423:     float xi[7], q[4], q1[4], t[3], t1[3], s[1], s1[1];
 424: 
 425:     t[0] = poses[k][0];
 426:     t[1] = poses[k][1];
 427:     t[2] = poses[k][2];
 428: 
 429:     q[0] = poses[k][3];
 430:     q[1] = poses[k][4];
 431:     q[2] = poses[k][5];
 432:     q[3] = poses[k][6];
 433: 
 434:     s[0] = poses[k][7];
 435:     
 436:     for (int n=0; n<7; n++) {
 437:       xi[n] = dx[k-num_fix][n];
 438:     }
 439: 
 440:     retrSim3(xi, t, q, s, t1, q1, s1);
 441: 
 442:     poses[k][0] = t1[0];
 443:     poses[k][1] = t1[1];
 444:     poses[k][2] = t1[2];
 445: 
 446:     poses[k][3] = q1[0];
 447:     poses[k][4] = q1[1];
 448:     poses[k][5] = q1[2];
 449:     poses[k][6] = q1[3];
 450: 
 451:     poses[k][7] = s1[0];
 452:   }
 453: }
