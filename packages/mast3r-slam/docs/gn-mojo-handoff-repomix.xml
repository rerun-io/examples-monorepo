<file path="packages/mast3r-slam/tools/bench_max_pose_retr.py">
 1: #!/usr/bin/env python
 2: from __future__ import annotations
 3: 
 4: import sys
 5: from pathlib import Path
 6: 
 7: import torch
 8: 
 9: PACKAGE_ROOT = Path(__file__).resolve().parents[1]
10: if str(PACKAGE_ROOT) not in sys.path:
11:     sys.path.insert(0, str(PACKAGE_ROOT))
12: 
13: from mast3r_slam import _backends as cuda_be
14: from mast3r_slam import max_ops
15: 
16: 
17: def bench(fn, warmup: int = 20, runs: int = 100) -> float:
18:     for _ in range(warmup):
19:         fn()
20:     torch.cuda.synchronize()
21:     timings: list[float] = []
22:     for _ in range(runs):
23:         start = torch.cuda.Event(enable_timing=True)
24:         end = torch.cuda.Event(enable_timing=True)
25:         start.record()
26:         fn()
27:         end.record()
28:         torch.cuda.synchronize()
29:         timings.append(start.elapsed_time(end))
30:     return float(torch.tensor(timings).median())
31: 
32: 
33: def main() -> None:
34:     assert torch.cuda.is_available(), "CUDA required"
35:     gen = torch.Generator(device="cuda").manual_seed(0)
36:     poses = torch.randn(64, 8, device="cuda", generator=gen, dtype=torch.float32)
37:     poses[:, 6] = 1.0
38:     poses[:, 7] = 1.0
39:     dx = torch.randn(63, 7, device="cuda", generator=gen, dtype=torch.float32) * 1e-3
40:     num_fix = 1
41: 
42:     cuda_ms = bench(lambda: cuda_be.pose_retr(poses.clone(), dx, num_fix))
43:     max_ms = bench(lambda: max_ops.pose_retr(poses.clone(), dx, num_fix))
44:     ratio = max_ms / max(cuda_ms, 1e-9)
45:     print(f"{'name':<16} {'cuda ms':>10} {'max ms':>10} {'ratio':>8}")
46:     print(f"{'pose_retr':<16} {cuda_ms:>10.3f} {max_ms:>10.3f} {ratio:>8.3f}")
47: 
48: 
49: if __name__ == "__main__":
50:     main()
</file>

<file path="packages/mast3r-slam/mast3r_slam/max_ops.py">
 1: from __future__ import annotations
 2: 
 3: from functools import lru_cache
 4: from pathlib import Path
 5: 
 6: import torch
 7: from torch import Tensor
 8: 
 9: 
10: def _ops_root() -> Path:
11:     return Path(__file__).resolve().parent / "backend" / "max_ops" / "gn_ops"
12: 
13: 
14: @lru_cache(maxsize=1)
15: def load_gn_custom_ops():
16:     from max.experimental.torch import CustomOpLibrary
17: 
18:     return CustomOpLibrary(_ops_root())
19: 
20: 
21: @lru_cache(maxsize=32)
22: def _num_fix_tensor(device_index: int, num_fix: int) -> Tensor:
23:     return torch.tensor([num_fix], device=torch.device("cuda", device_index), dtype=torch.int32)
24: 
25: 
26: def pose_retr(poses: Tensor, dx: Tensor, num_fix: int) -> Tensor:
27:     ops = load_gn_custom_ops()
28:     device_index = poses.device.index
29:     if device_index is None:
30:         raise ValueError("pose_retr requires a CUDA tensor")
31:     num_fix_tensor = _num_fix_tensor(device_index, num_fix)
32:     if hasattr(ops, "pose_retr_launch"):
33:         ops.pose_retr_launch(poses, poses, dx.contiguous(), num_fix_tensor)
34:     else:
35:         ops.pose_retr(poses, poses, dx.contiguous(), num_fix_tensor)
36:     return poses
37: 
38: 
39: def has_pose_retr() -> bool:
40:     try:
41:         _ = load_gn_custom_ops()
42:     except Exception:
43:         return False
44:     return True
</file>

