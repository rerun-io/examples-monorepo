1185: std::vector<torch::Tensor> gauss_newton_rays_cuda(
1186:   torch::Tensor Twc, torch::Tensor Xs, torch::Tensor Cs,
1187:   torch::Tensor ii, torch::Tensor jj, 
1188:   torch::Tensor idx_ii2jj, torch::Tensor valid_match,
1189:   torch::Tensor Q,
1190:   const float sigma_ray,
1191:   const float sigma_dist,
1192:   const float C_thresh,
1193:   const float Q_thresh,
1194:   const int max_iter,
1195:   const float delta_thresh)
1196: {
1197:   auto opts = Twc.options();
1198:   const int num_edges = ii.size(0);
1199:   const int num_poses = Xs.size(0);
1200:   const int n = Xs.size(1);
1201: 
1202:   const int num_fix = 1;
1203: 
1204:   // Setup indexing
1205:   torch::Tensor unique_kf_idx = get_unique_kf_idx(ii, jj);
1206:   // For edge construction
1207:   std::vector<torch::Tensor> inds = create_inds(unique_kf_idx, 0, ii, jj);
1208:   torch::Tensor ii_edge = inds[0];
1209:   torch::Tensor jj_edge = inds[1];
1210:   // For linear system indexing (pin=2 because fixing first two poses)
1211:   std::vector<torch::Tensor> inds_opt = create_inds(unique_kf_idx, num_fix, ii, jj);
1212:   torch::Tensor ii_opt = inds_opt[0];
1213:   torch::Tensor jj_opt = inds_opt[1];
1214: 
1215:   const int pose_dim = 7; // sim3
1216: 
1217:   // initialize buffers
1218:   torch::Tensor Hs = torch::zeros({4, num_edges, pose_dim, pose_dim}, opts);
1219:   torch::Tensor gs = torch::zeros({2, num_edges, pose_dim}, opts);
1220: 
1221:   // For debugging outputs
1222:   torch::Tensor dx;
1223: 
1224:   torch::Tensor delta_norm;
1225: 
1226:   for (int itr=0; itr<max_iter; itr++) {
1227: 
1228:     ray_align_kernel<<<num_edges, THREADS>>>(
1229:       Twc.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
1230:       Xs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1231:       Cs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1232:       ii_edge.packed_accessor32<long,1,torch::RestrictPtrTraits>(),
1233:       jj_edge.packed_accessor32<long,1,torch::RestrictPtrTraits>(),
1234:       idx_ii2jj.packed_accessor32<long,2,torch::RestrictPtrTraits>(),
1235:       valid_match.packed_accessor32<bool,3,torch::RestrictPtrTraits>(),
1236:       Q.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1237:       Hs.packed_accessor32<float,4,torch::RestrictPtrTraits>(),
1238:       gs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1239:       sigma_ray, sigma_dist, C_thresh, Q_thresh
1240:     );
1241: 
1242: 
1243:     // pose x pose block
1244:     SparseBlock A(num_poses - num_fix, pose_dim);
1245: 
1246:     A.update_lhs(Hs.reshape({-1, pose_dim, pose_dim}), 
1247:         torch::cat({ii_opt, ii_opt, jj_opt, jj_opt}), 
1248:         torch::cat({ii_opt, jj_opt, ii_opt, jj_opt}));
1249: 
1250:     A.update_rhs(gs.reshape({-1, pose_dim}), 
1251:         torch::cat({ii_opt, jj_opt}));
1252: 
1253:     // NOTE: Accounting for negative here!
1254:     dx = -A.solve();
1255: 
1256:     //
1257:     pose_retr_kernel<<<1, THREADS>>>(
1258:       Twc.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
1259:       dx.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
1260:       num_fix);
1261: 
1262:     // Termination criteria
1263:     // Need to specify this second argument otherwise ambiguous function call...
1264:     delta_norm = torch::linalg_norm(dx, std::optional<c10::Scalar>(), {}, false, {});
1265:     if (delta_norm.item<float>() < delta_thresh) {
1266:       break;
1267:     }
1268:         
1269: 
1270:   }
1271: 
1272:   return {dx}; // For debugging
1273: }
