 31: # ─── GPU Kernel Helpers ───────────────────────────────────────────────────────
 32: 
 33: 
 34: @always_inline
 35: def bilinear_sample(
 36:     data: UnsafePointer[Float32, MutAnyOrigin],
 37:     off11: Int, off12: Int, off21: Int, off22: Int,
 38:     w11: Float32, w12: Float32, w21: Float32, w22: Float32,
 39:     ch: Int,
 40: ) -> Float32:
 41:     """Sample a single channel from four bilinear corners.
 42: 
 43:     The corners are named by their bilinear weight, NOT their spatial position
 44:     (pixels are opposite the area weights — same convention as the CUDA kernel).
 45:     """
 46:     return (
 47:         w11 * data[off11 + ch]
 48:         + w12 * data[off12 + ch]
 49:         + w21 * data[off21 + ch]
 50:         + w22 * data[off22 + ch]
 51:     )
 52: 
 53: 
 54: @always_inline
 55: def bilinear_corners(
 56:     base_b: Int, rays_stride_v: Int,
 57:     v11: Int, u11: Int,
 58: ) -> InlineArray[Int, 4]:
 59:     """Compute the four corner offsets for bilinear interpolation.
 60: 
 61:     Returns [bottom-right, bottom-left, top-right, top-left] offsets.
 62:     NOTE: pixels opposite the area weights (same as CUDA kernel).
 63:     """
 64:     var offsets = InlineArray[Int, 4](fill=0)
 65:     offsets[0] = base_b + (v11 + 1) * rays_stride_v + (u11 + 1) * 9  # bottom-right
 66:     offsets[1] = base_b + (v11 + 1) * rays_stride_v + u11 * 9        # bottom-left
 67:     offsets[2] = base_b + v11 * rays_stride_v + (u11 + 1) * 9        # top-right
 68:     offsets[3] = base_b + v11 * rays_stride_v + u11 * 9              # top-left
 69:     return offsets^
 70: 
 71: 
 72: @always_inline
 73: def bilinear_weights(du: Float32, dv: Float32) -> InlineArray[Float32, 4]:
 74:     """Compute bilinear interpolation weights from fractional pixel offsets."""
 75:     var w = InlineArray[Float32, 4](fill=Float32(0.0))
 76:     w[0] = du * dv
 77:     w[1] = (1.0 - du) * dv
 78:     w[2] = du * (1.0 - dv)
 79:     w[3] = (1.0 - du) * (1.0 - dv)
 80:     return w^
 81: 
 82: 
 83: @always_inline
 84: def normalize_ray(
 85:     r0: Float32, r1: Float32, r2: Float32,
 86: ) -> InlineArray[Float32, 3]:
 87:     """Normalize a 3D ray direction to unit length."""
 88:     var r_norm: Float32 = sqrt(r0 * r0 + r1 * r1 + r2 * r2)
 89:     var r_inv: Float32 = 1.0 / r_norm
 90:     var out = InlineArray[Float32, 3](fill=Float32(0.0))
 91:     out[0] = r0 * r_inv
 92:     out[1] = r1 * r_inv
 93:     out[2] = r2 * r_inv
 94:     return out^
 95: 
 96: 
 97: # ─── GPU Kernels ──────────────────────────────────────────────────────────────
 98: 
 99: def iter_proj_kernel(
100:     rays_img: UnsafePointer[Float32, MutAnyOrigin],
101:     pts_3d_norm: UnsafePointer[Float32, MutAnyOrigin],
102:     p_init: UnsafePointer[Float32, MutAnyOrigin],
103:     p_new: UnsafePointer[Float32, MutAnyOrigin],
104:     converged: UnsafePointer[UInt8, MutAnyOrigin],
105:     h: Int,
106:     w: Int,
107:     num_pts: Int,
108:     max_iter: Int,
109:     lambda_init: Float32,
110:     cost_thresh: Float32,
111: ):
112:     """Levenberg-Marquardt iterative projection kernel.
113: 
114:     Each thread processes one point: bilinear-interpolates rays at the current
115:     pixel, normalises, computes error against the target 3D direction, builds a
116:     2x2 LM system, solves for a pixel update, and accepts/rejects based on cost.
117: 
118:     Mirrors the CUDA kernel in matching_kernels.cu:iter_proj_kernel (lines 119-275).
119:     """
120:     # ── Thread indexing ──
121:     var n: UInt = block_idx.x * block_dim.x + thread_idx.x
122:     var b: UInt = block_idx.y
123: 
124:     if n >= UInt(num_pts):
125:         return
126: 
127:     # ── Strides for row-major tensors ──
128:     var rays_stride_b: Int = h * w * 9
129:     var rays_stride_v: Int = w * 9
130:     var pts_stride_b: Int = num_pts * 3
131:     var p_stride_b: Int = num_pts * 2
132:     var conv_stride_b: Int = num_pts
133: 
134:     # ── Batch-invariant base offsets (hoisted out of loop) ──
135:     var base_b: Int = Int(b) * rays_stride_b
136:     var conv_idx: Int = Int(b) * conv_stride_b + Int(n)
137: 
138:     # ── Load initial pixel and clamp to valid bilinear range ──
139:     var u: Float32 = p_init[Int(b) * p_stride_b + Int(n) * 2 + 0]
140:     var v: Float32 = p_init[Int(b) * p_stride_b + Int(n) * 2 + 1]
141:     u = min(max(u, Float32(1.0)), Float32(w - 2))
142:     v = min(max(v, Float32(1.0)), Float32(h - 2))
143: 
144:     # ── Load target point once (loop-invariant) ──
145:     var pts_base: Int = Int(b) * pts_stride_b + Int(n) * 3
146:     var t0: Float32 = pts_3d_norm[pts_base + 0]
147:     var t1: Float32 = pts_3d_norm[pts_base + 1]
148:     var t2: Float32 = pts_3d_norm[pts_base + 2]
149: 
150:     var lam: Float32 = lambda_init
151: 
152:     for _i in range(max_iter):
153:         # ── Bilinear interpolation at current pixel ──
154:         var u11: Int = Int(floor(u))
155:         var v11: Int = Int(floor(v))
156:         var wt = bilinear_weights(u - Float32(u11), v - Float32(v11))
157:         var off = bilinear_corners(base_b, rays_stride_v, v11, u11)
158: 
159:         # Interpolate ray (ch 0-2), gx (ch 3-5), gy (ch 6-8)
160:         var r0: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 0)
161:         var r1: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 1)
162:         var r2: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 2)
163: 
164:         var gx0: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 3)
165:         var gx1: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 4)
166:         var gx2: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 5)
167: 
168:         var gy0: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 6)
169:         var gy1: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 7)
170:         var gy2: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 8)
171: 
172:         # ── Normalize ray ──
173:         var r = normalize_ray(r0, r1, r2)
174:         r0 = r[0]
175:         r1 = r[1]
176:         r2 = r[2]
177: 
178:         # ── Error and cost ──
179:         var e0: Float32 = r0 - t0
180:         var e1: Float32 = r1 - t1
181:         var e2: Float32 = r2 - t2
182:         var cost: Float32 = e0 * e0 + e1 * e1 + e2 * e2
183: 
184:         # ── Build normal equations: J^T J + lambda * I, -J^T r ──
185:         var A00: Float32 = gx0 * gx0 + gx1 * gx1 + gx2 * gx2 + lam
186:         var A01: Float32 = gx0 * gy0 + gx1 * gy1 + gx2 * gy2
187:         var A11: Float32 = gy0 * gy0 + gy1 * gy1 + gy2 * gy2 + lam
188:         var b0: Float32 = -(e0 * gx0 + e1 * gx1 + e2 * gx2)
189:         var b1: Float32 = -(e0 * gy0 + e1 * gy1 + e2 * gy2)
190: 
191:         # ── Solve 2x2 system via Cramer's rule ──
192:         var det_inv: Float32 = 1.0 / (A00 * A11 - A01 * A01)
193:         var delta_u: Float32 = det_inv * (A11 * b0 - A01 * b1)
194:         var delta_v: Float32 = det_inv * (-A01 * b0 + A00 * b1)
195: 
196:         var u_new: Float32 = min(max(u + delta_u, Float32(1.0)), Float32(w - 2))
197:         var v_new: Float32 = min(max(v + delta_v, Float32(1.0)), Float32(h - 2))
198: 
199:         # ── Evaluate new cost at candidate position ──
200:         var u11n: Int = Int(floor(u_new))
201:         var v11n: Int = Int(floor(v_new))
202:         var wtn = bilinear_weights(u_new - Float32(u11n), v_new - Float32(v11n))
203:         var offn = bilinear_corners(base_b, rays_stride_v, v11n, u11n)
204: 
205:         var nr0: Float32 = bilinear_sample(rays_img, offn[0], offn[1], offn[2], offn[3], wtn[0], wtn[1], wtn[2], wtn[3], 0)
206:         var nr1: Float32 = bilinear_sample(rays_img, offn[0], offn[1], offn[2], offn[3], wtn[0], wtn[1], wtn[2], wtn[3], 1)
207:         var nr2: Float32 = bilinear_sample(rays_img, offn[0], offn[1], offn[2], offn[3], wtn[0], wtn[1], wtn[2], wtn[3], 2)
208:         var nr = normalize_ray(nr0, nr1, nr2)
209: 
210:         var ne0: Float32 = nr[0] - t0
211:         var ne1: Float32 = nr[1] - t1
212:         var ne2: Float32 = nr[2] - t2
213:         var new_cost: Float32 = ne0 * ne0 + ne1 * ne1 + ne2 * ne2
214: 
215:         # ── Accept/reject step (Levenberg-Marquardt) ──
216:         if new_cost < cost:
217:             u = u_new
218:             v = v_new
219:             lam *= 0.1
220:             converged[conv_idx] = UInt8(1) if new_cost < cost_thresh else UInt8(0)
221:         else:
222:             lam *= 10.0
223:             converged[conv_idx] = UInt8(1) if cost < cost_thresh else UInt8(0)
224: 
225:     # ── Write final pixel ──
226:     var out_idx: Int = Int(b) * p_stride_b + Int(n) * 2
227:     p_new[out_idx + 0] = u
228:     p_new[out_idx + 1] = v
229: 
230: 
231: def refine_matches_kernel(
232:     D11: UnsafePointer[Float32, MutAnyOrigin],
233:     D21: UnsafePointer[Float32, MutAnyOrigin],
234:     p1: UnsafePointer[Int64, MutAnyOrigin],
235:     p1_new: UnsafePointer[Int64, MutAnyOrigin],
236:     h: Int,
237:     w: Int,
238:     num_pts: Int,
239:     fdim: Int,
240:     radius: Int,
241:     dilation_max: Int,
242: ):
243:     """Descriptor-based match refinement kernel (float32 path)."""
244:     var n: UInt = block_idx.x * block_dim.x + thread_idx.x
245:     var b: UInt = block_idx.y
246: 
247:     if n >= UInt(num_pts):
248:         return
249: 
250:     var d11_stride_b: Int = h * w * fdim
251:     var d11_stride_v: Int = w * fdim
252:     var d21_stride_b: Int = num_pts * fdim
253:     var p_stride_b: Int = num_pts * 2
254: 
255:     var p_base: Int = Int(b) * p_stride_b + Int(n) * 2
256:     var u0: Int = Int(p1[p_base + 0])
257:     var v0: Int = Int(p1[p_base + 1])
258: 
259:     # Pre-compute query descriptor base (loop-invariant)
260:     var d21_base: Int = Int(b) * d21_stride_b + Int(n) * fdim
261: 
262:     var max_score: Float32 = -3.4028235e+38
263:     var u_new: Int = u0
264:     var v_new: Int = v0
265: 
266:     for d in range(dilation_max, 0, -1):
267:         var rd: Int = radius * d
268:         var diam: Int = 2 * rd + 1
269:         var i: Int = 0
270:         while i < diam:
271:             var j: Int = 0
272:             while j < diam:
273:                 var u_cand: Int = u0 - rd + i
274:                 var v_cand: Int = v0 - rd + j
275: 
276:                 if v_cand >= 0 and v_cand < h and u_cand >= 0 and u_cand < w:
277:                     var score: Float32 = 0.0
278:                     var d11_base: Int = Int(b) * d11_stride_b + v_cand * d11_stride_v + u_cand * fdim
279:                     # SIMD-4 vectorized dot product
280:                     var k: Int = 0
281:                     while k + 4 <= fdim:
282:                         var v21 = D21.load[width=4](d21_base + k)
283:                         var v11 = D11.load[width=4](d11_base + k)
284:                         score += (v21 * v11).reduce_add()
285:                         k += 4
286:                     # Scalar remainder
287:                     while k < fdim:
288:                         score += D21[d21_base + k] * D11[d11_base + k]
289:                         k += 1
290: 
291:                     if score > max_score:
292:                         max_score = score
293:                         u_new = u_cand
294:                         v_new = v_cand
295: 
296:                 j += d
297:             i += d
298: 
299:         u0 = u_new
300:         v0 = v_new
301: 
302:     p1_new[p_base + 0] = Int64(u_new)
303:     p1_new[p_base + 1] = Int64(v_new)
304: 
305: 
306: def refine_matches_kernel_f16(
307:     D11: UnsafePointer[Float16, MutAnyOrigin],
308:     D21: UnsafePointer[Float16, MutAnyOrigin],
309:     p1: UnsafePointer[Int64, MutAnyOrigin],
310:     p1_new: UnsafePointer[Int64, MutAnyOrigin],
311:     h: Int,
312:     w: Int,
313:     num_pts: Int,
314:     fdim: Int,
315:     radius: Int,
316:     dilation_max: Int,
317: ):
318:     """Descriptor-based match refinement kernel (float16 path).
319: 
320:     Reads float16 descriptors directly, accumulates dot products in float32.
321:     """
322:     var n: UInt = block_idx.x * block_dim.x + thread_idx.x
323:     var b: UInt = block_idx.y
324: 
325:     if n >= UInt(num_pts):
326:         return
327: 
328:     var d11_stride_b: Int = h * w * fdim
329:     var d11_stride_v: Int = w * fdim
330:     var d21_stride_b: Int = num_pts * fdim
331:     var p_stride_b: Int = num_pts * 2
332: 
333:     var p_base: Int = Int(b) * p_stride_b + Int(n) * 2
334:     var u0: Int = Int(p1[p_base + 0])
335:     var v0: Int = Int(p1[p_base + 1])
336: 
337:     var d21_base: Int = Int(b) * d21_stride_b + Int(n) * fdim
338: 
339:     var max_score: Float32 = -3.4028235e+38
340:     var u_new: Int = u0
341:     var v_new: Int = v0
342: 
343:     for d in range(dilation_max, 0, -1):
344:         var rd: Int = radius * d
345:         var diam: Int = 2 * rd + 1
346:         var i: Int = 0
347:         while i < diam:
348:             var j: Int = 0
349:             while j < diam:
350:                 var u_cand: Int = u0 - rd + i
351:                 var v_cand: Int = v0 - rd + j
352: 
353:                 if v_cand >= 0 and v_cand < h and u_cand >= 0 and u_cand < w:
354:                     # SIMD-8 vectorized dot product (8 × f16 = 128 bits),
355:                     # accumulated in float32 for precision.
356:                     var score: Float32 = 0.0
357:                     var d11_base: Int = Int(b) * d11_stride_b + v_cand * d11_stride_v + u_cand * fdim
358:                     var k: Int = 0
359:                     while k + 8 <= fdim:
360:                         var v21 = D21.load[width=8](d21_base + k)
361:                         var v11 = D11.load[width=8](d11_base + k)
362:                         score += (v21.cast[DType.float32]() * v11.cast[DType.float32]()).reduce_add()
363:                         k += 8
364:                     # Scalar remainder
365:                     while k < fdim:
366:                         score += Float32(D21[d21_base + k]) * Float32(D11[d11_base + k])
367:                         k += 1
368: 
369:                     if score > max_score:
370:                         max_score = score
371:                         u_new = u_cand
372:                         v_new = v_cand
373: 
374:                 j += d
375:             i += d
376: 
377:         u0 = u_new
378:         v0 = v_new
379: 
380:     p1_new[p_base + 0] = Int64(u_new)
381:     p1_new[p_base + 1] = Int64(v_new)
382: 
