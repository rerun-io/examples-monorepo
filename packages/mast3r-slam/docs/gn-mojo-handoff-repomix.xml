 653: def assemble_dense_system_gpu(
 654:     hs: PythonObject,
 655:     gs: PythonObject,
 656:     ii_opt: PythonObject,
 657:     jj_opt: PythonObject,
 658:     n_vars: Int,
 659: ) raises -> PythonObject:
 660:     var torch = get_torch_module()
 661:     var num_edges = Int(py=hs.shape[1])
 662:     var dim = n_vars * POSE_DIM
 663:     var h_dense = torch.zeros(
 664:         Python.list(dim, dim),
 665:         device=hs.device,
 666:         dtype=torch.float64,
 667:     )
 668:     var b_dense = torch.zeros(
 669:         Python.list(n_vars, POSE_DIM),
 670:         device=gs.device,
 671:         dtype=torch.float64,
 672:     )
 673:     if n_vars <= 0:
 674:         return Python.tuple(h_dense, b_dense)
 675: 
 676:     var hs_ptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=Int(py=hs.data_ptr()))
 677:     var gs_ptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=Int(py=gs.data_ptr()))
 678:     var ii_ptr = UnsafePointer[Int64, MutAnyOrigin](unsafe_from_address=Int(py=ii_opt.contiguous().data_ptr()))
 679:     var jj_ptr = UnsafePointer[Int64, MutAnyOrigin](unsafe_from_address=Int(py=jj_opt.contiguous().data_ptr()))
 680:     var h_ptr = UnsafePointer[Float64, MutAnyOrigin](unsafe_from_address=Int(py=h_dense.data_ptr()))
 681:     var b_ptr = UnsafePointer[Float64, MutAnyOrigin](unsafe_from_address=Int(py=b_dense.data_ptr()))
 682: 
 683:     var ctx_ptr = get_cached_context_ptr()
 684:     ctx_ptr[].enqueue_function[assemble_h_dense_kernel, assemble_h_dense_kernel](
 685:         hs_ptr, ii_ptr, jj_ptr, h_ptr, num_edges, n_vars,
 686:         grid_dim=(ceildiv(dim, 16), ceildiv(dim, 16)),
 687:         block_dim=(16, 16),
 688:     )
 689:     ctx_ptr[].enqueue_function[assemble_b_dense_kernel, assemble_b_dense_kernel](
 690:         gs_ptr, ii_ptr, jj_ptr, b_ptr, num_edges, n_vars,
 691:         grid_dim=(ceildiv(n_vars, 16), 1),
 692:         block_dim=(16, POSE_DIM),
 693:     )
 694:     ctx_ptr[].synchronize()
 695:     return Python.tuple(h_dense, b_dense)
