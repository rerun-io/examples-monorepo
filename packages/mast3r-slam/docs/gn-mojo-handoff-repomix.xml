452:                     l += 1
453:             for n in range(POSE_DIM):
454:                 vi[n] += w * err * jxv[n]
455:                 vj[n] += w * err * jxv[n + 7]
456: 
457:         accumulate_row(err0, w0, drx_dpx, drx_dpy, drx_dpz, 0.0, rj2, -rj1, 0.0)
458:         accumulate_row(err1, w1, drx_dpy, dry_dpy, dry_dpz, -rj2, 0.0, rj0, 0.0)
