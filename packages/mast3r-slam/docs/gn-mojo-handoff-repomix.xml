 71:     Twc, Xs, Cs, ii, jj, idx_ii2jj, valid_match, Q = make_graph_fixture()
 72:     K = torch.tensor([[500.0, 0.0, 128.0], [0.0, 500.0, 128.0], [0.0, 0.0, 1.0]], device=DEVICE, dtype=torch.float32)
 73: 
 74:     rows: list[tuple[str, str, BenchResult, BenchResult]] = []
 75:     rows.append((
 76:         "rays_step",
 77:         "synthetic",
 78:         bench(lambda: cuda_be.gauss_newton_rays_step(Twc, Xs, Cs, ii, jj, idx_ii2jj, valid_match, Q, 0.003, 10.0, 0.0, 1.5)),
 79:         bench(lambda: gn_be.gauss_newton_rays_step(Twc, Xs, Cs, ii, jj, idx_ii2jj, valid_match, Q, 0.003, 10.0, 0.0, 1.5)),
 80:     ))
 81:     rows.append((
 82:         "calib_step",
 83:         "synthetic",
 84:         bench(lambda: cuda_be.gauss_newton_calib_step(Twc, Xs, Cs, K, ii, jj, idx_ii2jj, valid_match, Q, 256, 256, -10, 1e-6, 1.0, 10.0, 0.0, 1.5)),
 85:         bench(lambda: gn_be.gauss_newton_calib_step(Twc, Xs, Cs, K, ii, jj, idx_ii2jj, valid_match, Q, 256, 256, -10, 1e-6, 1.0, 10.0, 0.0, 1.5)),
 86:     ))
