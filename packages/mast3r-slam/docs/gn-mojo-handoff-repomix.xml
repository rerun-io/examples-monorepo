 467: __global__ void point_align_kernel(
 468:     const torch::PackedTensorAccessor32<float,2,torch::RestrictPtrTraits> Twc,
 469:     const torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> Xs,
 470:     const torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> Cs,
 471:     const torch::PackedTensorAccessor32<long,1,torch::RestrictPtrTraits> ii,
 472:     const torch::PackedTensorAccessor32<long,1,torch::RestrictPtrTraits> jj,
 473:     const torch::PackedTensorAccessor32<long,2,torch::RestrictPtrTraits> idx_ii2_jj,
 474:     const torch::PackedTensorAccessor32<bool,3,torch::RestrictPtrTraits> valid_match,
 475:     const torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> Q,
 476:     torch::PackedTensorAccessor32<float,4,torch::RestrictPtrTraits> Hs,
 477:     torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> gs,
 478:     const float sigma_point,
 479:     const float C_thresh,
 480:     const float Q_thresh)
 481: {
 482:  
 483:   // Twc and Xs first dim is number of poses
 484:   // ii, jj, Cii, Cjj, Q first dim is number of edges
 485:  
 486:   const int block_id = blockIdx.x;
 487:   const int thread_id = threadIdx.x;
 488:  
 489:   const int num_points = Xs.size(1);
 490:  
 491:   int ix = static_cast<int>(ii[block_id]);
 492:   int jx = static_cast<int>(jj[block_id]);
 493:  
 494:   __shared__ float ti[3], tj[3], tij[3];
 495:   __shared__ float qi[4], qj[4], qij[4];
 496:   __shared__ float si[1], sj[1], sij[1];
 497:  
 498:   __syncthreads();
 499:  
 500:   // load poses from global memory
 501:   if (thread_id < 3) {
 502:     ti[thread_id] = Twc[ix][thread_id];
 503:     tj[thread_id] = Twc[jx][thread_id];
 504:   }
 505:  
 506:   if (thread_id < 4) {
 507:     qi[thread_id] = Twc[ix][thread_id+3];
 508:     qj[thread_id] = Twc[jx][thread_id+3];
 509:   }
 510:  
 511:   if (thread_id < 1) {
 512:     si[thread_id] = Twc[ix][thread_id+7];
 513:     sj[thread_id] = Twc[jx][thread_id+7];
 514:   }
 515:  
 516:   __syncthreads();
 517:  
 518:   // Calculate relative poses
 519:   if (thread_id == 0) {
 520:     relSim3(ti, qi, si, tj, qj, sj, tij, qij, sij);
 521:   }
 522:  
 523:   __syncthreads();
 524:  
 525:   // //points
 526:   float Xi[3];
 527:   float Xj[3];
 528:   float Xj_Ci[3];
 529:  
 530:   // residuals
 531:   float err[3];
 532:   float w[3];
 533:  
 534:   // // jacobians
 535:   float Jx[14];
 536:   // float Jz;
 537:  
 538:   float* Ji = &Jx[0];
 539:   float* Jj = &Jx[7];
 540:  
 541:   // hessians
 542:   const int h_dim = 14*(14+1)/2;
 543:   float hij[h_dim];
 544:  
 545:   float vi[7], vj[7];
 546:  
 547:   int l; // We reuse this variable later for Hessian fill-in
 548:   for (l=0; l<h_dim; l++) {
 549:     hij[l] = 0;
 550:   }
 551:  
 552:   for (int n=0; n<7; n++) {
 553:     vi[n] = 0;
 554:     vj[n] = 0;
 555:   }
 556:  
 557:     // Parameters
 558:   const float sigma_point_inv = 1.0/sigma_point;
 559:  
 560:   __syncthreads();
 561:  
 562:   GPU_1D_KERNEL_LOOP(k, num_points) {
 563:  
 564:     // Get points
 565:     const bool valid_match_ind = valid_match[block_id][k][0]; 
 566:     const int64_t ind_Xi = valid_match_ind ? idx_ii2_jj[block_id][k] : 0;
 567: 
 568:     Xi[0] = Xs[ix][ind_Xi][0];
 569:     Xi[1] = Xs[ix][ind_Xi][1];
 570:     Xi[2] = Xs[ix][ind_Xi][2];
 571:  
 572:     Xj[0] = Xs[jx][k][0];
 573:     Xj[1] = Xs[jx][k][1];
 574:     Xj[2] = Xs[jx][k][2];
 575:  
 576:     // Transform point
 577:     actSim3(tij, qij, sij, Xj, Xj_Ci);
 578:  
 579:     // Error (difference in camera rays)
 580:     err[0] = Xj_Ci[0] - Xi[0];
 581:     err[1] = Xj_Ci[1] - Xi[1];
 582:     err[2] = Xj_Ci[2] - Xi[2];
 583:  
 584:     // Weights (Huber)
 585:     const float q = Q[block_id][k][0];
 586:     const float ci = Cs[ix][ind_Xi][0];
 587:     const float cj = Cs[jx][k][0];
 588:     const bool valid = 
 589:       valid_match_ind
 590:       & (q > Q_thresh)
 591:       & (ci > C_thresh)
 592:       & (cj > C_thresh);
 593: 
 594:     // Weight using confidences
 595:     const float conf_weight = q;
 596:     // const float conf_weight = q * ci * cj;
 597:     
 598:     const float sqrt_w_point = valid ? sigma_point_inv * sqrtf(conf_weight) : 0;
 599:  
 600:     // Robust weight
 601:     w[0] = huber(sqrt_w_point * err[0]);
 602:     w[1] = huber(sqrt_w_point * err[1]);
 603:     w[2] = huber(sqrt_w_point * err[2]);
 604:     
 605:     // Add back in sigma
 606:     const float w_const_point = sqrt_w_point * sqrt_w_point;
 607:     w[0] *= w_const_point;
 608:     w[1] *= w_const_point;
 609:     w[2] *= w_const_point;
 610:  
 611:     // Jacobians
 612:     
 613:     // x coordinate
 614:     Ji[0] = 1.0;
 615:     Ji[1] = 0.0;
 616:     Ji[2] = 0.0;
 617:     Ji[3] = 0.0;
 618:     Ji[4] = Xj_Ci[2]; // z
 619:     Ji[5] = -Xj_Ci[1]; // -y
 620:     Ji[6] = Xj_Ci[0]; // x
 621: 
 622:     apply_Sim3_adj_inv(ti, qi, si, Ji, Jj);
 623:     for (int n=0; n<7; n++) Ji[n] = -Jj[n];
 624: 
 625:     l=0;
 626:     for (int n=0; n<14; n++) {
 627:       for (int m=0; m<=n; m++) {
 628:         hij[l] += w[0] * Jx[n] * Jx[m];
 629:         l++;
 630:       }
 631:     }
 632:  
 633:     for (int n=0; n<7; n++) {
 634:       vi[n] += w[0] * err[0] * Ji[n];
 635:       vj[n] += w[0] * err[0] * Jj[n];
 636:     }
 637:  
 638:     // y coordinate
 639:     Ji[0] = 0.0;
 640:     Ji[1] = 1.0;
 641:     Ji[2] = 0.0;
 642:     Ji[3] = -Xj_Ci[2]; // -z
 643:     Ji[4] = 0; 
 644:     Ji[5] = Xj_Ci[0]; // x
 645:     Ji[6] = Xj_Ci[1]; // y
 646:  
 647:     apply_Sim3_adj_inv(ti, qi, si, Ji, Jj);
 648:     for (int n=0; n<7; n++) Ji[n] = -Jj[n];
 649: 
 650:     l=0;
 651:     for (int n=0; n<14; n++) {
 652:       for (int m=0; m<=n; m++) {
 653:         hij[l] += w[1] * Jx[n] * Jx[m];
 654:         l++;
 655:       }
 656:     }
 657:  
 658:     for (int n=0; n<7; n++) {
 659:       vi[n] += w[1] * err[1] * Ji[n];
 660:       vj[n] += w[1] * err[1] * Jj[n];
 661:     }
 662:  
 663:     // z coordinate
 664:     Ji[0] = 0.0;
 665:     Ji[1] = 0.0;
 666:     Ji[2] = 1.0;
 667:     Ji[3] = Xj_Ci[1]; // y
 668:     Ji[4] = -Xj_Ci[0]; // -x 
 669:     Ji[5] = 0;
 670:     Ji[6] = Xj_Ci[2]; // z
 671:  
 672:     apply_Sim3_adj_inv(ti, qi, si, Ji, Jj);
 673:     for (int n=0; n<7; n++) Ji[n] = -Jj[n];
 674: 
 675:     l=0;
 676:     for (int n=0; n<14; n++) {
 677:       for (int m=0; m<=n; m++) {
 678:         hij[l] += w[2] * Jx[n] * Jx[m];
 679:         l++;
 680:       }
 681:     }
 682:  
 683:     for (int n=0; n<7; n++) {
 684:       vi[n] += w[2] * err[2] * Ji[n];
 685:       vj[n] += w[2] * err[2] * Jj[n];
 686:     }
 687:  
 688:  
 689:   }
 690:  
 691:   __syncthreads();
 692:  
 693:   __shared__ float sdata[THREADS];
 694:   for (int n=0; n<7; n++) {
 695:     sdata[threadIdx.x] = vi[n];
 696:     blockReduce(sdata);
 697:     if (threadIdx.x == 0) {
 698:       gs[0][block_id][n] = sdata[0];
 699:     }
 700:  
 701:     __syncthreads();
 702:  
 703:     sdata[threadIdx.x] = vj[n];
 704:     blockReduce(sdata);
 705:     if (threadIdx.x == 0) {
 706:       gs[1][block_id][n] = sdata[0];
 707:     }
 708:  
 709:   }
 710:  
 711:   l=0;
 712:   for (int n=0; n<14; n++) {
 713:     for (int m=0; m<=n; m++) {
 714:       sdata[threadIdx.x] = hij[l];
 715:       blockReduce(sdata);
 716:  
 717:       if (threadIdx.x == 0) {
 718:         if (n<7 && m<7) {
 719:           Hs[0][block_id][n][m] = sdata[0];
 720:           Hs[0][block_id][m][n] = sdata[0];
 721:         }
 722:         else if (n >=7 && m<7) {
 723:           Hs[1][block_id][m][n-7] = sdata[0];
 724:           Hs[2][block_id][n-7][m] = sdata[0];
 725:         }
 726:         else {
 727:           Hs[3][block_id][n-7][m-7] = sdata[0];
 728:           Hs[3][block_id][m-7][n-7] = sdata[0];
 729:         }
 730:       }
 731:  
 732:       l++;
 733:     }
 734:   }
 735: }
