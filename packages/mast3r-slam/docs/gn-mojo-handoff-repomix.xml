 75:     num_poses: int = int(pose_data.shape[0])
 76:     num_fix: int = 1
 77:     unique_kf_idx: Tensor = get_unique_kf_idx(ii, jj)
 78:     ii_opt: Tensor
 79:     jj_opt: Tensor
 80:     ii_opt, jj_opt = create_inds(unique_kf_idx, num_fix, ii, jj)
 81:     n_vars: int = num_poses - num_fix
 82: 
 83:     dx: Tensor = torch.zeros((max(n_vars, 0), POSE_DIM), device=pose_data.device, dtype=pose_data.dtype)
 84:     for _ in range(max_iter):
 85:         hs: Tensor
 86:         gs: Tensor
 87:         hs, gs = step_fn(pose_data, *step_args)
 88:         h_dense: Tensor
 89:         b_dense: Tensor
 90:         h_dense, b_dense = assemble_dense_system(hs, gs, ii_opt, jj_opt, n_vars)
 91:         dx = solve_dense_system(h_dense, b_dense, n_vars)
 92:         pose_retr_fn(pose_data, dx, num_fix)
 93:         delta_norm: Tensor = torch.linalg.norm(dx)
 94:         if float(delta_norm.item()) < delta_thresh:
 95:             break
