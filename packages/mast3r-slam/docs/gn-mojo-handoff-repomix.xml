1719: std::vector<torch::Tensor> gauss_newton_calib_step_cuda(
1720:   torch::Tensor Twc, torch::Tensor Xs, torch::Tensor Cs,
1721:   torch::Tensor K,
1722:   torch::Tensor ii, torch::Tensor jj,
1723:   torch::Tensor idx_ii2jj, torch::Tensor valid_match,
