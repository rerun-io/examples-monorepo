304:         sigma_depth: float = self.cfg["sigma_depth"]
305:         delta_thresh: float = self.cfg["delta_norm"]
306: 
307:         pose_data: Float[Tensor, "n_unique sim3_dim"] = world_sim3_cams.data[:, 0, :]
308: 
309:         img_size = (int(self.frames[0].rgb_tensor.shape[-2]), int(self.frames[0].rgb_tensor.shape[-1]))
310:         height: int
311:         width: int
312:         height, width = img_size
313: 
314:         _gn_backends.gauss_newton_calib(
315:             pose_data,
