 70: @always_inline
 71: def exp_so3_components(
 72:     phi0: Float32,
 73:     phi1: Float32,
 74:     phi2: Float32,
 75: ) -> InlineArray[Float32, 4]:
 76:     var theta_sq = phi0 * phi0 + phi1 * phi1 + phi2 * phi2
 77:     var theta_p4 = theta_sq * theta_sq
 78:     var imag: Float32
 79:     var real: Float32
 80:     if theta_sq < 1e-6:
 81:         imag = 0.5 - (1.0 / 48.0) * theta_sq + (1.0 / 3840.0) * theta_p4
 82:         real = 1.0 - (1.0 / 8.0) * theta_sq + (1.0 / 384.0) * theta_p4
 83:     else:
 84:         var theta = sqrt(theta_sq)
 85:         imag = sin(0.5 * theta) / theta
 86:         real = cos(0.5 * theta)
 87:     var out = InlineArray[Float32, 4](fill=0.0)
 88:     out[0] = imag * phi0
 89:     out[1] = imag * phi1
 90:     out[2] = imag * phi2
 91:     out[3] = real
 92:     return out^
