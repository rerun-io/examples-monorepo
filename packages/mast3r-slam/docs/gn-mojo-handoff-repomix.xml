  2: """Benchmark GN public APIs and one-step accumulators."""
  3: 
  4: from __future__ import annotations
  5: 
  6: import sys
  7: from collections.abc import Callable
  8: from dataclasses import dataclass
  9: 
 10: import torch
 11: from torch import Tensor
 12: 
 13: from mast3r_slam import _backends as cuda_be
 14: from mast3r_slam import gn_backends as gn_be
 15: 
 16: assert torch.cuda.is_available(), "CUDA not available"
 17: DEVICE: torch.device = torch.device("cuda")
 18: 
 19: 
 20: @dataclass(slots=True, frozen=True)
 21: class BenchResult:
 22:     median_ms: float
 23:     mean_ms: float
 24:     std_ms: float
 25: 
 26: 
 27: def bench(fn: Callable[[], object], warmup: int = 20, runs: int = 100) -> BenchResult:
 28:     for _ in range(warmup):
 29:         fn()
 30:     torch.cuda.synchronize()
 31: 
 32:     timings: list[float] = []
 33:     for _ in range(runs):
 34:         start = torch.cuda.Event(enable_timing=True)
 35:         end = torch.cuda.Event(enable_timing=True)
 36:         start.record()
 37:         fn()
 38:         end.record()
 39:         torch.cuda.synchronize()
 40:         timings.append(start.elapsed_time(end))
 41: 
 42:     t = torch.tensor(timings)
 43:     return BenchResult(float(t.median()), float(t.mean()), float(t.std()))
 44: 
 45: 
 46: def make_graph_fixture(
