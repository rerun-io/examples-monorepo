384: def refine_matches_kernel_f16_cached[
385:     FDIM: Int,
386:     BLOCK_SIZE: Int,
387: ](
388:     D11: UnsafePointer[Float16, MutAnyOrigin],
389:     D21: UnsafePointer[Float16, MutAnyOrigin],
390:     p1: UnsafePointer[Int64, MutAnyOrigin],
391:     p1_new: UnsafePointer[Int64, MutAnyOrigin],
392:     h: Int,
393:     w: Int,
394:     num_pts: Int,
395: ):
396:     """Specialized f16 refinement kernel for the common radius=2, dilation=2 case.
397: 
398:     Each thread copies its query descriptor into shared memory once, then reuses
399:     it across all candidate scores. This reduces repeated global reads of D21.
400:     """
401:     var n: UInt = block_idx.x * block_dim.x + thread_idx.x
402:     var b: UInt = block_idx.y
403: 
404:     if n >= UInt(num_pts):
405:         return
406: 
407:     comptime CHUNKS = FDIM // 8
408: 
409:     var q_shared = stack_allocation[
410:         BLOCK_SIZE * CHUNKS,
411:         SIMD[DType.float16, 8],
412:         address_space=AddressSpace.SHARED,
413:     ]()
414: 
415:     var d11_stride_b: Int = h * w * FDIM
416:     var d11_stride_v: Int = w * FDIM
417:     var d21_stride_b: Int = num_pts * FDIM
418:     var p_stride_b: Int = num_pts * 2
419: 
420:     var p_base: Int = Int(b) * p_stride_b + Int(n) * 2
421:     var u0: Int = Int(p1[p_base + 0])
422:     var v0: Int = Int(p1[p_base + 1])
423:     var d21_base: Int = Int(b) * d21_stride_b + Int(n) * FDIM
424:     var q_shared_base: Int = Int(thread_idx.x) * CHUNKS
425: 
426:     comptime for chunk in range(CHUNKS):
427:         q_shared[q_shared_base + chunk] = D21.load[width=8](
428:             d21_base + chunk * 8
429:         )
430:     barrier()
431: 
432:     var max_score: Float32 = -3.4028235e+38
433:     var u_new: Int = u0
434:     var v_new: Int = v0
435: 
436:     for d in range(2, 0, -1):
437:         var rd: Int = 2 * d
438:         var diam: Int = 2 * rd + 1
439:         var i: Int = 0
440:         while i < diam:
441:             var j: Int = 0
442:             while j < diam:
443:                 var u_cand: Int = u0 - rd + i
444:                 var v_cand: Int = v0 - rd + j
445: 
446:                 if v_cand >= 0 and v_cand < h and u_cand >= 0 and u_cand < w:
447:                     var score: Float32 = 0.0
448:                     var d11_base: Int = Int(b) * d11_stride_b + v_cand * d11_stride_v + u_cand * FDIM
449:                     comptime for chunk in range(CHUNKS):
450:                         var q = q_shared[q_shared_base + chunk]
451:                         var v11 = D11.load[width=8](
452:                             d11_base + chunk * 8
453:                         )
454:                         score += (
455:                             q.cast[DType.float32]() * v11.cast[DType.float32]()
456:                         ).reduce_add()
457: 
458:                     if score > max_score:
459:                         max_score = score
460:                         u_new = u_cand
461:                         v_new = v_cand
462: 
463:                 j += d
464:             i += d
465: 
466:         u0 = u_new
467:         v0 = v_new
468: 
469:     p1_new[p_base + 0] = Int64(u_new)
470:     p1_new[p_base + 1] = Int64(v_new)
471: 
