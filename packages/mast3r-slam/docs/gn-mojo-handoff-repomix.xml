 91:         bench(lambda: gn_be.gauss_newton_rays(Twc.clone(), Xs, Cs, ii, jj, idx_ii2jj, valid_match, Q, 0.003, 10.0, 0.0, 1.5, 5, 1e-8)),
 92:     ))
