 99: def exp_so3_components(phi0: Float32, phi1: Float32, phi2: Float32) -> InlineArray[Float32, 4]:
100:     var theta_sq = phi0 * phi0 + phi1 * phi1 + phi2 * phi2
101:     var theta_p4 = theta_sq * theta_sq
102:     var imag: Float32
103:     var real: Float32
104:     if theta_sq < 1e-6:
105:         imag = 0.5 - (1.0 / 48.0) * theta_sq + (1.0 / 3840.0) * theta_p4
106:         real = 1.0 - (1.0 / 8.0) * theta_sq + (1.0 / 384.0) * theta_p4
107:     else:
108:         var theta = sqrt(theta_sq)
109:         imag = sin(0.5 * theta) / theta
110:         real = cos(0.5 * theta)
111:     var out = InlineArray[Float32, 4](fill=0.0)
112:     out[0] = imag * phi0
113:     out[1] = imag * phi1
114:     out[2] = imag * phi2
115:     out[3] = real
116:     return out^
