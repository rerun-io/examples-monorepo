 737: std::vector<torch::Tensor> gauss_newton_points_cuda(
 738:   torch::Tensor Twc, torch::Tensor Xs, torch::Tensor Cs,
 739:   torch::Tensor ii, torch::Tensor jj, 
 740:   torch::Tensor idx_ii2jj, torch::Tensor valid_match,
 741:   torch::Tensor Q,
 742:   const float sigma_point,
 743:   const float C_thresh,
 744:   const float Q_thresh,
 745:   const int max_iter,
 746:   const float delta_thresh)
 747: {
 748:   auto opts = Twc.options();
 749:   const int num_edges = ii.size(0);
 750:   const int num_poses = Xs.size(0);
 751:   const int n = Xs.size(1);
 752: 
 753:   const int num_fix = 1;
 754: 
 755:   // Setup indexing
 756:   torch::Tensor unique_kf_idx = get_unique_kf_idx(ii, jj);
 757:   // For edge construction
 758:   std::vector<torch::Tensor> inds = create_inds(unique_kf_idx, 0, ii, jj);
 759:   torch::Tensor ii_edge = inds[0];
 760:   torch::Tensor jj_edge = inds[1];
 761:   // For linear system indexing (pin=2 because fixing first two poses)
 762:   std::vector<torch::Tensor> inds_opt = create_inds(unique_kf_idx, num_fix, ii, jj);
 763:   torch::Tensor ii_opt = inds_opt[0];
 764:   torch::Tensor jj_opt = inds_opt[1];
 765: 
 766:   const int pose_dim = 7; // sim3
 767: 
 768:   // initialize buffers
 769:   torch::Tensor Hs = torch::zeros({4, num_edges, pose_dim, pose_dim}, opts);
 770:   torch::Tensor gs = torch::zeros({2, num_edges, pose_dim}, opts);
 771: 
 772:   // For debugging outputs
 773:   torch::Tensor dx;
 774: 
 775:   torch::Tensor delta_norm;
 776: 
 777:   for (int itr=0; itr<max_iter; itr++) {
 778: 
 779:     point_align_kernel<<<num_edges, THREADS>>>(
 780:       Twc.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
 781:       Xs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
 782:       Cs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
 783:       ii_edge.packed_accessor32<long,1,torch::RestrictPtrTraits>(),
 784:       jj_edge.packed_accessor32<long,1,torch::RestrictPtrTraits>(),
 785:       idx_ii2jj.packed_accessor32<long,2,torch::RestrictPtrTraits>(),
 786:       valid_match.packed_accessor32<bool,3,torch::RestrictPtrTraits>(),
 787:       Q.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
 788:       Hs.packed_accessor32<float,4,torch::RestrictPtrTraits>(),
 789:       gs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
 790:       sigma_point, C_thresh, Q_thresh
 791:     );
 792: 
 793: 
 794:     // pose x pose block
 795:     SparseBlock A(num_poses - num_fix, pose_dim);
 796: 
 797:     A.update_lhs(Hs.reshape({-1, pose_dim, pose_dim}), 
 798:         torch::cat({ii_opt, ii_opt, jj_opt, jj_opt}), 
 799:         torch::cat({ii_opt, jj_opt, ii_opt, jj_opt}));
 800: 
 801:     A.update_rhs(gs.reshape({-1, pose_dim}), 
 802:         torch::cat({ii_opt, jj_opt}));
 803: 
 804:     // NOTE: Accounting for negative here!
 805:     dx = -A.solve();
 806:     
 807:     pose_retr_kernel<<<1, THREADS>>>(
 808:       Twc.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
 809:       dx.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
 810:       num_fix);
 811: 
 812:     // Termination criteria
 813:     // Need to specify this second argument otherwise ambiguous function call...
 814:     delta_norm = torch::linalg_norm(dx, std::optional<c10::Scalar>(), {}, false, {});
 815:     if (delta_norm.item<float>() < delta_thresh) {
 816:       break;
 817:     }
 818:         
 819: 
 820:   }
 821: 
 822:   return {dx}; // For debugging
 823: }
