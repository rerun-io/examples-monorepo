 299: __device__ void
 300: expSO3(const float *phi, float* q) {
 301:   // SO3 exponential map
 302:   float theta_sq = phi[0]*phi[0] + phi[1]*phi[1] + phi[2]*phi[2];
 303: 
 304:   float imag, real;
 305: 
 306:   if (theta_sq < EPS) {
 307:     float theta_p4 = theta_sq * theta_sq;
 308:     imag = 0.5 - (1.0/48.0)*theta_sq + (1.0/3840.0)*theta_p4;
 309:     real = 1.0 - (1.0/ 8.0)*theta_sq + (1.0/ 384.0)*theta_p4;
 310:   } else {
 311:     float theta = sqrtf(theta_sq);
 312:     imag = sinf(0.5 * theta) / theta;
 313:     real = cosf(0.5 * theta);
 314:   }
 315: 
 316:   q[0] = imag * phi[0];
 317:   q[1] = imag * phi[1];
 318:   q[2] = imag * phi[2];
 319:   q[3] = real;
 320: 
 321: }
 322: 
 323: __device__ void
 324: expSim3(const float *xi, float* t, float* q, float* s) {
 325:   float tau[3] = {xi[0], xi[1], xi[2]};
 326:   float phi[3] = {xi[3], xi[4], xi[5]};
 327:   float sigma = xi[6];
 328: 
 329:   // New for sim3
 330:   float scale = expf(sigma);
 331: 
 332:   // 1. Rotation
 333:   expSO3(phi, q);
 334:   // 2. Scale
 335:   s[0] = scale;
 336: 
 337:   // 3. Translation
 338: 
 339:   // TODO: Reuse this from expSO3?
 340:   float theta_sq = phi[0]*phi[0] + phi[1]*phi[1] + phi[2]*phi[2];
 341:   float theta = sqrtf(theta_sq);
 342: 
 343:   // Coefficients for W
 344:   https://github.com/princeton-vl/lietorch/blob/0fa9ce8ffca86d985eca9e189a99690d6f3d4df6/lietorch/include/rxso3.h#L190
 345:   
 346:   // TODO: Does this really match equations? Where is scale-1
 347:   float A, B, C;
 348:   const float one = 1.0;
 349:   const float half = 0.5;
 350:   if (fabs(sigma) < EPS) {
 351:     C = one;
 352:     if (fabs(theta) < EPS) {
 353:       A = half;
 354:       B = 1.0/6.0;
 355:     } else {
 356:       A = (one - cosf(theta)) / theta_sq;
 357:       B = (theta - sinf(theta)) / (theta_sq * theta);
 358:     }
 359:   } else {
 360:     C = (scale - one) / sigma;
 361:     if (fabs(theta) < EPS) {
 362:       float sigma_sq = sigma * sigma;
 363:       A = ((sigma - one) * scale + one) / sigma_sq;
 364:       B = (scale * half * sigma_sq + scale - one - sigma * scale) /
 365:           (sigma_sq * sigma);
 366:     } else {
 367:       float a = scale * sinf(theta);
 368:       float b = scale * cosf(theta);
 369:       float c = theta_sq + sigma * sigma;
 370:       A = (a * sigma + (one - b) * theta) / (theta * c);
 371:       B = (C - ((b - one) * sigma + a * theta) / (c)) / (theta_sq); // Why is it C - ????? not +?
 372:     }
 373:   }
 374: 
 375:   // W = C * I + A * Phi + B * Phi2;
 376:   // t = W tau
 377:   t[0] = C * tau[0]; 
 378:   t[1] = C * tau[1]; 
 379:   t[2] = C * tau[2];
 380: 
 381:   crossInplace(phi, tau);
 382:   t[0] += A * tau[0];
 383:   t[1] += A * tau[1];
 384:   t[2] += A * tau[2];
 385: 
 386:   crossInplace(phi, tau);
 387:   t[0] += B * tau[0];
 388:   t[1] += B * tau[1];
 389:   t[2] += B * tau[2];
 390: }
