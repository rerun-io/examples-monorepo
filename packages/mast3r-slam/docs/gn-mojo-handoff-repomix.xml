 50: @always_inline
 51: def act_so3_components(
 52:     qx: Float32,
 53:     qy: Float32,
 54:     qz: Float32,
 55:     qw: Float32,
 56:     x0: Float32,
 57:     x1: Float32,
 58:     x2: Float32,
 59: ) -> InlineArray[Float32, 3]:
