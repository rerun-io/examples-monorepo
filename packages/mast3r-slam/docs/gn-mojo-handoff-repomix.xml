 14:     ii_opt: UnsafePointer[Int64, MutAnyOrigin],
 15:     jj_opt: UnsafePointer[Int64, MutAnyOrigin],
 16:     h_dense: UnsafePointer[Float64, MutAnyOrigin],
 17:     num_edges: Int,
 18:     n_vars: Int,
 19: ):
 20:     var row: Int = Int(global_idx.x)
 21:     var col: Int = Int(global_idx.y)
