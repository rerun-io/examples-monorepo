1046: def iter_proj_kernel(
1047:     rays_img: UnsafePointer[Float32, MutAnyOrigin],
1048:     pts_3d_norm: UnsafePointer[Float32, MutAnyOrigin],
1049:     p_init: UnsafePointer[Float32, MutAnyOrigin],
1050:     p_new: UnsafePointer[Float32, MutAnyOrigin],
1051:     converged: UnsafePointer[UInt8, MutAnyOrigin],
1052:     h: Int,
1053:     w: Int,
1054:     num_pts: Int,
1055:     max_iter: Int,
1056:     lambda_init: Float32,
1057:     cost_thresh: Float32,
1058: ):
1059:     """Levenberg-Marquardt iterative projection kernel.
1060: 
1061:     Each thread processes one point: bilinear-interpolates rays at the current
1062:     pixel, normalises, computes error against the target 3D direction, builds a
1063:     2x2 LM system, solves for a pixel update, and accepts/rejects based on cost.
1064: 
1065:     Mirrors the CUDA kernel in matching_kernels.cu:iter_proj_kernel (lines 119-275).
1066:     """
1067:     # ── Thread indexing ──
1068:     var n: UInt = block_idx.x * block_dim.x + thread_idx.x
1069:     var b: UInt = block_idx.y
1070: 
1071:     if n >= UInt(num_pts):
1072:         return
1073: 
1074:     # ── Strides for row-major tensors ──
1075:     var rays_stride_b: Int = h * w * 9
1076:     var rays_stride_v: Int = w * 9
1077:     var pts_stride_b: Int = num_pts * 3
1078:     var p_stride_b: Int = num_pts * 2
1079:     var conv_stride_b: Int = num_pts
1080: 
1081:     # ── Batch-invariant base offsets (hoisted out of loop) ──
1082:     var base_b: Int = Int(b) * rays_stride_b
1083:     var conv_idx: Int = Int(b) * conv_stride_b + Int(n)
1084: 
1085:     # ── Load initial pixel and clamp to valid bilinear range ──
1086:     var u: Float32 = p_init[Int(b) * p_stride_b + Int(n) * 2 + 0]
1087:     var v: Float32 = p_init[Int(b) * p_stride_b + Int(n) * 2 + 1]
1088:     u = min(max(u, Float32(1.0)), Float32(w - 2))
1089:     v = min(max(v, Float32(1.0)), Float32(h - 2))
1090: 
1091:     # ── Load target point once (loop-invariant) ──
1092:     var pts_base: Int = Int(b) * pts_stride_b + Int(n) * 3
1093:     var t0: Float32 = pts_3d_norm[pts_base + 0]
1094:     var t1: Float32 = pts_3d_norm[pts_base + 1]
1095:     var t2: Float32 = pts_3d_norm[pts_base + 2]
1096: 
1097:     var lam: Float32 = lambda_init
1098: 
1099:     for _i in range(max_iter):
1100:         # ── Bilinear interpolation at current pixel ──
1101:         var u11: Int = Int(floor(u))
1102:         var v11: Int = Int(floor(v))
1103:         var wt = bilinear_weights(u - Float32(u11), v - Float32(v11))
1104:         var off = bilinear_corners(base_b, rays_stride_v, v11, u11)
1105: 
1106:         # Interpolate ray (ch 0-2), gx (ch 3-5), gy (ch 6-8)
1107:         var r0: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 0)
1108:         var r1: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 1)
1109:         var r2: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 2)
1110: 
1111:         var gx0: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 3)
1112:         var gx1: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 4)
1113:         var gx2: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 5)
1114: 
1115:         var gy0: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 6)
1116:         var gy1: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 7)
1117:         var gy2: Float32 = bilinear_sample(rays_img, off[0], off[1], off[2], off[3], wt[0], wt[1], wt[2], wt[3], 8)
1118: 
1119:         # ── Normalize ray ──
1120:         var r = normalize_ray(r0, r1, r2)
1121:         r0 = r[0]
1122:         r1 = r[1]
1123:         r2 = r[2]
1124: 
1125:         # ── Error and cost ──
1126:         var e0: Float32 = r0 - t0
1127:         var e1: Float32 = r1 - t1
1128:         var e2: Float32 = r2 - t2
1129:         var cost: Float32 = e0 * e0 + e1 * e1 + e2 * e2
1130: 
1131:         # ── Build normal equations: J^T J + lambda * I, -J^T r ──
1132:         var A00: Float32 = gx0 * gx0 + gx1 * gx1 + gx2 * gx2 + lam
1133:         var A01: Float32 = gx0 * gy0 + gx1 * gy1 + gx2 * gy2
1134:         var A11: Float32 = gy0 * gy0 + gy1 * gy1 + gy2 * gy2 + lam
1135:         var b0: Float32 = -(e0 * gx0 + e1 * gx1 + e2 * gx2)
1136:         var b1: Float32 = -(e0 * gy0 + e1 * gy1 + e2 * gy2)
1137: 
1138:         # ── Solve 2x2 system via Cramer's rule ──
1139:         var det_inv: Float32 = 1.0 / (A00 * A11 - A01 * A01)
1140:         var delta_u: Float32 = det_inv * (A11 * b0 - A01 * b1)
1141:         var delta_v: Float32 = det_inv * (-A01 * b0 + A00 * b1)
1142: 
1143:         var u_new: Float32 = min(max(u + delta_u, Float32(1.0)), Float32(w - 2))
1144:         var v_new: Float32 = min(max(v + delta_v, Float32(1.0)), Float32(h - 2))
1145: 
1146:         # ── Evaluate new cost at candidate position ──
1147:         var u11n: Int = Int(floor(u_new))
1148:         var v11n: Int = Int(floor(v_new))
1149:         var wtn = bilinear_weights(u_new - Float32(u11n), v_new - Float32(v11n))
1150:         var offn = bilinear_corners(base_b, rays_stride_v, v11n, u11n)
1151: 
1152:         var nr0: Float32 = bilinear_sample(rays_img, offn[0], offn[1], offn[2], offn[3], wtn[0], wtn[1], wtn[2], wtn[3], 0)
1153:         var nr1: Float32 = bilinear_sample(rays_img, offn[0], offn[1], offn[2], offn[3], wtn[0], wtn[1], wtn[2], wtn[3], 1)
1154:         var nr2: Float32 = bilinear_sample(rays_img, offn[0], offn[1], offn[2], offn[3], wtn[0], wtn[1], wtn[2], wtn[3], 2)
1155:         var nr = normalize_ray(nr0, nr1, nr2)
1156: 
1157:         var ne0: Float32 = nr[0] - t0
1158:         var ne1: Float32 = nr[1] - t1
1159:         var ne2: Float32 = nr[2] - t2
1160:         var new_cost: Float32 = ne0 * ne0 + ne1 * ne1 + ne2 * ne2
1161: 
1162:         # ── Accept/reject step (Levenberg-Marquardt) ──
1163:         if new_cost < cost:
1164:             u = u_new
1165:             v = v_new
1166:             lam *= 0.1
1167:             converged[conv_idx] = UInt8(1) if new_cost < cost_thresh else UInt8(0)
1168:         else:
1169:             lam *= 10.0
1170:             converged[conv_idx] = UInt8(1) if cost < cost_thresh else UInt8(0)
1171: 
1172:     # ── Write final pixel ──
1173:     var out_idx: Int = Int(b) * p_stride_b + Int(n) * 2
1174:     p_new[out_idx + 0] = u
1175:     p_new[out_idx + 1] = v
1176: 
