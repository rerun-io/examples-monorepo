 95: @always_inline
 96: def exp_sim3_components(
 97:     xi0: Float32,
 98:     xi1: Float32,
 99:     xi2: Float32,
100:     xi3: Float32,
101:     xi4: Float32,
102:     xi5: Float32,
103:     xi6: Float32,
104: ) -> InlineArray[Float32, POSE_STRIDE]:
105:     var tau0 = xi0
106:     var tau1 = xi1
107:     var tau2 = xi2
108:     var phi0 = xi3
109:     var phi1 = xi4
110:     var phi2 = xi5
111:     var sigma = xi6
112:     var scale = exp(sigma)
113:     var q = exp_so3_components(phi0, phi1, phi2)
114: 
115:     var theta_sq = phi0 * phi0 + phi1 * phi1 + phi2 * phi2
116:     var theta = sqrt(theta_sq)
117:     var A: Float32
118:     var B: Float32
119:     var C: Float32
120:     if abs(sigma) < Float32(1e-6):
121:         C = 1.0
122:         if abs(theta) < Float32(1e-6):
123:             A = 0.5
124:             B = 1.0 / 6.0
125:         else:
126:             A = (1.0 - cos(theta)) / theta_sq
127:             B = (theta - sin(theta)) / (theta_sq * theta)
128:     else:
129:         C = (scale - 1.0) / sigma
130:         if abs(theta) < Float32(1e-6):
131:             var sigma_sq = sigma * sigma
132:             A = ((sigma - 1.0) * scale + 1.0) / sigma_sq
133:             B = (scale * 0.5 * sigma_sq + scale - 1.0 - sigma * scale) / (sigma_sq * sigma)
134:         else:
135:             var a = scale * sin(theta)
136:             var b = scale * cos(theta)
137:             var c = theta_sq + sigma * sigma
138:             A = (a * sigma + (1.0 - b) * theta) / (theta * c)
139:             B = (C - (((b - 1.0) * sigma + a * theta) / c)) / theta_sq
140: 
141:     var out = InlineArray[Float32, POSE_STRIDE](fill=0.0)
142:     out[0] = C * tau0
143:     out[1] = C * tau1
144:     out[2] = C * tau2
145: 
146:     var cx0 = phi1 * tau2 - phi2 * tau1
147:     var cx1 = phi2 * tau0 - phi0 * tau2
148:     var cx2 = phi0 * tau1 - phi1 * tau0
149:     out[0] += A * cx0
150:     out[1] += A * cx1
151:     out[2] += A * cx2
152: 
153:     var c2x0 = phi1 * cx2 - phi2 * cx1
154:     var c2x1 = phi2 * cx0 - phi0 * cx2
155:     var c2x2 = phi0 * cx1 - phi1 * cx0
156:     out[0] += B * c2x0
157:     out[1] += B * c2x1
158:     out[2] += B * c2x2
159:     out[3] = q[0]
160:     out[4] = q[1]
161:     out[5] = q[2]
162:     out[6] = q[3]
163:     out[7] = scale
164:     return out^
