 980: 
 981: @always_inline
 982: def bilinear_sample(
 983:     data: UnsafePointer[Float32, MutAnyOrigin],
 984:     off11: Int, off12: Int, off21: Int, off22: Int,
 985:     w11: Float32, w12: Float32, w21: Float32, w22: Float32,
 986:     ch: Int,
 987: ) -> Float32:
 988:     """Sample a single channel from four bilinear corners.
 989: 
 990:     The corners are named by their bilinear weight, NOT their spatial position
 991:     (pixels are opposite the area weights — same convention as the CUDA kernel).
 992:     """
 993:     return (
 994:         w11 * data[off11 + ch]
 995:         + w12 * data[off12 + ch]
 996:         + w21 * data[off21 + ch]
 997:         + w22 * data[off22 + ch]
 998:     )
 999: 
1000: 
1001: @always_inline
1002: def bilinear_corners(
1003:     base_b: Int, rays_stride_v: Int,
1004:     v11: Int, u11: Int,
1005: ) -> InlineArray[Int, 4]:
1006:     """Compute the four corner offsets for bilinear interpolation.
1007: 
1008:     Returns [bottom-right, bottom-left, top-right, top-left] offsets.
1009:     NOTE: pixels opposite the area weights (same as CUDA kernel).
1010:     """
1011:     var offsets = InlineArray[Int, 4](fill=0)
1012:     offsets[0] = base_b + (v11 + 1) * rays_stride_v + (u11 + 1) * 9  # bottom-right
1013:     offsets[1] = base_b + (v11 + 1) * rays_stride_v + u11 * 9        # bottom-left
1014:     offsets[2] = base_b + v11 * rays_stride_v + (u11 + 1) * 9        # top-right
1015:     offsets[3] = base_b + v11 * rays_stride_v + u11 * 9              # top-left
1016:     return offsets^
1017: 
1018: 
1019: @always_inline
1020: def bilinear_weights(du: Float32, dv: Float32) -> InlineArray[Float32, 4]:
1021:     """Compute bilinear interpolation weights from fractional pixel offsets."""
1022:     var w = InlineArray[Float32, 4](fill=Float32(0.0))
1023:     w[0] = du * dv
1024:     w[1] = (1.0 - du) * dv
1025:     w[2] = du * (1.0 - dv)
1026:     w[3] = (1.0 - du) * (1.0 - dv)
1027:     return w^
1028: 
1029: 
1030: @always_inline
1031: def normalize_ray(
1032:     r0: Float32, r1: Float32, r2: Float32,
1033: ) -> InlineArray[Float32, 3]:
1034:     """Normalize a 3D ray direction to unit length."""
1035:     var r_norm: Float32 = sqrt(r0 * r0 + r1 * r1 + r2 * r2)
1036:     var r_inv: Float32 = 1.0 / r_norm
1037:     var out = InlineArray[Float32, 3](fill=Float32(0.0))
1038:     out[0] = r0 * r_inv
1039:     out[1] = r1 * r_inv
1040:     out[2] = r2 * r_inv
1041:     return out^
1042: 
