 332: 
 333: @always_inline
 334: def act_sim3_components(
 335:     tx: Float32, ty: Float32, tz: Float32,
 336:     qx: Float32, qy: Float32, qz: Float32, qw: Float32,
 337:     s: Float32,
 338:     x0: Float32, x1: Float32, x2: Float32,
 339: ) -> InlineArray[Float32, 3]:
 340:     var rot = act_so3_components(qx, qy, qz, qw, x0, x1, x2)
 341:     var out = InlineArray[Float32, 3](fill=0.0)
 342:     out[0] = rot[0] * s + tx
 343:     out[1] = rot[1] * s + ty
 344:     out[2] = rot[2] * s + tz
 345:     return out^
 346: 
 347: 
 348: @always_inline
 349: def dot3_components(
 350:     a0: Float32, a1: Float32, a2: Float32,
 351:     b0: Float32, b1: Float32, b2: Float32,
 352: ) -> Float32:
 353:     return a0 * b0 + a1 * b1 + a2 * b2
 354: 
 355: 
 356: @always_inline
 357: def squared_norm3_components(x0: Float32, x1: Float32, x2: Float32) -> Float32:
 358:     return x0 * x0 + x1 * x1 + x2 * x2
 359: 
 360: 
 361: @always_inline
 362: def huber_scalar(r: Float32) -> Float32:
 363:     var r_abs = abs(r)
 364:     if r_abs < 1.345:
 365:         return 1.0
 366:     return 1.345 / r_abs
 367: 
 368: 
 369: @always_inline
 370: def rel_sim3_components(
 371:     tix: Float32, tiy: Float32, tiz: Float32,
 372:     qix: Float32, qiy: Float32, qiz: Float32, qiw: Float32,
 373:     si: Float32,
 374:     tjx: Float32, tjy: Float32, tjz: Float32,
 375:     qjx: Float32, qjy: Float32, qjz: Float32, qjw: Float32,
 376:     sj: Float32,
 377: ) -> InlineArray[Float32, 8]:
 378:     var si_inv = 1.0 / si
 379:     var qi_inv = quat_inv_components(qix, qiy, qiz, qiw)
 380:     var qij = quat_comp_components(qi_inv[0], qi_inv[1], qi_inv[2], qi_inv[3], qjx, qjy, qjz, qjw)
 381:     var dt0 = tjx - tix
 382:     var dt1 = tjy - tiy
 383:     var dt2 = tjz - tiz
 384:     var rot_t = act_so3_components(qi_inv[0], qi_inv[1], qi_inv[2], qi_inv[3], dt0, dt1, dt2)
 385:     var out = InlineArray[Float32, 8](fill=0.0)
 386:     out[0] = rot_t[0] * si_inv
 387:     out[1] = rot_t[1] * si_inv
 388:     out[2] = rot_t[2] * si_inv
 389:     out[3] = qij[0]
 390:     out[4] = qij[1]
 391:     out[5] = qij[2]
 392:     out[6] = qij[3]
 393:     out[7] = si_inv * sj
 394:     return out^
 395: 
 396: 
 397: @always_inline
 398: def apply_sim3_adj_inv_components(
 399:     tx: Float32, ty: Float32, tz: Float32,
 400:     qx: Float32, qy: Float32, qz: Float32, qw: Float32,
 401:     s: Float32,
 402:     x0: Float32, x1: Float32, x2: Float32,
 403:     x3: Float32, x4: Float32, x5: Float32,
 404:     x6: Float32,
 405: ) -> InlineArray[Float32, 7]:
 406:     var s_inv = 1.0 / s
 407:     var ra = act_so3_components(qx, qy, qz, qw, x0, x1, x2)
 408:     var out = InlineArray[Float32, 7](fill=0.0)
 409:     out[0] = s_inv * ra[0]
 410:     out[1] = s_inv * ra[1]
 411:     out[2] = s_inv * ra[2]
 412: 
 413:     var rb = act_so3_components(qx, qy, qz, qw, x3, x4, x5)
 414:     out[3] = rb[0] + s_inv * (ty * ra[2] - tz * ra[1])
 415:     out[4] = rb[1] + s_inv * (tz * ra[0] - tx * ra[2])
 416:     out[5] = rb[2] + s_inv * (tx * ra[1] - ty * ra[0])
 417:     out[6] = x6 + s_inv * dot3_components(tx, ty, tz, ra[0], ra[1], ra[2])
 418:     return out^
 419: 
