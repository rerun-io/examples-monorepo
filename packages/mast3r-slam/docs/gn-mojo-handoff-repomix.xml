 52:     gen = torch.Generator(device=DEVICE).manual_seed(seed)
 53:     Twc = torch.randn(num_poses, 8, device=DEVICE, generator=gen, dtype=torch.float32)
 54:     Twc[:, 6] = 1.0
 55:     Twc[:, 7] = 1.0
 56:     Xs = torch.randn(num_poses, num_points, 3, device=DEVICE, generator=gen, dtype=torch.float32).contiguous()
 57:     Cs = torch.rand(num_poses, num_points, 1, device=DEVICE, generator=gen, dtype=torch.float32).contiguous() + 0.5
 58:     ii = torch.randint(0, num_poses - 1, (num_edges,), device=DEVICE, generator=gen, dtype=torch.long)
 59:     jj = torch.clamp(ii + 1, max=num_poses - 1)
 60:     idx_ii2jj = torch.randint(0, num_points, (num_edges, num_points), device=DEVICE, generator=gen, dtype=torch.long).contiguous()
 61:     valid_match = (torch.rand(num_edges, num_points, 1, device=DEVICE, generator=gen) > 0.1).contiguous()
 62:     Q = (torch.rand(num_edges, num_points, 1, device=DEVICE, generator=gen, dtype=torch.float32) * 2.0 + 1.0).contiguous()
 63:     return Twc, Xs, Cs, ii, jj, idx_ii2jj, valid_match, Q
 64: 
 65: 
 66: def main() -> None:
 67:     if not all(hasattr(cuda_be, name) for name in ("gauss_newton_rays_step", "gauss_newton_calib_step")):
 68:         print("ERROR: CUDA GN step helpers are not built")
 69:         sys.exit(1)
