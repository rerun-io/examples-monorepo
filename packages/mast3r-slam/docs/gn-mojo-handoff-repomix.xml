377:         var xi_base = (ix * num_points + ind_xi) * 3
378:         var xj_base = (jx * num_points + k) * 3
379:         var ci = cs[ix * num_points + ind_xi]
380:         var cj = cs[jx * num_points + k]
381:         var qv = q_tensor[edge * num_points + k]
382: 
383:         var xi0 = xs[xi_base + 0]
384:         var xi1 = xs[xi_base + 1]
385:         var xi2 = xs[xi_base + 2]
386:         var xj0 = xs[xj_base + 0]
387:         var xj1 = xs[xj_base + 1]
388:         var xj2 = xs[xj_base + 2]
389: 
390:         var norm2_i = squared_norm3_components(xi0, xi1, xi2)
391:         var norm1_i = sqrt(norm2_i)
392:         var norm1_i_inv = 1.0 / norm1_i
393:         var ri0 = norm1_i_inv * xi0
394:         var ri1 = norm1_i_inv * xi1
395:         var ri2 = norm1_i_inv * xi2
396: 
397:         var xj_ci = act_sim3_components(
398:             rel0, rel1, rel2, rel3, rel4, rel5, rel6, rel7, xj0, xj1, xj2
399:         )
400:         var norm2_j = squared_norm3_components(xj_ci[0], xj_ci[1], xj_ci[2])
401:         var norm1_j = sqrt(norm2_j)
402:         var norm1_j_inv = 1.0 / norm1_j
403:         var rj0 = norm1_j_inv * xj_ci[0]
404:         var rj1 = norm1_j_inv * xj_ci[1]
405:         var rj2 = norm1_j_inv * xj_ci[2]
406: 
407:         var err0 = rj0 - ri0
408:         var err1 = rj1 - ri1
409:         var err2 = rj2 - ri2
410:         var err3 = norm1_j - norm1_i
411: 
412:         var valid = valid_match_ind and (qv > q_thresh) and (ci > c_thresh) and (cj > c_thresh)
413:         var conf_weight: Float32 = qv
414:         var sqrt_w_ray: Float32 = 0.0
415:         var sqrt_w_dist: Float32 = 0.0
416:         if valid:
417:             var sqrt_conf = sqrt(conf_weight)
