263: @always_inline
264: def apply_sim3_adj_inv_components(
265:     tx: Float32, ty: Float32, tz: Float32,
266:     qx: Float32, qy: Float32, qz: Float32, qw: Float32,
267:     s: Float32,
268:     x0: Float32, x1: Float32, x2: Float32,
269:     x3: Float32, x4: Float32, x5: Float32,
270:     x6: Float32,
