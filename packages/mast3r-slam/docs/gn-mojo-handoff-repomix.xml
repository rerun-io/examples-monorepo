 455: std::vector<torch::Tensor> pose_retr_cuda(
 456:   torch::Tensor poses,
 457:   torch::Tensor dx,
 458:   const int num_fix)
 459: {
 460:   pose_retr_kernel<<<1, THREADS>>>(
 461:     poses.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
 462:     dx.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
 463:     num_fix);
 464:   return {poses};
 465: }
