475: def iter_proj_py(
476:     rays_img_obj: PythonObject,
477:     pts_3d_norm_obj: PythonObject,
478:     p_init_obj: PythonObject,
479:     max_iter_obj: PythonObject,
480:     lambda_init_obj: PythonObject,
481:     cost_thresh_obj: PythonObject,
482: ) raises -> PythonObject:
483:     """Drop-in replacement for mast3r_slam_backends.iter_proj."""
484:     var torch = Python.import_module("torch")
485: 
486:     # Ensure inputs are contiguous
487:     var rays_img: PythonObject = rays_img_obj.contiguous()
488:     var pts_3d_norm: PythonObject = pts_3d_norm_obj.contiguous()
489:     var p_init: PythonObject = p_init_obj.contiguous()
490: 
491:     # Extract shapes
492:     var batch: Int = Int(py=rays_img.shape[0])
493:     var h: Int = Int(py=rays_img.shape[1])
494:     var w: Int = Int(py=rays_img.shape[2])
495:     var num_pts: Int = Int(py=pts_3d_norm.shape[1])
496:     var max_iter: Int = Int(py=max_iter_obj)
497:     var lambda_init: Float64 = Float64(py=lambda_init_obj)
498:     var cost_thresh: Float64 = Float64(py=cost_thresh_obj)
499: 
500:     # No torch.cuda.synchronize() — CUDA stream ordering handles dependencies.
501: 
502:     # Allocate output tensors via torch.empty (kernel writes all positions)
503:     var p_new: PythonObject = torch.empty(
504:         Python.list(batch, num_pts, 2),
505:         device=rays_img.device,
506:         dtype=torch.float32,
507:     )
508:     # Allocate directly as bool — PyTorch stores bool as uint8 internally,
509:     # so the kernel can write UInt8 (0/1) to it without a .to(bool) cast.
510:     var converged: PythonObject = torch.empty(
511:         Python.list(batch, num_pts),
512:         device=rays_img.device,
513:         dtype=torch.bool,
514:     )
515: 
516:     # Get raw CUDA pointers
517:     var rays_ptr: Int = Int(py=rays_img.data_ptr())
518:     var pts_ptr: Int = Int(py=pts_3d_norm.data_ptr())
519:     var pinit_ptr: Int = Int(py=p_init.data_ptr())
520:     var pnew_ptr: Int = Int(py=p_new.data_ptr())
521:     var conv_ptr: Int = Int(py=converged.data_ptr())
522: 
523:     var rays_uptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=rays_ptr)
524:     var pts_uptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=pts_ptr)
525:     var pinit_uptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=pinit_ptr)
526:     var pnew_uptr = UnsafePointer[Float32, MutAnyOrigin](unsafe_from_address=pnew_ptr)
527:     var conv_uptr = UnsafePointer[UInt8, MutAnyOrigin](unsafe_from_address=conv_ptr)
528: 
529:     var ctx_ptr = get_cached_context_ptr()
530:     var block_size: Int = choose_iter_proj_block(num_pts)
531:     var num_blocks_x: Int = ceildiv(num_pts, block_size)
532:     ctx_ptr[].enqueue_function[iter_proj_kernel, iter_proj_kernel](
533:         rays_uptr,
534:         pts_uptr,
535:         pinit_uptr,
536:         pnew_uptr,
537:         conv_uptr,
538:         h,
539:         w,
540:         num_pts,
541:         max_iter,
542:         Float32(lambda_init),
543:         Float32(cost_thresh),
544:         grid_dim=(num_blocks_x, batch),
545:         block_dim=block_size,
546:     )
547:     # Device-wide sync to ensure Mojo's kernel completes before PyTorch's
548:     # caching allocator can recycle the output buffer on a subsequent call.
549:     Python.import_module("torch").cuda.synchronize()
550:     # PyTorch ops on the same default stream will wait automatically.
551: 
552:     return Python.tuple(p_new, converged)
553: 
