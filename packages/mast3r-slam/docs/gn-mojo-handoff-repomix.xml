  1: import lietorch
  2: import torch
  3: from jaxtyping import Bool, Float, Float32, Int
  4: from mast3r.model import AsymmetricMASt3R
  5: from torch import Tensor
  6: 
  7: from mast3r_slam import gn_backends as _gn_backends  # pyrefly: ignore
  8: from mast3r_slam.config import config
  9: from mast3r_slam.frame import Frame, SharedKeyframes
 10: from mast3r_slam.geometry import (
 11:     constrain_points_to_ray,
 12: )
 13: from mast3r_slam.mast3r_utils import mast3r_match_symmetric
 14: 
 15: 
 16: class FactorGraph:
 17:     """Maintains pairwise factors between keyframes and solves global pose optimisation.
 18: 
 19:     Stores symmetric matching edges (correspondences, quality scores, validity
 20:     masks) and provides Gauss-Newton solvers for both ray-distance and
 21:     calibrated reprojection formulations.
 22:     """
 23: 
 24:     def __init__(
 25:         self,
 26:         model: AsymmetricMASt3R,
 27:         frames: SharedKeyframes,
 28:         K: Float[Tensor, "3 3"] | None = None,
 29:         device: str = "cuda",
 30:     ) -> None:
 31:         self.model: AsymmetricMASt3R = model
 32:         self.frames: SharedKeyframes = frames
 33:         self.device: str = device
 34:         self.cfg: dict = config["local_opt"]
 35:         self.ii: Int[Tensor, "..."] = torch.as_tensor([], dtype=torch.long, device=self.device)
 36:         self.jj: Int[Tensor, "..."] = torch.as_tensor([], dtype=torch.long, device=self.device)
 37:         self.idx_ii2jj: Int[Tensor, "..."] = torch.as_tensor([], dtype=torch.long, device=self.device)
 38:         self.idx_jj2ii: Int[Tensor, "..."] = torch.as_tensor([], dtype=torch.long, device=self.device)
 39:         self.valid_match_j: Bool[Tensor, "..."] = torch.as_tensor([], dtype=torch.bool, device=self.device)
 40:         self.valid_match_i: Bool[Tensor, "..."] = torch.as_tensor([], dtype=torch.bool, device=self.device)
 41:         self.Q_ii2jj: Float32[Tensor, "..."] = torch.as_tensor([], dtype=torch.float32, device=self.device)
 42:         self.Q_jj2ii: Float32[Tensor, "..."] = torch.as_tensor([], dtype=torch.float32, device=self.device)
 43:         self.window_size: float = self.cfg["window_size"]
 44: 
 45:         self.K: Float[Tensor, "3 3"] | None = K
 46: 
 47:     def add_factors(
 48:         self,
 49:         ii: list[int],
 50:         jj: list[int],
 51:         min_match_frac: float,
 52:         is_reloc: bool = False,
 53:     ) -> bool:
 54:         """Add pairwise matching factors between keyframe pairs.
 55: 
 56:         Runs symmetric MASt3R matching between keyframes indexed by ``ii`` and
 57:         ``jj``, filters by match quality, and appends valid edges to the graph.
 58: 
 59:         Args:
 60:             ii: List of source keyframe indices.
 61:             jj: List of target keyframe indices.
 62:             min_match_frac: Minimum fraction of valid matches to accept an edge.
 63:             is_reloc: If True, return False immediately on any invalid edge.
 64: 
 65:         Returns:
 66:             True if at least one valid edge was added, False otherwise.
 67:         """
 68:         kf_ii: list[Frame] = [self.frames[idx] for idx in ii]
 69:         kf_jj: list[Frame] = [self.frames[idx] for idx in jj]
 70:         feat_i_list: list[Float[Tensor, "1 n_patches feat_dim"]] = []
 71:         feat_j_list: list[Float[Tensor, "1 n_patches feat_dim"]] = []
 72:         pos_i_list: list[Int[Tensor, "1 n_patches 2"]] = []
 73:         pos_j_list: list[Int[Tensor, "1 n_patches 2"]] = []
 74:         for kf_i in kf_ii:
 75:             assert kf_i.feat is not None
 76:             assert kf_i.pos is not None
 77:             feat_i_list.append(kf_i.feat)
 78:             pos_i_list.append(kf_i.pos)
 79:         for kf_j in kf_jj:
 80:             assert kf_j.feat is not None
 81:             assert kf_j.pos is not None
 82:             feat_j_list.append(kf_j.feat)
 83:             pos_j_list.append(kf_j.pos)
 84:         feat_i: Float[Tensor, "b n_patches feat_dim"] = torch.cat(feat_i_list)
 85:         feat_j: Float[Tensor, "b n_patches feat_dim"] = torch.cat(feat_j_list)
 86:         pos_i: Int[Tensor, "b n_patches 2"] = torch.cat(pos_i_list)
 87:         pos_j: Int[Tensor, "b n_patches 2"] = torch.cat(pos_j_list)
 88:         shape_i: list[Int[Tensor, "1 2"]] = [kf_i.img_true_shape for kf_i in kf_ii]
 89:         shape_j: list[Int[Tensor, "1 2"]] = [kf_j.img_true_shape for kf_j in kf_jj]
 90: 
 91:         (
 92:             idx_i2j,
 93:             idx_j2i,
 94:             valid_match_j,
 95:             valid_match_i,
 96:             Qii,
 97:             Qjj,
 98:             Qji,
 99:             Qij,
100:         ) = mast3r_match_symmetric(
101:             self.model, feat_i, pos_i, feat_j, pos_j, shape_i, shape_j
102:         )
103: 
104:         batch_inds: Int[Tensor, "b hw"] = torch.arange(idx_i2j.shape[0], device=idx_i2j.device)[
105:             :, None
106:         ].repeat(1, idx_i2j.shape[1])
107:         Qj: Float[Tensor, "b hw 1"] = torch.sqrt(Qii[batch_inds, idx_i2j] * Qji)
108:         Qi: Float[Tensor, "b hw 1"] = torch.sqrt(Qjj[batch_inds, idx_j2i] * Qij)
109: 
110:         valid_Qj: Bool[Tensor, "b hw 1"] = Qj > self.cfg["Q_conf"]
111:         valid_Qi: Bool[Tensor, "b hw 1"] = Qi > self.cfg["Q_conf"]
112:         valid_j: Bool[Tensor, "b hw 1"] = valid_match_j & valid_Qj
113:         valid_i: Bool[Tensor, "b hw 1"] = valid_match_i & valid_Qi
114:         nj: int = valid_j.shape[1] * valid_j.shape[2]
115:         ni: int = valid_i.shape[1] * valid_i.shape[2]
116:         match_frac_j: Float[Tensor, "b"] = valid_j.sum(dim=(1, 2)) / nj
117:         match_frac_i: Float[Tensor, "b"] = valid_i.sum(dim=(1, 2)) / ni
118: 
119:         ii_tensor: Int[Tensor, "b"] = torch.as_tensor(ii, device=self.device)
120:         jj_tensor: Int[Tensor, "b"] = torch.as_tensor(jj, device=self.device)
121: 
122:         # NOTE: Saying we need both edge directions to be above thrhreshold to accept either
123:         invalid_edges: Bool[Tensor, "b"] = torch.minimum(match_frac_j, match_frac_i) < min_match_frac
124:         consecutive_edges: Bool[Tensor, "b"] = ii_tensor == (jj_tensor - 1)
125:         invalid_edges = (~consecutive_edges) & invalid_edges
126: 
127:         if invalid_edges.any() and is_reloc:
128:             return False
129: 
130:         valid_edges: Bool[Tensor, "b"] = ~invalid_edges
131:         ii_tensor = ii_tensor[valid_edges]
132:         jj_tensor = jj_tensor[valid_edges]
133:         idx_i2j = idx_i2j[valid_edges]
134:         idx_j2i = idx_j2i[valid_edges]
135:         valid_match_j = valid_match_j[valid_edges]
136:         valid_match_i = valid_match_i[valid_edges]
137:         Qj = Qj[valid_edges]
138:         Qi = Qi[valid_edges]
139: 
140:         self.ii = torch.cat([self.ii, ii_tensor])
141:         self.jj = torch.cat([self.jj, jj_tensor])
142:         self.idx_ii2jj = torch.cat([self.idx_ii2jj, idx_i2j])
143:         self.idx_jj2ii = torch.cat([self.idx_jj2ii, idx_j2i])
144:         self.valid_match_j = torch.cat([self.valid_match_j, valid_match_j])
145:         self.valid_match_i = torch.cat([self.valid_match_i, valid_match_i])
146:         self.Q_ii2jj = torch.cat([self.Q_ii2jj, Qj])
147:         self.Q_jj2ii = torch.cat([self.Q_jj2ii, Qi])
148: 
149:         added_new_edges: bool = bool(valid_edges.sum() > 0)
150:         return added_new_edges
151: 
152:     def get_unique_kf_idx(self) -> Int[Tensor, "n_unique"]:
153:         """Return sorted unique keyframe indices from all edges.
154: 
155:         Returns:
156:             1-D tensor of unique keyframe indices.
157:         """
158:         return torch.unique(torch.cat([self.ii, self.jj]), sorted=True)
159: 
160:     def prep_two_way_edges(
161:         self,
162:     ) -> tuple[
163:         Int[Tensor, "n_edges"],
164:         Int[Tensor, "n_edges"],
165:         Int[Tensor, "n_edges hw"],
166:         Bool[Tensor, "n_edges hw 1"],
167:         Float[Tensor, "n_edges hw 1"],
168:     ]:
169:         """Concatenate forward and backward edges into symmetric form.
170: 
171:         Returns:
172:             A tuple of (ii, jj, idx_ii2jj, valid_match, Q_ii2jj) with
173:             doubled edges (original + reversed).
174:         """
175:         ii: Int[Tensor, "n_edges"] = torch.cat((self.ii, self.jj), dim=0)
176:         jj: Int[Tensor, "n_edges"] = torch.cat((self.jj, self.ii), dim=0)
177:         idx_ii2jj: Int[Tensor, "n_edges hw"] = torch.cat((self.idx_ii2jj, self.idx_jj2ii), dim=0)
178:         valid_match: Bool[Tensor, "n_edges hw 1"] = torch.cat((self.valid_match_j, self.valid_match_i), dim=0)
179:         Q_ii2jj: Float[Tensor, "n_edges hw 1"] = torch.cat((self.Q_ii2jj, self.Q_jj2ii), dim=0)
180:         return ii, jj, idx_ii2jj, valid_match, Q_ii2jj
181: 
182:     def get_poses_points(
183:         self,
184:         unique_kf_idx: Int[Tensor, "n_unique"],
185:     ) -> tuple[
186:         Float[Tensor, "n_unique hw 3"],
187:         lietorch.Sim3,
188:         Float[Tensor, "n_unique hw 1"],
189:     ]:
190:         """Read poses, point maps, and confidences for a set of keyframe indices.
191: 
192:         Args:
193:             unique_kf_idx: Tensor of keyframe buffer indices.
194: 
195:         Returns:
196:             A tuple of (Xs, world_sim3_cams, Cs) with stacked point maps, Sim3 poses,
197:             and average confidence values.
198:         """
199:         kfs: list[Frame] = [self.frames[idx] for idx in unique_kf_idx]
200:         X_list: list[Float[Tensor, "hw 3"]] = []
201:         C_list: list[Float[Tensor, "hw 1"]] = []
202:         for kf in kfs:
203:             assert kf.X_canon is not None
204:             X_list.append(kf.X_canon)
205:             avg_conf: Float[Tensor, "hw 1"] | None = kf.get_average_conf()
206:             assert avg_conf is not None
207:             C_list.append(avg_conf)
208:         Xs: Float[Tensor, "n_unique hw 3"] = torch.stack(X_list)
209:         world_sim3_cams: lietorch.Sim3 = lietorch.Sim3(torch.stack([kf.world_sim3_cam.data for kf in kfs]))
210: 
211:         Cs: Float[Tensor, "n_unique hw 1"] = torch.stack(C_list)
212: 
213:         return Xs, world_sim3_cams, Cs
214: 
215:     def solve_GN_rays(self) -> None:
216:         """Run Gauss-Newton optimisation using ray-distance residuals.
217: 
218:         Pins the first ``pin`` keyframes and optimises the rest.  Writes
219:         the updated poses back into the shared keyframe buffer.
220:         """
221:         pin: int = self.cfg["pin"]
222:         unique_kf_idx: Int[Tensor, "n_unique"] = self.get_unique_kf_idx()
223:         n_unique_kf: int = unique_kf_idx.numel()
224:         if n_unique_kf <= pin:
225:             return
226: 
227:         Xs: Float[Tensor, "n_unique hw 3"]
228:         world_sim3_cams: lietorch.Sim3
229:         Cs: Float[Tensor, "n_unique hw 1"]
230:         Xs, world_sim3_cams, Cs = self.get_poses_points(unique_kf_idx)
231: 
232:         ii: Int[Tensor, "n_edges"]
233:         jj: Int[Tensor, "n_edges"]
234:         idx_ii2jj: Int[Tensor, "n_edges hw"]
235:         valid_match: Bool[Tensor, "n_edges hw 1"]
236:         Q_ii2jj: Float[Tensor, "n_edges hw 1"]
237:         ii, jj, idx_ii2jj, valid_match, Q_ii2jj = self.prep_two_way_edges()
238: 
239:         C_thresh: float = self.cfg["C_conf"]
240:         Q_thresh: float = self.cfg["Q_conf"]
241:         max_iter: int = self.cfg["max_iters"]
242:         sigma_ray: float = self.cfg["sigma_ray"]
243:         sigma_dist: float = self.cfg["sigma_dist"]
244:         delta_thresh: float = self.cfg["delta_norm"]
245: 
246:         pose_data: Float[Tensor, "n_unique sim3_dim"] = world_sim3_cams.data[:, 0, :]
247:         _gn_backends.gauss_newton_rays(
248:             pose_data,
249:             Xs,
250:             Cs,
251:             ii,
252:             jj,
253:             idx_ii2jj,
254:             valid_match,
255:             Q_ii2jj,
256:             sigma_ray,
257:             sigma_dist,
258:             C_thresh,
259:             Q_thresh,
260:             max_iter,
261:             delta_thresh,
262:         )
263: 
264:         # Update the keyframe world_sim3_cam
265:         self.frames.update_world_sim3_cams(world_sim3_cams[pin:], unique_kf_idx[pin:])
266: 
267:     def solve_GN_calib(self) -> None:
268:         """Run Gauss-Newton optimisation using calibrated reprojection residuals.
269: 
270:         Constrains points to calibrated rays, then pins the first ``pin``
271:         keyframes and optimises the rest.  Writes the updated poses back
272:         into the shared keyframe buffer.
273:         """
274:         assert self.K is not None
275:         K: Float[Tensor, "3 3"] = self.K
276:         pin: int = self.cfg["pin"]
277:         unique_kf_idx: Int[Tensor, "n_unique"] = self.get_unique_kf_idx()
278:         n_unique_kf: int = unique_kf_idx.numel()
279:         if n_unique_kf <= pin:
280:             return
281: 
282:         Xs: Float[Tensor, "n_unique hw 3"]
283:         world_sim3_cams: lietorch.Sim3
284:         Cs: Float[Tensor, "n_unique hw 1"]
285:         Xs, world_sim3_cams, Cs = self.get_poses_points(unique_kf_idx)
286: 
287:         # Constrain points to ray
288:         img_size: tuple[int, int] = (int(self.frames[0].rgb_tensor.shape[-2]), int(self.frames[0].rgb_tensor.shape[-1]))
289:         Xs = constrain_points_to_ray(img_size, Xs, K)
290: 
291:         ii: Int[Tensor, "n_edges"]
292:         jj: Int[Tensor, "n_edges"]
293:         idx_ii2jj: Int[Tensor, "n_edges hw"]
294:         valid_match: Bool[Tensor, "n_edges hw 1"]
295:         Q_ii2jj: Float[Tensor, "n_edges hw 1"]
296:         ii, jj, idx_ii2jj, valid_match, Q_ii2jj = self.prep_two_way_edges()
297: 
298:         C_thresh: float = self.cfg["C_conf"]
299:         Q_thresh: float = self.cfg["Q_conf"]
300:         pixel_border: float = self.cfg["pixel_border"]
301:         z_eps: float = self.cfg["depth_eps"]
302:         max_iter: int = self.cfg["max_iters"]
