 421: def gauss_newton_rays_step_kernel(
 422:     twc: UnsafePointer[Float32, MutAnyOrigin],
 423:     xs: UnsafePointer[Float32, MutAnyOrigin],
 424:     cs: UnsafePointer[Float32, MutAnyOrigin],
 425:     ii: UnsafePointer[Int64, MutAnyOrigin],
 426:     jj: UnsafePointer[Int64, MutAnyOrigin],
 427:     idx_ii2jj: UnsafePointer[Int64, MutAnyOrigin],
 428:     valid_match: UnsafePointer[UInt8, MutAnyOrigin],
 429:     q_tensor: UnsafePointer[Float32, MutAnyOrigin],
 430:     hs: UnsafePointer[Float32, MutAnyOrigin],
 431:     gs: UnsafePointer[Float32, MutAnyOrigin],
 432:     num_points: Int,
 433:     num_edges: Int,
 434:     sigma_ray: Float32,
 435:     sigma_dist: Float32,
 436:     c_thresh: Float32,
 437:     q_thresh: Float32,
 438: ):
 439:     var edge = Int(block_idx.x)
 440:     var tid = Int(thread_idx.x)
 441:     var block_threads = Int(block_dim.x)
 442:     if edge >= num_edges:
 443:         return
 444: 
 445:     var ix = Int(ii[edge])
 446:     var jx = Int(jj[edge])
 447:     var pi = ix * POSE_STRIDE
 448:     var pj = jx * POSE_STRIDE
 449: 
 450:     var rel = rel_sim3_components(
 451:         twc[pi + 0], twc[pi + 1], twc[pi + 2],
 452:         twc[pi + 3], twc[pi + 4], twc[pi + 5], twc[pi + 6],
 453:         twc[pi + 7],
 454:         twc[pj + 0], twc[pj + 1], twc[pj + 2],
 455:         twc[pj + 3], twc[pj + 4], twc[pj + 5], twc[pj + 6],
 456:         twc[pj + 7],
 457:     )
 458: 
 459:     var hij = InlineArray[Float32, RAYS_HDIM](fill=0.0)
 460:     var vi = InlineArray[Float32, POSE_DIM](fill=0.0)
 461:     var vj = InlineArray[Float32, POSE_DIM](fill=0.0)
 462:     var jxv = InlineArray[Float32, 14](fill=0.0)
 463: 
 464:     var sigma_ray_inv = 1.0 / sigma_ray
 465:     var sigma_dist_inv = 1.0 / sigma_dist
 466: 
 467:     for k in range(tid, num_points, block_threads):
 468:         var valid_match_ind = valid_match[edge * num_points + k] != 0
 469:         var ind_xi = Int(idx_ii2jj[edge * num_points + k])
 470:         if not valid_match_ind:
 471:             ind_xi = 0
 472: 
 473:         var xi_base = (ix * num_points + ind_xi) * 3
 474:         var xj_base = (jx * num_points + k) * 3
 475:         var ci = cs[ix * num_points + ind_xi]
 476:         var cj = cs[jx * num_points + k]
 477:         var qv = q_tensor[edge * num_points + k]
 478: 
 479:         var xi0 = xs[xi_base + 0]
 480:         var xi1 = xs[xi_base + 1]
 481:         var xi2 = xs[xi_base + 2]
 482:         var xj0 = xs[xj_base + 0]
 483:         var xj1 = xs[xj_base + 1]
 484:         var xj2 = xs[xj_base + 2]
 485: 
 486:         var norm2_i = squared_norm3_components(xi0, xi1, xi2)
 487:         var norm1_i = sqrt(norm2_i)
 488:         var norm1_i_inv = 1.0 / norm1_i
 489:         var ri0 = norm1_i_inv * xi0
 490:         var ri1 = norm1_i_inv * xi1
 491:         var ri2 = norm1_i_inv * xi2
 492: 
 493:         var xj_ci = act_sim3_components(
 494:             rel[0], rel[1], rel[2], rel[3], rel[4], rel[5], rel[6], rel[7], xj0, xj1, xj2
 495:         )
 496:         var norm2_j = squared_norm3_components(xj_ci[0], xj_ci[1], xj_ci[2])
 497:         var norm1_j = sqrt(norm2_j)
 498:         var norm1_j_inv = 1.0 / norm1_j
 499:         var rj0 = norm1_j_inv * xj_ci[0]
 500:         var rj1 = norm1_j_inv * xj_ci[1]
 501:         var rj2 = norm1_j_inv * xj_ci[2]
 502: 
 503:         var err0 = rj0 - ri0
 504:         var err1 = rj1 - ri1
 505:         var err2 = rj2 - ri2
 506:         var err3 = norm1_j - norm1_i
 507: 
 508:         var valid = valid_match_ind and (qv > q_thresh) and (ci > c_thresh) and (cj > c_thresh)
 509:         var conf_weight: Float32 = qv
 510:         var sqrt_w_ray: Float32 = 0.0
 511:         var sqrt_w_dist: Float32 = 0.0
 512:         if valid:
 513:             var sqrt_conf = sqrt(conf_weight)
 514:             sqrt_w_ray = sigma_ray_inv * sqrt_conf
 515:             sqrt_w_dist = sigma_dist_inv * sqrt_conf
 516: 
 517:         var w0 = huber_scalar(sqrt_w_ray * err0) * sqrt_w_ray * sqrt_w_ray
 518:         var w1 = huber_scalar(sqrt_w_ray * err1) * sqrt_w_ray * sqrt_w_ray
 519:         var w2 = huber_scalar(sqrt_w_ray * err2) * sqrt_w_ray * sqrt_w_ray
 520:         var w3 = huber_scalar(sqrt_w_dist * err3) * sqrt_w_dist * sqrt_w_dist
 521: 
 522:         var norm3_j_inv = norm1_j_inv / norm2_j
 523:         var drx_dpx = norm1_j_inv - xj_ci[0] * xj_ci[0] * norm3_j_inv
 524:         var dry_dpy = norm1_j_inv - xj_ci[1] * xj_ci[1] * norm3_j_inv
 525:         var drz_dpz = norm1_j_inv - xj_ci[2] * xj_ci[2] * norm3_j_inv
 526:         var drx_dpy = -xj_ci[0] * xj_ci[1] * norm3_j_inv
 527:         var drx_dpz = -xj_ci[0] * xj_ci[2] * norm3_j_inv
 528:         var dry_dpz = -xj_ci[1] * xj_ci[2] * norm3_j_inv
 529: 
 530:         @parameter
 531:         def accumulate_row(
 532:             err: Float32,
 533:             w: Float32,
 534:             ji0: Float32, ji1: Float32, ji2: Float32, ji3: Float32, ji4: Float32, ji5: Float32, ji6: Float32,
 535:         ):
 536:             var jadj = apply_sim3_adj_inv_components(
 537:                 twc[pi + 0], twc[pi + 1], twc[pi + 2],
 538:                 twc[pi + 3], twc[pi + 4], twc[pi + 5], twc[pi + 6], twc[pi + 7],
 539:                 ji0, ji1, ji2, ji3, ji4, ji5, ji6,
 540:             )
 541:             for n in range(POSE_DIM):
 542:                 jxv[n + 7] = jadj[n]
 543:                 jxv[n] = -jadj[n]
 544:             var l = 0
 545:             for n in range(14):
 546:                 for m in range(n + 1):
 547:                     hij[l] += w * jxv[n] * jxv[m]
 548:                     l += 1
 549:             for n in range(POSE_DIM):
 550:                 vi[n] += w * err * jxv[n]
 551:                 vj[n] += w * err * jxv[n + 7]
 552: 
 553:         accumulate_row(err0, w0, drx_dpx, drx_dpy, drx_dpz, 0.0, rj2, -rj1, 0.0)
 554:         accumulate_row(err1, w1, drx_dpy, dry_dpy, dry_dpz, -rj2, 0.0, rj0, 0.0)
 555:         accumulate_row(err2, w2, drx_dpz, dry_dpz, drz_dpz, rj1, -rj0, 0.0, 0.0)
 556:         accumulate_row(err3, w3, rj0, rj1, rj2, 0.0, 0.0, 0.0, norm1_j)
 557: 
 558:     var sdata = stack_allocation[
 559:         RAYS_THREADS,
 560:         Scalar[DType.float32],
 561:         address_space=AddressSpace.SHARED,
 562:     ]()
 563: 
 564:     for n in range(POSE_DIM):
 565:         sdata[tid] = vi[n]
 566:         barrier()
 567:         var active = block_threads // 2
 568:         while active > 0:
 569:             if tid < active:
 570:                 sdata[tid] += sdata[tid + active]
 571:             barrier()
 572:             active = active // 2
 573:         if tid == 0:
 574:             gs[(0 * num_edges + edge) * POSE_DIM + n] = sdata[0][0]
 575: 
 576:         sdata[tid] = vj[n]
 577:         barrier()
 578:         active = block_threads // 2
 579:         while active > 0:
 580:             if tid < active:
 581:                 sdata[tid] += sdata[tid + active]
 582:             barrier()
 583:             active = active // 2
 584:         if tid == 0:
 585:             gs[(1 * num_edges + edge) * POSE_DIM + n] = sdata[0][0]
 586: 
 587:     var l = 0
 588:     for n in range(14):
 589:         for m in range(n + 1):
 590:             sdata[tid] = hij[l]
 591:             barrier()
 592:             var active_h = block_threads // 2
 593:             while active_h > 0:
 594:                 if tid < active_h:
 595:                     sdata[tid] += sdata[tid + active_h]
 596:                 barrier()
 597:                 active_h = active_h // 2
 598:             if tid == 0:
 599:                 var val = sdata[0][0]
 600:                 if n < 7 and m < 7:
 601:                     hs[((0 * num_edges + edge) * 49) + n * 7 + m] = val
 602:                     hs[((0 * num_edges + edge) * 49) + m * 7 + n] = val
 603:                 elif n >= 7 and m < 7:
 604:                     hs[((1 * num_edges + edge) * 49) + m * 7 + (n - 7)] = val
 605:                     hs[((2 * num_edges + edge) * 49) + (n - 7) * 7 + m] = val
 606:                 else:
 607:                     hs[((3 * num_edges + edge) * 49) + (n - 7) * 7 + (m - 7)] = val
 608:                     hs[((3 * num_edges + edge) * 49) + (m - 7) * 7 + (n - 7)] = val
 609:             l += 1
 610: 
