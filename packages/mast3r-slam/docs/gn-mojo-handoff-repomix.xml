1739:   calib_proj_kernel<<<num_edges, THREADS>>>(
1740:     Twc.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
1741:     Xs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1742:     Cs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1743:     K.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
1744:     ii.packed_accessor32<long,1,torch::RestrictPtrTraits>(),
1745:     jj.packed_accessor32<long,1,torch::RestrictPtrTraits>(),
1746:     idx_ii2jj.packed_accessor32<long,2,torch::RestrictPtrTraits>(),
1747:     valid_match.packed_accessor32<bool,3,torch::RestrictPtrTraits>(),
1748:     Q.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1749:     Hs.packed_accessor32<float,4,torch::RestrictPtrTraits>(),
1750:     gs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1751:     height, width, pixel_border, z_eps, sigma_pixel, sigma_depth,
1752:     C_thresh, Q_thresh
1753:   );
