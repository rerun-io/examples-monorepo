   1: """Mojo GPU implementations of mast3r-slam matching kernels.
   2: 
   3: Provides `iter_proj` and `refine_matches` as drop-in replacements
   4: for the CUDA implementations in mast3r_slam_backends.
   5: 
   6: Build: mojo build --emit shared-lib -o mast3r_slam_mojo_backends.so \
   7:            mast3r_slam/backend/mojo/matching_kernels.mojo
   8: """
   9: 
  10: from gn_kernels import GN_IMPORT_SENTINEL
  11: 
  12: from std.os import abort
  13: from std.math import ceildiv, sqrt, min, max, floor, exp, sin, cos, abs
  14: from std.sys import has_accelerator
  15: from std.gpu import global_idx, block_idx, block_dim, thread_idx, barrier
  16: from std.gpu.host import DeviceContext, DeviceBuffer
  17: from std.gpu.memory import AddressSpace
  18: from std.memory import alloc
  19: from std.memory import stack_allocation
  20: from std.python import Python, PythonObject
  21: from std.python.bindings import PythonModuleBuilder
  22: 
  23: # ─── Launch heuristics ────────────────────────────────────────────────────────
  24: # The CUDA reference uses 16 threads. Mojo benefits from larger blocks on large
  25: # workloads, but that hurts the smaller 64x64 iter_proj benchmark where wrapper
  26: # overhead dominates. Pick block sizes per workload instead of forcing a single
  27: # compile-time choice for every case.
  28: def choose_iter_proj_block(num_pts: Int) -> Int:
  29:     if num_pts <= 4096:
  30:         return 16
  31:     if num_pts <= 16384:
  32:         return 64
  33:     return 128
  34: 
  35: 
  36: def choose_refine_block(num_pts: Int, fdim: Int) -> Int:
  37:     if num_pts <= 1024:
  38:         return 8
  39:     return 16
  40: 
  41: 
  42: def get_cached_context_ptr() raises -> UnsafePointer[DeviceContext, MutAnyOrigin]:
  43:     """Return the process-lifetime DeviceContext storage for this extension."""
  44:     var module = Python.import_module("mast3r_slam_mojo_backends")
  45:     var ctx_addr = Int(py=module._ctx_addr)
  46:     return UnsafePointer[DeviceContext, MutAnyOrigin](
  47:         unsafe_from_address=ctx_addr
  48:     )
  49: 
  50: 
  51: def get_torch_module() raises -> PythonObject:
  52:     return Python.import_module("torch")
  53: 
  54: 
  55: def get_cuda_backend_module() raises -> PythonObject:
  56:     return Python.import_module("mast3r_slam._backends")
  57: 
  58: 
  59: def get_lietorch_module() raises -> PythonObject:
  60:     return Python.import_module("lietorch")
  61: 
  62: 
  63: comptime POSE_DIM = 7
  64: comptime POSE_STRIDE = 8
  65: comptime RAYS_HDIM = 14 * (14 + 1) // 2
  66: comptime RAYS_THREADS = 64
  67: 
  68: 
  69: def get_unique_kf_idx(ii: PythonObject, jj: PythonObject) raises -> PythonObject:
  70:     var torch = get_torch_module()
  71:     return torch.unique(torch.cat(Python.list(ii, jj)), sorted=True)
  72: 
  73: 
  74: def create_inds(
  75:     unique_kf_idx: PythonObject,
  76:     pin: Int,
  77:     ii: PythonObject,
  78:     jj: PythonObject,
  79: ) raises -> PythonObject:
  80:     var torch = get_torch_module()
  81:     var ii_ind = torch.searchsorted(unique_kf_idx, ii) - pin
  82:     var jj_ind = torch.searchsorted(unique_kf_idx, jj) - pin
  83:     return Python.tuple(ii_ind, jj_ind)
  84: 
  85: 
  86: def assemble_dense_system(
  87:     hs: PythonObject,
  88:     gs: PythonObject,
  89:     ii_opt: PythonObject,
  90:     jj_opt: PythonObject,
  91:     n_vars: Int,
  92: ) raises -> PythonObject:
  93:     var torch = get_torch_module()
  94:     var flat_h = torch.zeros(
  95:         Python.list(n_vars * n_vars, POSE_DIM * POSE_DIM),
  96:         device=hs.device,
  97:         dtype=hs.dtype,
  98:     )
  99:     var block_terms = torch.cat(Python.list(hs[0], hs[1], hs[2], hs[3]), dim=0).reshape(-1, POSE_DIM * POSE_DIM)
 100:     var rows = torch.cat(Python.list(ii_opt, ii_opt, jj_opt, jj_opt), dim=0)
 101:     var cols = torch.cat(Python.list(ii_opt, jj_opt, ii_opt, jj_opt), dim=0)
 102:     var valid_h = (rows >= 0) & (cols >= 0)
 103:     if Bool(py=valid_h.any().item()):
 104:         var block_indices = rows[valid_h] * n_vars + cols[valid_h]
 105:         flat_h.index_add_(0, block_indices, block_terms[valid_h])
 106:     var h_dense = flat_h.view(n_vars, n_vars, POSE_DIM, POSE_DIM).permute(0, 2, 1, 3).reshape(
 107:         n_vars * POSE_DIM,
 108:         n_vars * POSE_DIM,
 109:     )
 110: 
 111:     var b_dense = torch.zeros(
 112:         Python.list(n_vars, POSE_DIM),
 113:         device=gs.device,
 114:         dtype=gs.dtype,
 115:     )
 116:     var rhs_terms = torch.cat(Python.list(gs[0], gs[1]), dim=0)
 117:     var rhs_rows = torch.cat(Python.list(ii_opt, jj_opt), dim=0)
 118:     var valid_b = rhs_rows >= 0
 119:     if Bool(py=valid_b.any().item()):
 120:         b_dense.index_add_(0, rhs_rows[valid_b], rhs_terms[valid_b])
 121: 
 122:     return Python.tuple(h_dense, b_dense)
 123: 
 124: 
 125: def solve_dense_system(
 126:     h_dense: PythonObject,
 127:     b_dense: PythonObject,
 128:     n_vars: Int,
 129: ) raises -> PythonObject:
 130:     var torch = get_torch_module()
 131:     if n_vars <= 0:
 132:         return torch.zeros(Python.list(0, POSE_DIM), device=h_dense.device, dtype=h_dense.dtype)
 133: 
 134:     var h64 = h_dense.to(dtype=torch.float64)
 135:     var b64 = b_dense.to(dtype=torch.float64)
 136:     var rhs = -b64.reshape(n_vars * POSE_DIM, 1)
 137:     var eye = torch.eye(n_vars * POSE_DIM, device=h_dense.device, dtype=torch.float64)
 138:     var chol_h = h64 + 1e-9 * eye
 139:     var chol = torch.linalg.cholesky_ex(chol_h, upper=False)
 140:     var l_factor = chol[0]
 141:     var info = chol[1]
 142:     if Int(py=info.max().item()) != 0:
 143:         return torch.zeros(Python.list(n_vars, POSE_DIM), device=h_dense.device, dtype=h_dense.dtype)
 144:     var dx_vec = torch.cholesky_solve(rhs, l_factor, upper=False)
 145:     return dx_vec.to(dtype=h_dense.dtype).view(n_vars, POSE_DIM)
 146: 
 147: 
 148: def assemble_h_dense_kernel(
 149:     hs: UnsafePointer[Float32, MutAnyOrigin],
 150:     ii_opt: UnsafePointer[Int64, MutAnyOrigin],
 151:     jj_opt: UnsafePointer[Int64, MutAnyOrigin],
 152:     h_dense: UnsafePointer[Float64, MutAnyOrigin],
 153:     num_edges: Int,
 154:     n_vars: Int,
 155: ):
 156:     var row: Int = Int(global_idx.x)
 157:     var col: Int = Int(global_idx.y)
 158:     var dim: Int = n_vars * POSE_DIM
 159:     if row >= dim or col >= dim:
 160:         return
 161: 
 162:     var bi = row // POSE_DIM
 163:     var bj = col // POSE_DIM
 164:     var ki = row % POSE_DIM
 165:     var kj = col % POSE_DIM
 166: 
 167:     var acc: Float64 = 0.0
 168:     for e in range(num_edges):
 169:         var ii = Int(ii_opt[e])
 170:         var jj = Int(jj_opt[e])
 171:         if ii >= 0 and bj == ii and bi == ii:
 172:             acc += Float64(hs[((0 * num_edges + e) * POSE_DIM + ki) * POSE_DIM + kj])
 173:         if ii >= 0 and jj >= 0 and bi == ii and bj == jj:
 174:             acc += Float64(hs[((1 * num_edges + e) * POSE_DIM + ki) * POSE_DIM + kj])
 175:         if ii >= 0 and jj >= 0 and bi == jj and bj == ii:
 176:             acc += Float64(hs[((2 * num_edges + e) * POSE_DIM + ki) * POSE_DIM + kj])
 177:         if jj >= 0 and bi == jj and bj == jj:
 178:             acc += Float64(hs[((3 * num_edges + e) * POSE_DIM + ki) * POSE_DIM + kj])
 179:     h_dense[row * dim + col] = acc
 180: 
 181: 
 182: def assemble_b_dense_kernel(
 183:     gs: UnsafePointer[Float32, MutAnyOrigin],
 184:     ii_opt: UnsafePointer[Int64, MutAnyOrigin],
 185:     jj_opt: UnsafePointer[Int64, MutAnyOrigin],
 186:     b_dense: UnsafePointer[Float64, MutAnyOrigin],
 187:     num_edges: Int,
 188:     n_vars: Int,
 189: ):
 190:     var row: Int = Int(global_idx.x)
 191:     var col: Int = Int(global_idx.y)
 192:     if row >= n_vars or col >= POSE_DIM:
 193:         return
 194: 
 195:     var acc: Float64 = 0.0
 196:     for e in range(num_edges):
 197:         var ii = Int(ii_opt[e])
 198:         var jj = Int(jj_opt[e])
 199:         if ii >= 0 and row == ii:
 200:             acc += Float64(gs[(0 * num_edges + e) * POSE_DIM + col])
 201:         if jj >= 0 and row == jj:
 202:             acc += Float64(gs[(1 * num_edges + e) * POSE_DIM + col])
 203:     b_dense[row * POSE_DIM + col] = acc
 204: 
 205: 
 206: @always_inline
 207: def quat_comp_components(
 208:     aix: Float32, aiy: Float32, aiz: Float32, aiw: Float32,
 209:     bjx: Float32, bjy: Float32, bjz: Float32, bjw: Float32,
 210: ) -> InlineArray[Float32, 4]:
 211:     var out = InlineArray[Float32, 4](fill=0.0)
 212:     out[0] = aiw * bjx + aix * bjw + aiy * bjz - aiz * bjy
 213:     out[1] = aiw * bjy - aix * bjz + aiy * bjw + aiz * bjx
 214:     out[2] = aiw * bjz + aix * bjy - aiy * bjx + aiz * bjw
 215:     out[3] = aiw * bjw - aix * bjx - aiy * bjy - aiz * bjz
 216:     return out^
 217: 
 218: 
 219: @always_inline
 220: def act_so3_components(
 221:     qx: Float32, qy: Float32, qz: Float32, qw: Float32,
 222:     x0: Float32, x1: Float32, x2: Float32,
 223: ) -> InlineArray[Float32, 3]:
 224:     var uv0 = 2.0 * (qy * x2 - qz * x1)
 225:     var uv1 = 2.0 * (qz * x0 - qx * x2)
 226:     var uv2 = 2.0 * (qx * x1 - qy * x0)
 227:     var out = InlineArray[Float32, 3](fill=0.0)
 228:     out[0] = x0 + qw * uv0 + (qy * uv2 - qz * uv1)
 229:     out[1] = x1 + qw * uv1 + (qz * uv0 - qx * uv2)
 230:     out[2] = x2 + qw * uv2 + (qx * uv1 - qy * uv0)
 231:     return out^
 232: 
 233: 
 234: @always_inline
 235: def exp_so3_components(phi0: Float32, phi1: Float32, phi2: Float32) -> InlineArray[Float32, 4]:
 236:     var theta_sq = phi0 * phi0 + phi1 * phi1 + phi2 * phi2
 237:     var theta_p4 = theta_sq * theta_sq
 238:     var imag: Float32
 239:     var real: Float32
 240:     if theta_sq < 1e-6:
 241:         imag = 0.5 - (1.0 / 48.0) * theta_sq + (1.0 / 3840.0) * theta_p4
 242:         real = 1.0 - (1.0 / 8.0) * theta_sq + (1.0 / 384.0) * theta_p4
 243:     else:
 244:         var theta = sqrt(theta_sq)
 245:         imag = sin(0.5 * theta) / theta
 246:         real = cos(0.5 * theta)
 247:     var out = InlineArray[Float32, 4](fill=0.0)
 248:     out[0] = imag * phi0
 249:     out[1] = imag * phi1
 250:     out[2] = imag * phi2
 251:     out[3] = real
 252:     return out^
 253: 
 254: 
 255: @always_inline
 256: def exp_sim3_components(
 257:     xi0: Float32, xi1: Float32, xi2: Float32, xi3: Float32, xi4: Float32, xi5: Float32, xi6: Float32,
 258: ) -> InlineArray[Float32, 8]:
 259:     var tau0: Float32 = xi0
 260:     var tau1: Float32 = xi1
 261:     var tau2: Float32 = xi2
 262:     var phi0: Float32 = xi3
 263:     var phi1: Float32 = xi4
 264:     var phi2: Float32 = xi5
 265:     var sigma: Float32 = xi6
 266:     var scale: Float32 = exp(sigma)
 267:     var q = exp_so3_components(phi0, phi1, phi2)
 268: 
 269:     var theta_sq: Float32 = phi0 * phi0 + phi1 * phi1 + phi2 * phi2
 270:     var theta: Float32 = sqrt(theta_sq)
 271:     var A: Float32
 272:     var B: Float32
 273:     var C: Float32
 274:     if abs(sigma) < Float32(1e-6):
 275:         C = 1.0
 276:         if abs(theta) < Float32(1e-6):
 277:             A = 0.5
 278:             B = 1.0 / 6.0
 279:         else:
 280:             A = (1.0 - cos(theta)) / theta_sq
 281:             B = (theta - sin(theta)) / (theta_sq * theta)
 282:     else:
 283:         C = (scale - 1.0) / sigma
 284:         if abs(theta) < Float32(1e-6):
 285:             var sigma_sq: Float32 = sigma * sigma
 286:             A = ((sigma - 1.0) * scale + 1.0) / sigma_sq
 287:             B = (scale * 0.5 * sigma_sq + scale - 1.0 - sigma * scale) / (sigma_sq * sigma)
 288:         else:
 289:             var a: Float32 = scale * sin(theta)
 290:             var b: Float32 = scale * cos(theta)
 291:             var c: Float32 = theta_sq + sigma * sigma
 292:             A = (a * sigma + (1.0 - b) * theta) / (theta * c)
 293:             B = (C - (((b - 1.0) * sigma + a * theta) / c)) / theta_sq
 294: 
 295:     var out = InlineArray[Float32, 8](fill=0.0)
 296:     out[0] = C * tau0
 297:     out[1] = C * tau1
 298:     out[2] = C * tau2
 299: 
 300:     var cx0: Float32 = phi1 * tau2 - phi2 * tau1
 301:     var cx1: Float32 = phi2 * tau0 - phi0 * tau2
 302:     var cx2: Float32 = phi0 * tau1 - phi1 * tau0
 303:     out[0] += A * cx0
 304:     out[1] += A * cx1
 305:     out[2] += A * cx2
 306: 
 307:     var c2x0: Float32 = phi1 * cx2 - phi2 * cx1
 308:     var c2x1: Float32 = phi2 * cx0 - phi0 * cx2
 309:     var c2x2: Float32 = phi0 * cx1 - phi1 * cx0
 310:     out[0] += B * c2x0
 311:     out[1] += B * c2x1
 312:     out[2] += B * c2x2
 313:     out[3] = q[0]
 314:     out[4] = q[1]
 315:     out[5] = q[2]
 316:     out[6] = q[3]
 317:     out[7] = scale
 318:     return out^
 319: 
