1625: std::vector<torch::Tensor> gauss_newton_calib_cuda(
1626:   torch::Tensor Twc, torch::Tensor Xs, torch::Tensor Cs,
1627:   torch::Tensor K,
1628:   torch::Tensor ii, torch::Tensor jj, 
1629:   torch::Tensor idx_ii2jj, torch::Tensor valid_match,
1630:   torch::Tensor Q,
1631:   const int height, const int width,
1632:   const int pixel_border,
1633:   const float z_eps,
1634:   const float sigma_pixel, const float sigma_depth,
1635:   const float C_thresh,
1636:   const float Q_thresh,
1637:   const int max_iter,
1638:   const float delta_thresh)
1639: {
1640:   auto opts = Twc.options();
1641:   const int num_edges = ii.size(0);
1642:   const int num_poses = Xs.size(0);
1643:   const int n = Xs.size(1);
1644: 
1645:   const int num_fix = 1;
1646: 
1647:   // Setup indexing
1648:   torch::Tensor unique_kf_idx = get_unique_kf_idx(ii, jj);
1649:   // For edge construction
1650:   std::vector<torch::Tensor> inds = create_inds(unique_kf_idx, 0, ii, jj);
1651:   torch::Tensor ii_edge = inds[0];
1652:   torch::Tensor jj_edge = inds[1];
1653:   // For linear system indexing (pin=2 because fixing first two poses)
1654:   std::vector<torch::Tensor> inds_opt = create_inds(unique_kf_idx, num_fix, ii, jj);
1655:   torch::Tensor ii_opt = inds_opt[0];
1656:   torch::Tensor jj_opt = inds_opt[1];
1657: 
1658:   const int pose_dim = 7; // sim3
1659: 
1660:   // initialize buffers
1661:   torch::Tensor Hs = torch::zeros({4, num_edges, pose_dim, pose_dim}, opts);
1662:   torch::Tensor gs = torch::zeros({2, num_edges, pose_dim}, opts);
1663: 
1664:   // For debugging outputs
1665:   torch::Tensor dx;
1666: 
1667:   torch::Tensor delta_norm;
1668: 
1669:   for (int itr=0; itr<max_iter; itr++) {
1670: 
1671:     calib_proj_kernel<<<num_edges, THREADS>>>(
1672:       Twc.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
1673:       Xs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1674:       Cs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1675:       K.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
1676:       ii_edge.packed_accessor32<long,1,torch::RestrictPtrTraits>(),
1677:       jj_edge.packed_accessor32<long,1,torch::RestrictPtrTraits>(),
1678:       idx_ii2jj.packed_accessor32<long,2,torch::RestrictPtrTraits>(),
1679:       valid_match.packed_accessor32<bool,3,torch::RestrictPtrTraits>(),
1680:       Q.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1681:       Hs.packed_accessor32<float,4,torch::RestrictPtrTraits>(),
1682:       gs.packed_accessor32<float,3,torch::RestrictPtrTraits>(),
1683:       height, width, pixel_border, z_eps, sigma_pixel, sigma_depth, C_thresh, Q_thresh
1684:     );
1685: 
1686: 
1687:     // pose x pose block
1688:     SparseBlock A(num_poses - num_fix, pose_dim);
1689: 
1690:     A.update_lhs(Hs.reshape({-1, pose_dim, pose_dim}), 
1691:         torch::cat({ii_opt, ii_opt, jj_opt, jj_opt}), 
1692:         torch::cat({ii_opt, jj_opt, ii_opt, jj_opt}));
1693: 
1694:     A.update_rhs(gs.reshape({-1, pose_dim}), 
1695:         torch::cat({ii_opt, jj_opt}));
1696: 
1697:     // NOTE: Accounting for negative here!
1698:     dx = -A.solve();
1699: 
1700:     
1701:     pose_retr_kernel<<<1, THREADS>>>(
1702:       Twc.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
1703:       dx.packed_accessor32<float,2,torch::RestrictPtrTraits>(),
1704:       num_fix);
1705: 
1706:     // Termination criteria
1707:     // Need to specify this second argument otherwise ambiguous function call...
1708:     delta_norm = torch::linalg_norm(dx, std::optional<c10::Scalar>(), {}, false, {});
1709:     if (delta_norm.item<float>() < delta_thresh) {
1710:       break;
1711:     }
1712:         
1713: 
