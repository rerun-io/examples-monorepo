426:         var norm3_j_inv = norm1_j_inv / norm2_j
427:         var drx_dpx = norm1_j_inv - xj_ci[0] * xj_ci[0] * norm3_j_inv
428:         var dry_dpy = norm1_j_inv - xj_ci[1] * xj_ci[1] * norm3_j_inv
429:         var drz_dpz = norm1_j_inv - xj_ci[2] * xj_ci[2] * norm3_j_inv
430:         var drx_dpy = -xj_ci[0] * xj_ci[1] * norm3_j_inv
431:         var drx_dpz = -xj_ci[0] * xj_ci[2] * norm3_j_inv
432:         var dry_dpz = -xj_ci[1] * xj_ci[2] * norm3_j_inv
433: 
434:         @parameter
435:         def accumulate_row(
436:             err: Float32,
437:             w: Float32,
438:             ji0: Float32, ji1: Float32, ji2: Float32, ji3: Float32, ji4: Float32, ji5: Float32, ji6: Float32,
439:         ):
440:             var jadj = apply_sim3_adj_inv_components(
