 612: def pose_retr_kernel(
 613:     poses: UnsafePointer[Float32, MutAnyOrigin],
 614:     dx: UnsafePointer[Float32, MutAnyOrigin],
 615:     num_fix: Int,
 616:     num_poses: Int,
 617: ):
 618:     var k: Int = Int(global_idx.x) + num_fix
 619:     if k >= num_poses:
 620:         return
 621:     var xi = exp_sim3_components(
 622:         dx[(k - num_fix) * POSE_DIM + 0],
 623:         dx[(k - num_fix) * POSE_DIM + 1],
 624:         dx[(k - num_fix) * POSE_DIM + 2],
 625:         dx[(k - num_fix) * POSE_DIM + 3],
 626:         dx[(k - num_fix) * POSE_DIM + 4],
 627:         dx[(k - num_fix) * POSE_DIM + 5],
 628:         dx[(k - num_fix) * POSE_DIM + 6],
 629:     )
 630:     var p = k * 8
 631:     var rot_t = act_so3_components(
 632:         xi[3], xi[4], xi[5], xi[6],
 633:         poses[p + 0], poses[p + 1], poses[p + 2],
 634:     )
 635:     var q1 = quat_comp_components(
 636:         xi[3], xi[4], xi[5], xi[6],
 637:         poses[p + 3], poses[p + 4], poses[p + 5], poses[p + 6],
 638:     )
 639:     poses[p + 0] = rot_t[0] * xi[7] + xi[0]
 640:     poses[p + 1] = rot_t[1] * xi[7] + xi[1]
 641:     poses[p + 2] = rot_t[2] * xi[7] + xi[2]
 642:     poses[p + 3] = q1[0]
 643:     poses[p + 4] = q1[1]
 644:     poses[p + 5] = q1[2]
 645:     poses[p + 6] = q1[3]
 646:     poses[p + 7] = xi[7] * poses[p + 7]
 647: 
