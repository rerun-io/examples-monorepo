 143:         Eigen::VectorXd x = solver.solve(b);
 144:         dx = torch::from_blob(x.data(), {N, M}, torch::TensorOptions()
 145:           .dtype(torch::kFloat64)).to(torch::kCUDA).to(torch::kFloat32);
 146:       }
 147:       else {
 148:         dx = torch::zeros({N, M}, torch::TensorOptions()
 149:           .device(torch::kCUDA).dtype(torch::kFloat32));
 150:       }
 151:       
 152:       return dx;
 153:     }
 154: 
 155:   private:
 156:     const int N;
 157:     const int M;
 158: 
 159: };
