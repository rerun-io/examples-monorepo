 321: @always_inline
 322: def quat_inv_components(
 323:     qx: Float32, qy: Float32, qz: Float32, qw: Float32,
 324: ) -> InlineArray[Float32, 4]:
 325:     var out = InlineArray[Float32, 4](fill=0.0)
 326:     out[0] = -qx
 327:     out[1] = -qy
 328:     out[2] = -qz
 329:     out[3] = qw
 330:     return out^
