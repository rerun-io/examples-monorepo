 392: __device__ void
 393: retrSim3(const float *xi, const float* t, const float* q, const float* s, float* t1, float* q1, float* s1) {
 394:   
 395:   // retraction on Sim3 manifold
 396:   float dt[3] = {0, 0, 0};
 397:   float dq[4] = {0, 0, 0, 1};
 398:   float ds[1] = {0};
 399:   
 400:   expSim3(xi, dt, dq, ds);
 401: 
 402:   // Compose transformation from left
 403:   // R
 404:   quat_comp(dq, q, q1);
 405:   // t = ds dR R + ds
 406:   actSO3(dq, t, t1);
 407:   scale_vec3_inplace(t1, ds[0]);
 408:   t1[0] += dt[0];
 409:   t1[1] += dt[1];
 410:   t1[2] += dt[2];
 411:   // s
 412:   s1[0] = ds[0] * s[0];
 413: }
