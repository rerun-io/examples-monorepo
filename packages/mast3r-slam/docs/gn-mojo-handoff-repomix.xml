1310: __global__ void calib_proj_kernel(
1311:     const torch::PackedTensorAccessor32<float,2,torch::RestrictPtrTraits> Twc,
1312:     const torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> Xs,
1313:     const torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> Cs,
1314:     const torch::PackedTensorAccessor32<float,2,torch::RestrictPtrTraits> K,
1315:     const torch::PackedTensorAccessor32<long,1,torch::RestrictPtrTraits> ii,
1316:     const torch::PackedTensorAccessor32<long,1,torch::RestrictPtrTraits> jj,
1317:     const torch::PackedTensorAccessor32<long,2,torch::RestrictPtrTraits> idx_ii2_jj,
1318:     const torch::PackedTensorAccessor32<bool,3,torch::RestrictPtrTraits> valid_match,
1319:     const torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> Q,
1320:     torch::PackedTensorAccessor32<float,4,torch::RestrictPtrTraits> Hs,
1321:     torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> gs,
1322:     const int height,
1323:     const int width,
1324:     const int pixel_border,
1325:     const float z_eps,
1326:     const float sigma_pixel,
1327:     const float sigma_depth,
1328:     const float C_thresh,
1329:     const float Q_thresh)
1330: {
1331:  
1332:   // Twc and Xs first dim is number of poses
1333:   // ii, jj, Cii, Cjj, Q first dim is number of edges
1334:  
1335:   const int block_id = blockIdx.x;
1336:   const int thread_id = threadIdx.x;
1337:  
1338:   const int num_points = Xs.size(1);
1339:  
1340:   int ix = static_cast<int>(ii[block_id]);
1341:   int jx = static_cast<int>(jj[block_id]);
1342: 
1343:   __shared__ float fx;
1344:   __shared__ float fy;
1345:   __shared__ float cx;
1346:   __shared__ float cy;
1347:  
1348:   __shared__ float ti[3], tj[3], tij[3];
1349:   __shared__ float qi[4], qj[4], qij[4];
1350:   __shared__ float si[1], sj[1], sij[1];
1351: 
1352:   // load intrinsics from global memory
1353:   if (thread_id == 0) {
1354:     fx = K[0][0];
1355:     fy = K[1][1];
1356:     cx = K[0][2];
1357:     cy = K[1][2];
1358:   }
1359:  
1360:   __syncthreads();
1361:  
1362:   // load poses from global memory
1363:   if (thread_id < 3) {
1364:     ti[thread_id] = Twc[ix][thread_id];
1365:     tj[thread_id] = Twc[jx][thread_id];
1366:   }
1367:  
1368:   if (thread_id < 4) {
1369:     qi[thread_id] = Twc[ix][thread_id+3];
1370:     qj[thread_id] = Twc[jx][thread_id+3];
1371:   }
1372:  
1373:   if (thread_id < 1) {
1374:     si[thread_id] = Twc[ix][thread_id+7];
1375:     sj[thread_id] = Twc[jx][thread_id+7];
1376:   }
1377:  
1378:   __syncthreads();
1379:  
1380:   // Calculate relative poses
1381:   if (thread_id == 0) {
1382:     relSim3(ti, qi, si, tj, qj, sj, tij, qij, sij);
1383:   }
1384:  
1385:   __syncthreads();
1386:  
1387:   // //points
1388:   float Xi[3];
1389:   float Xj[3];
1390:   float Xj_Ci[3];
1391:  
1392:   // residuals
1393:   float err[3];
1394:   float w[3];
1395:  
1396:   // // jacobians
1397:   float Jx[14];
1398:   // float Jz;
1399:  
1400:   float* Ji = &Jx[0];
1401:   float* Jj = &Jx[7];
1402:  
1403:   // hessians
1404:   const int h_dim = 14*(14+1)/2;
1405:   float hij[h_dim];
1406:  
1407:   float vi[7], vj[7];
1408:  
1409:   int l; // We reuse this variable later for Hessian fill-in
1410:   for (l=0; l<h_dim; l++) {
1411:     hij[l] = 0;
1412:   }
1413:  
1414:   for (int n=0; n<7; n++) {
1415:     vi[n] = 0;
1416:     vj[n] = 0;
1417:   }
1418:  
1419:   // Parameters
1420:   const float sigma_pixel_inv = 1.0/sigma_pixel;
1421:   const float sigma_depth_inv = 1.0/sigma_depth;
1422:  
1423:   __syncthreads();
1424:  
1425:   GPU_1D_KERNEL_LOOP(k, num_points) {
1426:  
1427:     // Get points
1428:     const bool valid_match_ind = valid_match[block_id][k][0]; 
1429:     const int64_t ind_Xi = valid_match_ind ? idx_ii2_jj[block_id][k] : 0;
1430: 
1431:     Xi[0] = Xs[ix][ind_Xi][0];
1432:     Xi[1] = Xs[ix][ind_Xi][1];
1433:     Xi[2] = Xs[ix][ind_Xi][2];
1434:  
1435:     Xj[0] = Xs[jx][k][0];
1436:     Xj[1] = Xs[jx][k][1];
1437:     Xj[2] = Xs[jx][k][2];
1438: 
1439:     // Get measurement pixel
1440:     const int u_target = ind_Xi % width; 
1441:     const int v_target = ind_Xi / width;
1442:  
1443:     // Transform point
1444:     actSim3(tij, qij, sij, Xj, Xj_Ci);
1445: 
1446:     // // Check if in front of camera
1447:     const bool valid_z = ((Xj_Ci[2] > z_eps) && (Xi[2] > z_eps));
1448: 
1449:     // Handle depth related vars
1450:     const float zj_inv = valid_z ? 1.0/Xj_Ci[2] : 0.0;
1451:     const float zj_log = valid_z ? logf(Xj_Ci[2]) : 0.0;
1452:     const float zi_log = valid_z ? logf(Xi[2]) : 0.0; 
1453: 
1454:     // Project point
1455:     const float x_div_z = Xj_Ci[0] * zj_inv;
1456:     const float y_div_z = Xj_Ci[1] * zj_inv;
1457:     const float u = fx * x_div_z + cx;
1458:     const float v = fy * y_div_z + cy;
1459: 
1460:     // Handle proj
1461:     const bool valid_u = ((u > pixel_border) && (u < width - 1 - pixel_border));
1462:     const bool valid_v = ((v > pixel_border) && (v < height - 1 - pixel_border));
1463: 
1464:     // Error (difference in camera rays)
1465:     err[0] = u - u_target;
1466:     err[1] = v - v_target;
1467:     err[2] = zj_log - zi_log; // Log-depth
1468: 
1469:     // Weights (Huber)
1470:     const float q = Q[block_id][k][0];
1471:     const float ci = Cs[ix][ind_Xi][0];
1472:     const float cj = Cs[jx][k][0];
1473:     const bool valid =
1474:       valid_match_ind
1475:       & (q > Q_thresh)
1476:       & (ci > C_thresh)
1477:       & (cj > C_thresh)
1478:       & valid_u & valid_v & valid_z; // Check for valid image and depth
1479:     
1480:     // Weight using confidences
1481:     const float conf_weight = q;
1482:     
1483:     const float sqrt_w_pixel = valid ? sigma_pixel_inv * sqrtf(conf_weight) : 0;
1484:     const float sqrt_w_depth = valid ? sigma_depth_inv * sqrtf(conf_weight) : 0;
1485: 
1486:     // Robust weight
1487:     w[0] = huber(sqrt_w_pixel * err[0]);
1488:     w[1] = huber(sqrt_w_pixel * err[1]);
1489:     w[2] = huber(sqrt_w_depth * err[2]);
1490:     
1491:     // Add back in sigma
1492:     const float w_const_pixel = sqrt_w_pixel * sqrt_w_pixel;
1493:     const float w_const_depth = sqrt_w_depth * sqrt_w_depth;
1494:     w[0] *= w_const_pixel;
1495:     w[1] *= w_const_pixel;
1496:     w[2] *= w_const_depth;
1497: 
1498:     // Jacobians    
1499: 
1500:     // x coordinate
1501:     Ji[0] = fx * zj_inv;
1502:     Ji[1] = 0.0;
1503:     Ji[2] = -fx * x_div_z * zj_inv;
1504:     Ji[3] = -fx * x_div_z * y_div_z;
1505:     Ji[4] = fx * (1 + x_div_z*x_div_z);
1506:     Ji[5] = -fx * y_div_z; 
1507:     Ji[6] = 0.0;
1508: 
1509:     apply_Sim3_adj_inv(ti, qi, si, Ji, Jj);
1510:     for (int n=0; n<7; n++) Ji[n] = -Jj[n];
1511: 
1512: 
1513:     l=0;
1514:     for (int n=0; n<14; n++) {
1515:       for (int m=0; m<=n; m++) {
1516:         hij[l] += w[0] * Jx[n] * Jx[m];
1517:         l++;
1518:       }
1519:     }
1520: 
1521:     for (int n=0; n<7; n++) {
1522:       vi[n] += w[0] * err[0] * Ji[n];
1523:       vj[n] += w[0] * err[0] * Jj[n];
1524:     }
1525: 
1526:     // y coordinate
1527:     Ji[0] = 0.0; 
1528:     Ji[1] = fy * zj_inv;
1529:     Ji[2] = -fy * y_div_z * zj_inv;
1530:     Ji[3] = -fy * (1 + y_div_z*y_div_z);
1531:     Ji[4] = fy * x_div_z * y_div_z;
1532:     Ji[5] = fy * x_div_z; 
1533:     Ji[6] = 0.0;
1534: 
1535:     apply_Sim3_adj_inv(ti, qi, si, Ji, Jj);
1536:     for (int n=0; n<7; n++) Ji[n] = -Jj[n];
1537: 
1538:     l=0;
1539:     for (int n=0; n<14; n++) {
1540:       for (int m=0; m<=n; m++) {
1541:         hij[l] += w[1] * Jx[n] * Jx[m];
1542:         l++;
1543:       }
1544:     }
1545: 
1546:     for (int n=0; n<7; n++) {
1547:       vi[n] += w[1] * err[1] * Ji[n];
1548:       vj[n] += w[1] * err[1] * Jj[n];
1549:     }
1550: 
1551:     // z coordinate
1552:     Ji[0] = 0.0; 
1553:     Ji[1] = 0.0; 
1554:     Ji[2] = zj_inv;
1555:     Ji[3] = y_div_z; // y
1556:     Ji[4] = -x_div_z; // -x
1557:     Ji[5] = 0.0;
1558:     Ji[6] = 1.0; // z
1559: 
1560:     apply_Sim3_adj_inv(ti, qi, si, Ji, Jj);
1561:     for (int n=0; n<7; n++) Ji[n] = -Jj[n];
1562: 
1563:     l=0;
1564:     for (int n=0; n<14; n++) {
1565:       for (int m=0; m<=n; m++) {
1566:         hij[l] += w[2] * Jx[n] * Jx[m];
1567:         l++;
1568:       }
1569:     }
1570: 
1571:     for (int n=0; n<7; n++) {
1572:       vi[n] += w[2] * err[2] * Ji[n];
1573:       vj[n] += w[2] * err[2] * Jj[n];
1574:     }
1575: 
1576:   }
1577:  
1578:   __syncthreads();
1579:  
1580:   __shared__ float sdata[THREADS];
1581:   for (int n=0; n<7; n++) {
1582:     sdata[threadIdx.x] = vi[n];
1583:     blockReduce(sdata);
1584:     if (threadIdx.x == 0) {
1585:       gs[0][block_id][n] = sdata[0];
1586:     }
1587:  
1588:     __syncthreads();
1589:  
1590:     sdata[threadIdx.x] = vj[n];
1591:     blockReduce(sdata);
1592:     if (threadIdx.x == 0) {
1593:       gs[1][block_id][n] = sdata[0];
1594:     }
1595:  
1596:   }
1597:  
1598:   l=0;
1599:   for (int n=0; n<14; n++) {
1600:     for (int m=0; m<=n; m++) {
1601:       sdata[threadIdx.x] = hij[l];
1602:       blockReduce(sdata);
1603:  
1604:       if (threadIdx.x == 0) {
1605:         if (n<7 && m<7) {
1606:           Hs[0][block_id][n][m] = sdata[0];
1607:           Hs[0][block_id][m][n] = sdata[0];
1608:         }
1609:         else if (n >=7 && m<7) {
1610:           Hs[1][block_id][m][n-7] = sdata[0];
1611:           Hs[2][block_id][n-7][m] = sdata[0];
1612:         }
1613:         else {
1614:           Hs[3][block_id][n-7][m-7] = sdata[0];
1615:           Hs[3][block_id][m-7][n-7] = sdata[0];
1616:         }
1617:       }
1618:  
1619:       l++;
1620:     }
1621:   }
1622: }
