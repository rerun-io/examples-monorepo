235: @always_inline
236: def rel_sim3_components(
237:     tix: Float32, tiy: Float32, tiz: Float32,
238:     qix: Float32, qiy: Float32, qiz: Float32, qiw: Float32,
239:     si: Float32,
240:     tjx: Float32, tjy: Float32, tjz: Float32,
241:     qjx: Float32, qjy: Float32, qjz: Float32, qjw: Float32,
242:     sj: Float32,
243: ) -> InlineArray[Float32, 8]:
244:     var si_inv = 1.0 / si
245:     var qi_inv = quat_inv_components(qix, qiy, qiz, qiw)
246:     var qij = quat_comp_components(qi_inv[0], qi_inv[1], qi_inv[2], qi_inv[3], qjx, qjy, qjz, qjw)
247:     var dt0 = tjx - tix
248:     var dt1 = tjy - tiy
249:     var dt2 = tjz - tiz
250:     var rot_t = act_so3_components(qi_inv[0], qi_inv[1], qi_inv[2], qi_inv[3], dt0, dt1, dt2)
251:     var out = InlineArray[Float32, 8](fill=0.0)
252:     out[0] = rot_t[0] * si_inv
253:     out[1] = rot_t[1] * si_inv
254:     out[2] = rot_t[2] * si_inv
255:     out[3] = qij[0]
256:     out[4] = qij[1]
257:     out[5] = qij[2]
258:     out[6] = qij[3]
