 61:     var uv1 = 2.0 * (qz * x0 - qx * x2)
 62:     var uv2 = 2.0 * (qx * x1 - qy * x0)
 63:     var out = InlineArray[Float32, 3](fill=0.0)
 64:     out[0] = x0 + qw * uv0 + (qy * uv2 - qz * uv1)
 65:     out[1] = x1 + qw * uv1 + (qz * uv0 - qx * uv2)
 66:     out[2] = x2 + qw * uv2 + (qx * uv1 - qy * uv0)
