 698: def quat_comp_tensor(qi: PythonObject, qj: PythonObject) raises -> PythonObject:
 699:     var torch = get_torch_module()
 700:     var qix = tensor_col(qi, 0)
 701:     var qiy = tensor_col(qi, 1)
 702:     var qiz = tensor_col(qi, 2)
 703:     var qiw = tensor_col(qi, 3)
 704:     var qjx = tensor_col(qj, 0)
 705:     var qjy = tensor_col(qj, 1)
 706:     var qjz = tensor_col(qj, 2)
 707:     var qjw = tensor_col(qj, 3)
 708:     var x = qiw * qjx + qix * qjw + qiy * qjz - qiz * qjy
 709:     var y = qiw * qjy - qix * qjz + qiy * qjw + qiz * qjx
 710:     var z = qiw * qjz + qix * qjy - qiy * qjx + qiz * qjw
 711:     var w = qiw * qjw - qix * qjx - qiy * qjy - qiz * qjz
 712:     return torch.cat(Python.list(x, y, z, w), dim=1)
 713: 
 714: 
 715: def act_so3_tensor(q: PythonObject, X: PythonObject) raises -> PythonObject:
 716:     var torch = get_torch_module()
 717:     var qx = tensor_col(q, 0)
 718:     var qy = tensor_col(q, 1)
 719:     var qz = tensor_col(q, 2)
 720:     var qw = tensor_col(q, 3)
 721:     var Xx = tensor_col(X, 0)
 722:     var Xy = tensor_col(X, 1)
 723:     var Xz = tensor_col(X, 2)
 724: 
 725:     var uv0 = 2.0 * (qy * Xz - qz * Xy)
 726:     var uv1 = 2.0 * (qz * Xx - qx * Xz)
 727:     var uv2 = 2.0 * (qx * Xy - qy * Xx)
 728: 
 729:     var Y0 = Xx + qw * uv0 + (qy * uv2 - qz * uv1)
 730:     var Y1 = Xy + qw * uv1 + (qz * uv0 - qx * uv2)
 731:     var Y2 = Xz + qw * uv2 + (qx * uv1 - qy * uv0)
 732:     return torch.cat(Python.list(Y0, Y1, Y2), dim=1)
 733: 
 734: 
 735: def exp_so3_tensor(phi: PythonObject) raises -> PythonObject:
 736:     var torch = get_torch_module()
 737:     var phi0 = tensor_col(phi, 0)
 738:     var phi1 = tensor_col(phi, 1)
 739:     var phi2 = tensor_col(phi, 2)
 740:     var theta_sq = phi0 * phi0 + phi1 * phi1 + phi2 * phi2
 741:     var theta_p4 = theta_sq * theta_sq
 742:     var theta = torch.sqrt(theta_sq)
 743:     var small = theta_sq < 1e-6
 744: 
 745:     var imag_small = 0.5 - (1.0 / 48.0) * theta_sq + (1.0 / 3840.0) * theta_p4
 746:     var imag_large = torch.sin(0.5 * theta) / theta
 747:     var real_small = 1.0 - (1.0 / 8.0) * theta_sq + (1.0 / 384.0) * theta_p4
 748:     var real_large = torch.cos(0.5 * theta)
 749: 
 750:     var imag = torch.where(small, imag_small, imag_large)
 751:     var real = torch.where(small, real_small, real_large)
 752:     return torch.cat(Python.list(imag * phi0, imag * phi1, imag * phi2, real), dim=1)
 753: 
 754: 
 755: def exp_sim3_tensor(xi: PythonObject) raises -> PythonObject:
 756:     var torch = get_torch_module()
 757:     var tau = xi.narrow(1, 0, 3)
 758:     var phi = xi.narrow(1, 3, 3)
 759:     var sigma = tensor_col(xi, 6)
 760:     var scale = torch.exp(sigma)
 761: 
 762:     var q = exp_so3_tensor(phi)
 763: 
 764:     var phi0 = tensor_col(phi, 0)
 765:     var phi1 = tensor_col(phi, 1)
 766:     var phi2 = tensor_col(phi, 2)
 767:     var theta_sq = phi0 * phi0 + phi1 * phi1 + phi2 * phi2
 768:     var theta = torch.sqrt(theta_sq)
 769:     var sigma_sq = sigma * sigma
 770:     var c = theta_sq + sigma_sq
 771:     var small_sigma = torch.abs(sigma) < 1e-6
 772:     var small_theta = torch.abs(theta) < 1e-6
 773: 
 774:     var C = torch.where(small_sigma, torch.ones_like(sigma), (scale - 1.0) / sigma)
 775: 
 776:     var A_small_sigma = torch.where(
 777:         small_theta,
 778:         torch.full_like(theta, 0.5),
 779:         (1.0 - torch.cos(theta)) / theta_sq,
 780:     )
 781:     var B_small_sigma = torch.where(
 782:         small_theta,
 783:         torch.full_like(theta, 1.0 / 6.0),
 784:         (theta - torch.sin(theta)) / (theta_sq * theta),
 785:     )
 786: 
 787:     var A_large_sigma = torch.where(
 788:         small_theta,
 789:         ((sigma - 1.0) * scale + 1.0) / sigma_sq,
 790:         (scale * torch.sin(theta) * sigma + (1.0 - scale * torch.cos(theta)) * theta) / (theta * c),
 791:     )
 792:     var B_large_sigma = torch.where(
 793:         small_theta,
 794:         (scale * 0.5 * sigma_sq + scale - 1.0 - sigma * scale) / (sigma_sq * sigma),
 795:         (C - (((scale * torch.cos(theta) - 1.0) * sigma + scale * torch.sin(theta) * theta) / c)) / theta_sq,
 796:     )
 797: 
 798:     var A = torch.where(small_sigma, A_small_sigma, A_large_sigma)
 799:     var B = torch.where(small_sigma, B_small_sigma, B_large_sigma)
 800: 
 801:     var tau1 = torch.cross(phi, tau, dim=1)
 802:     var tau2 = torch.cross(phi, tau1, dim=1)
 803:     var t = C * tau + A * tau1 + B * tau2
 804:     return Python.tuple(t, q, scale)
