  81:       std::vector<T> tripletList;
  82:       for (int n=0; n<ii.size(0); n++) {
  83:         const int i = ii_acc[n];
  84:         const int j = jj_acc[n];
  85: 
  86:         if (i >= 0 && j >= 0) {
  87:           for (int k=0; k<M; k++) {
  88:             for (int l=0; l<M; l++) {
  89:               double val = As_acc[n][k][l];
  90:               tripletList.push_back(T(M*i + k, M*j + l, val));
  91:             }
  92:           }
  93:         }
  94:       }
  95:       A.setFromTriplets(tripletList.begin(), tripletList.end());
