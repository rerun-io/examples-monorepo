  74:       auto ii_cpu = ii.to(torch::kCPU).to(torch::kInt64);
  75:       auto jj_cpu = jj.to(torch::kCPU).to(torch::kInt64);
  76: 
  77:       auto As_acc = As_cpu.accessor<double,3>();
  78:       auto ii_acc = ii_cpu.accessor<long,1>();
  79:       auto jj_acc = jj_cpu.accessor<long,1>();
