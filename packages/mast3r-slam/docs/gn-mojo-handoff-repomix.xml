287: def gauss_newton_rays_step_kernel(
288:     twc: UnsafePointer[Float32, MutAnyOrigin],
289:     xs: UnsafePointer[Float32, MutAnyOrigin],
290:     cs: UnsafePointer[Float32, MutAnyOrigin],
291:     ii: UnsafePointer[Int64, MutAnyOrigin],
292:     jj: UnsafePointer[Int64, MutAnyOrigin],
293:     idx_ii2jj: UnsafePointer[Int64, MutAnyOrigin],
294:     valid_match: UnsafePointer[UInt8, MutAnyOrigin],
295:     q_tensor: UnsafePointer[Float32, MutAnyOrigin],
296:     hs: UnsafePointer[Float32, MutAnyOrigin],
297:     gs: UnsafePointer[Float32, MutAnyOrigin],
298:     num_points: Int,
299:     num_edges: Int,
300:     sigma_ray: Float32,
301:     sigma_dist: Float32,
302:     c_thresh: Float32,
303:     q_thresh: Float32,
304: ):
305:     var edge = Int(block_idx.x)
306:     var tid = Int(thread_idx.x)
307:     var block_threads = Int(block_dim.x)
308:     if edge >= num_edges:
309:         return
310: 
311:     var ix = Int(ii[edge])
312:     var jx = Int(jj[edge])
313:     var pi = ix * POSE_STRIDE
314:     var pj = jx * POSE_STRIDE
