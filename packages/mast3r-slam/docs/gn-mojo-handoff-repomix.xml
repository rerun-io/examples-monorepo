 858: __global__ void ray_align_kernel(
 859:     const torch::PackedTensorAccessor32<float,2,torch::RestrictPtrTraits> Twc,
 860:     const torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> Xs,
 861:     const torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> Cs,
 862:     const torch::PackedTensorAccessor32<long,1,torch::RestrictPtrTraits> ii,
 863:     const torch::PackedTensorAccessor32<long,1,torch::RestrictPtrTraits> jj,
 864:     const torch::PackedTensorAccessor32<long,2,torch::RestrictPtrTraits> idx_ii2_jj,
 865:     const torch::PackedTensorAccessor32<bool,3,torch::RestrictPtrTraits> valid_match,
 866:     const torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> Q,
 867:     torch::PackedTensorAccessor32<float,4,torch::RestrictPtrTraits> Hs,
 868:     torch::PackedTensorAccessor32<float,3,torch::RestrictPtrTraits> gs,
 869:     const float sigma_ray,
 870:     const float sigma_dist,
 871:     const float C_thresh,
 872:     const float Q_thresh)
 873: {
 874:  
 875:   // Twc and Xs first dim is number of poses
 876:   // ii, jj, Cii, Cjj, Q first dim is number of edges
 877:  
 878:   const int block_id = blockIdx.x;
 879:   const int thread_id = threadIdx.x;
 880:  
 881:   const int num_points = Xs.size(1);
 882:  
 883:   int ix = static_cast<int>(ii[block_id]);
 884:   int jx = static_cast<int>(jj[block_id]);
 885:  
 886:   __shared__ float ti[3], tj[3], tij[3];
 887:   __shared__ float qi[4], qj[4], qij[4];
 888:   __shared__ float si[1], sj[1], sij[1];
 889:  
 890:   __syncthreads();
 891:  
 892:   // load poses from global memory
 893:   if (thread_id < 3) {
 894:     ti[thread_id] = Twc[ix][thread_id];
 895:     tj[thread_id] = Twc[jx][thread_id];
 896:   }
 897:  
 898:   if (thread_id < 4) {
 899:     qi[thread_id] = Twc[ix][thread_id+3];
 900:     qj[thread_id] = Twc[jx][thread_id+3];
 901:   }
 902:  
 903:   if (thread_id < 1) {
 904:     si[thread_id] = Twc[ix][thread_id+7];
 905:     sj[thread_id] = Twc[jx][thread_id+7];
 906:   }
 907:  
 908:   __syncthreads();
 909:  
 910:   // Calculate relative poses
 911:   if (thread_id == 0) {
 912:     relSim3(ti, qi, si, tj, qj, sj, tij, qij, sij);
 913:   }
 914:  
 915:   __syncthreads();
 916:  
 917:   // //points
 918:   float Xi[3];
 919:   float Xj[3];
 920:   float Xj_Ci[3];
 921:  
 922:   // residuals
 923:   float err[4];
 924:   float w[4];
 925:  
 926:   // // jacobians
 927:   float Jx[14];
 928:   // float Jz;
 929:  
 930:   float* Ji = &Jx[0];
 931:   float* Jj = &Jx[7];
 932:  
 933:   // hessians
 934:   const int h_dim = 14*(14+1)/2;
 935:   float hij[h_dim];
 936:  
 937:   float vi[7], vj[7];
 938:  
 939:   int l; // We reuse this variable later for Hessian fill-in
 940:   for (l=0; l<h_dim; l++) {
 941:     hij[l] = 0;
 942:   }
 943:  
 944:   for (int n=0; n<7; n++) {
 945:     vi[n] = 0;
 946:     vj[n] = 0;
 947:   }
 948:  
 949:     // Parameters
 950:   const float sigma_ray_inv = 1.0/sigma_ray;
 951:   const float sigma_dist_inv = 1.0/sigma_dist;
 952:  
 953:   __syncthreads();
 954:  
 955:   GPU_1D_KERNEL_LOOP(k, num_points) {
 956:  
 957:     // Get points
 958:     const bool valid_match_ind = valid_match[block_id][k][0]; 
 959:     const int64_t ind_Xi = valid_match_ind ? idx_ii2_jj[block_id][k] : 0;
 960: 
 961:     Xi[0] = Xs[ix][ind_Xi][0];
 962:     Xi[1] = Xs[ix][ind_Xi][1];
 963:     Xi[2] = Xs[ix][ind_Xi][2];
 964:  
 965:     Xj[0] = Xs[jx][k][0];
 966:     Xj[1] = Xs[jx][k][1];
 967:     Xj[2] = Xs[jx][k][2];
 968:  
 969:     // Normalize measurement point
 970:     const float norm2_i = squared_norm3(Xi);
 971:     const float norm1_i = sqrtf(norm2_i);
 972:     const float norm1_i_inv = 1.0/norm1_i;    
 973:     
 974:     float ri[3];
 975:     for (int i=0; i<3; i++) ri[i] = norm1_i_inv * Xi[i];
 976:  
 977:     // Transform point
 978:     actSim3(tij, qij, sij, Xj, Xj_Ci);
 979:  
 980:     // Get predicted point norm
 981:     const float norm2_j = squared_norm3(Xj_Ci);
 982:     const float norm1_j = sqrtf(norm2_j);
 983:     const float norm1_j_inv = 1.0/norm1_j;
 984: 
 985:     float rj_Ci[3];
 986:     for (int i=0; i<3; i++) rj_Ci[i] = norm1_j_inv * Xj_Ci[i];
 987:  
 988:     // Error (difference in camera rays)
 989:     err[0] = rj_Ci[0] - ri[0];
 990:     err[1] = rj_Ci[1] - ri[1];
 991:     err[2] = rj_Ci[2] - ri[2];
 992:     err[3] = norm1_j - norm1_i; // Distance
 993:  
 994:     // Weights (Huber)
 995:     const float q = Q[block_id][k][0];
 996:     const float ci = Cs[ix][ind_Xi][0];
 997:     const float cj = Cs[jx][k][0];
 998:     const bool valid = 
 999:       valid_match_ind
1000:       & (q > Q_thresh)
1001:       & (ci > C_thresh)
1002:       & (cj > C_thresh);
1003: 
1004:     // Weight using confidences
1005:     const float conf_weight = q;
1006:     // const float conf_weight = q * ci * cj;
1007:     
1008:     const float sqrt_w_ray = valid ? sigma_ray_inv * sqrtf(conf_weight) : 0;
1009:     const float sqrt_w_dist = valid ? sigma_dist_inv * sqrtf(conf_weight) : 0;
1010:  
1011:     // Robust weight
1012:     w[0] = huber(sqrt_w_ray * err[0]);
1013:     w[1] = huber(sqrt_w_ray * err[1]);
1014:     w[2] = huber(sqrt_w_ray * err[2]);
1015:     w[3] = huber(sqrt_w_dist * err[3]);
1016:     
1017:     // Add back in sigma
1018:     const float w_const_ray = sqrt_w_ray * sqrt_w_ray;
1019:     const float w_const_dist = sqrt_w_dist * sqrt_w_dist;
1020:     w[0] *= w_const_ray;
1021:     w[1] *= w_const_ray;
1022:     w[2] *= w_const_ray;
1023:     w[3] *= w_const_dist;
1024:  
1025:     // Jacobians
1026:     
1027:     const float norm3_j_inv = norm1_j_inv / norm2_j;
1028:     const float drx_dPx = norm1_j_inv - Xj_Ci[0]*Xj_Ci[0]*norm3_j_inv;
1029:     const float dry_dPy = norm1_j_inv - Xj_Ci[1]*Xj_Ci[1]*norm3_j_inv;
1030:     const float drz_dPz = norm1_j_inv - Xj_Ci[2]*Xj_Ci[2]*norm3_j_inv;
1031:     const float drx_dPy = - Xj_Ci[0]*Xj_Ci[1]*norm3_j_inv;
1032:     const float drx_dPz = - Xj_Ci[0]*Xj_Ci[2]*norm3_j_inv;
1033:     const float dry_dPz = - Xj_Ci[1]*Xj_Ci[2]*norm3_j_inv;
1034:  
1035:     // rx coordinate
1036:     Ji[0] = drx_dPx;
1037:     Ji[1] = drx_dPy;
1038:     Ji[2] = drx_dPz;
1039:     Ji[3] = 0.0;
1040:     Ji[4] = rj_Ci[2]; // z
1041:     Ji[5] = -rj_Ci[1]; // -y
1042:     Ji[6] = 0.0; // x
1043: 
1044:     apply_Sim3_adj_inv(ti, qi, si, Ji, Jj);
1045:     for (int n=0; n<7; n++) Ji[n] = -Jj[n];
1046: 
1047:     l=0;
1048:     for (int n=0; n<14; n++) {
1049:       for (int m=0; m<=n; m++) {
1050:         hij[l] += w[0] * Jx[n] * Jx[m];
1051:         l++;
1052:       }
1053:     }
1054:  
1055:     for (int n=0; n<7; n++) {
1056:       vi[n] += w[0] * err[0] * Ji[n];
1057:       vj[n] += w[0] * err[0] * Jj[n];
1058:     }
1059:  
1060:     // ry coordinate
1061:     Ji[0] = drx_dPy; // same as drx_dPy
1062:     Ji[1] = dry_dPy;
1063:     Ji[2] = dry_dPz;
1064:     Ji[3] = -rj_Ci[2]; // -z
1065:     Ji[4] = 0.0;
1066:     Ji[5] = rj_Ci[0]; // x
1067:     Ji[6] = 0.0; // y
1068:  
1069:     apply_Sim3_adj_inv(ti, qi, si, Ji, Jj);
1070:     for (int n=0; n<7; n++) Ji[n] = -Jj[n];
1071: 
1072:     l=0;
1073:     for (int n=0; n<14; n++) {
1074:       for (int m=0; m<=n; m++) {
1075:         hij[l] += w[1] * Jx[n] * Jx[m];
1076:         l++;
1077:       }
1078:     }
1079:  
1080:     for (int n=0; n<7; n++) {
1081:       vi[n] += w[1] * err[1] * Ji[n];
1082:       vj[n] += w[1] * err[1] * Jj[n];
1083:     }
1084:  
1085:     // rz coordinate
1086:     Ji[0] = drx_dPz; // same as drz_dPX
1087:     Ji[1] = dry_dPz; // same as drz_dPy
1088:     Ji[2] = drz_dPz;
1089:     Ji[3] = rj_Ci[1]; // y
1090:     Ji[4] = -rj_Ci[0]; // -x
1091:     Ji[5] = 0.0;
1092:     Ji[6] = 0.0; // z
1093:  
1094:     apply_Sim3_adj_inv(ti, qi, si, Ji, Jj);
1095:     for (int n=0; n<7; n++) Ji[n] = -Jj[n];
1096: 
1097:     l=0;
1098:     for (int n=0; n<14; n++) {
1099:       for (int m=0; m<=n; m++) {
1100:         hij[l] += w[2] * Jx[n] * Jx[m];
1101:         l++;
1102:       }
1103:     }
1104:  
1105:     for (int n=0; n<7; n++) {
1106:       vi[n] += w[2] * err[2] * Ji[n];
1107:       vj[n] += w[2] * err[2] * Jj[n];
1108:     }
1109: 
1110: 
1111:     // dist coordinate
1112:     Ji[0] = rj_Ci[0];
1113:     Ji[1] = rj_Ci[1]; 
1114:     Ji[2] = rj_Ci[2];
1115:     Ji[3] = 0.0; 
1116:     Ji[4] = 0.0; 
1117:     Ji[5] = 0.0;
1118:     Ji[6] = norm1_j;
1119:  
1120:     apply_Sim3_adj_inv(ti, qi, si, Ji, Jj);
1121:     for (int n=0; n<7; n++) Ji[n] = -Jj[n];
1122: 
1123:     l=0;
1124:     for (int n=0; n<14; n++) {
1125:       for (int m=0; m<=n; m++) {
1126:         hij[l] += w[3] * Jx[n] * Jx[m];
1127:         l++;
1128:       }
1129:     }
1130:  
1131:     for (int n=0; n<7; n++) {
1132:       vi[n] += w[3] * err[3] * Ji[n];
1133:       vj[n] += w[3] * err[3] * Jj[n];
1134:     }
1135:  
1136:  
1137:   }
1138:  
1139:   __syncthreads();
1140:  
1141:   __shared__ float sdata[THREADS];
1142:   for (int n=0; n<7; n++) {
1143:     sdata[threadIdx.x] = vi[n];
1144:     blockReduce(sdata);
1145:     if (threadIdx.x == 0) {
1146:       gs[0][block_id][n] = sdata[0];
1147:     }
1148:  
1149:     __syncthreads();
1150:  
1151:     sdata[threadIdx.x] = vj[n];
1152:     blockReduce(sdata);
1153:     if (threadIdx.x == 0) {
1154:       gs[1][block_id][n] = sdata[0];
1155:     }
1156:  
1157:   }
1158:  
1159:   l=0;
1160:   for (int n=0; n<14; n++) {
1161:     for (int m=0; m<=n; m++) {
1162:       sdata[threadIdx.x] = hij[l];
1163:       blockReduce(sdata);
1164:  
1165:       if (threadIdx.x == 0) {
1166:         if (n<7 && m<7) {
1167:           Hs[0][block_id][n][m] = sdata[0];
1168:           Hs[0][block_id][m][n] = sdata[0];
1169:         }
1170:         else if (n >=7 && m<7) {
1171:           Hs[1][block_id][m][n-7] = sdata[0];
1172:           Hs[2][block_id][n-7][m] = sdata[0];
1173:         }
1174:         else {
1175:           Hs[3][block_id][n-7][m-7] = sdata[0];
1176:           Hs[3][block_id][m-7][n-7] = sdata[0];
1177:         }
1178:       }
1179:  
1180:       l++;
1181:     }
1182:   }
1183: }
