555: def refine_matches_py(
556:     D11_obj: PythonObject,
557:     D21_obj: PythonObject,
558:     p1_obj: PythonObject,
559:     radius_obj: PythonObject,
560:     dilation_max_obj: PythonObject,
561: ) raises -> PythonObject:
562:     """Drop-in replacement for mast3r_slam_backends.refine_matches."""
563:     var torch = Python.import_module("torch")
564: 
565:     var p1: PythonObject = p1_obj.contiguous()
566: 
567:     # Shapes from original (possibly half) inputs
568:     var batch: Int = Int(py=D11_obj.shape[0])
569:     var h: Int = Int(py=D11_obj.shape[1])
570:     var w: Int = Int(py=D11_obj.shape[2])
571:     var fdim: Int = Int(py=D11_obj.shape[3])
572:     var num_pts: Int = Int(py=p1.shape[1])
573:     var radius: Int = Int(py=radius_obj)
574:     var dilation_max: Int = Int(py=dilation_max_obj)
575: 
576:     # Allocate output
577:     var p1_new: PythonObject = torch.empty(
578:         Python.list(batch, num_pts, 2),
579:         device=p1.device,
580:         dtype=p1.dtype,
581:     )
582: 
583:     var p1_ptr: Int = Int(py=p1.data_ptr())
584:     var p1_new_ptr: Int = Int(py=p1_new.data_ptr())
585:     var p1_uptr = UnsafePointer[Int64, MutAnyOrigin](unsafe_from_address=p1_ptr)
586:     var p1_new_uptr = UnsafePointer[Int64, MutAnyOrigin](unsafe_from_address=p1_new_ptr)
587: 
588:     var ctx_ptr = get_cached_context_ptr()
589:     var block_size: Int = choose_refine_block(num_pts, fdim)
590:     var num_blocks_x: Int = ceildiv(num_pts, block_size)
591: 
592:     # Dispatch float16 vs float32 to avoid half→float copy overhead (~7 µs)
593:     var is_half: Bool = Bool(D11_obj.dtype == torch.float16)
594: 
595:     if is_half:
596:         var D11: PythonObject = D11_obj.contiguous()
597:         var D21: PythonObject = D21_obj.contiguous()
598:         var d11_ptr: Int = Int(py=D11.data_ptr())
599:         var d21_ptr: Int = Int(py=D21.data_ptr())
600:         var d11_uptr = UnsafePointer[Float16, MutAnyOrigin](unsafe_from_address=d11_ptr)
601:         var d21_uptr = UnsafePointer[Float16, MutAnyOrigin](unsafe_from_address=d21_ptr)
602: 
603:         # Specialize the hot MASt3R-SLAM path so the compiler can unroll the
604:         # inner dot product and we only read each query descriptor once.
605:         if radius == 2 and dilation_max == 2 and block_size == 8 and fdim == 16:
606:             comptime kernel = refine_matches_kernel_f16_cached[16, 8]
607:             ctx_ptr[].enqueue_function[kernel, kernel](
608:                 d11_uptr,
609:                 d21_uptr,
610:                 p1_uptr,
611:                 p1_new_uptr,
612:                 h, w, num_pts,
613:                 grid_dim=(num_blocks_x, batch),
614:                 block_dim=block_size,
615:             )
616:         elif radius == 2 and dilation_max == 2 and block_size == 16 and fdim == 128:
617:             comptime kernel = refine_matches_kernel_f16_cached[128, 16]
618:             ctx_ptr[].enqueue_function[kernel, kernel](
619:                 d11_uptr,
620:                 d21_uptr,
621:                 p1_uptr,
622:                 p1_new_uptr,
623:                 h, w, num_pts,
624:                 grid_dim=(num_blocks_x, batch),
625:                 block_dim=block_size,
626:             )
627:         else:
628:             ctx_ptr[].enqueue_function[refine_matches_kernel_f16, refine_matches_kernel_f16](
629:                 d11_uptr,
630:                 d21_uptr,
631:                 p1_uptr,
632:                 p1_new_uptr,
633:                 h, w, num_pts, fdim, radius, dilation_max,
634:                 grid_dim=(num_blocks_x, batch),
635:                 block_dim=block_size,
636:             )
637:     else:
638:         var D11: PythonObject = D11_obj.contiguous().float()
639:         var D21: PythonObject = D21_obj.contiguous().float()
640:         var d11_ptr: Int = Int(py=D11.data_ptr())
