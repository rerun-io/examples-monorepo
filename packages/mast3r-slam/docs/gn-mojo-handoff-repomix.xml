 12: 
 13: def get_unique_kf_idx(ii: Tensor, jj: Tensor) -> Tensor:
 14:     return torch.unique(torch.cat((ii, jj)), sorted=True)
 15: 
 16: 
 17: def create_inds(unique_kf_idx: Tensor, pin: int, ii: Tensor, jj: Tensor) -> tuple[Tensor, Tensor]:
 18:     ii_ind: Tensor = torch.searchsorted(unique_kf_idx, ii) - pin
 19:     jj_ind: Tensor = torch.searchsorted(unique_kf_idx, jj) - pin
 20:     return ii_ind, jj_ind
 21: 
 22: 
 23: def assemble_dense_system(
 24:     hs: Tensor,
 25:     gs: Tensor,
 26:     ii_opt: Tensor,
 27:     jj_opt: Tensor,
 28:     n_vars: int,
 29: ) -> tuple[Tensor, Tensor]:
 30:     device: torch.device = hs.device
 31:     flat_h: Tensor = torch.zeros((n_vars * n_vars, POSE_DIM * POSE_DIM), device=device, dtype=hs.dtype)
 32:     block_terms: Tensor = torch.cat((hs[0], hs[1], hs[2], hs[3]), dim=0).reshape(-1, POSE_DIM * POSE_DIM)
 33:     rows: Tensor = torch.cat((ii_opt, ii_opt, jj_opt, jj_opt), dim=0)
 34:     cols: Tensor = torch.cat((ii_opt, jj_opt, ii_opt, jj_opt), dim=0)
 35:     valid_h: Tensor = (rows >= 0) & (cols >= 0)
 36:     if bool(valid_h.any()):
 37:         block_indices: Tensor = rows[valid_h] * n_vars + cols[valid_h]
 38:         flat_h.index_add_(0, block_indices, block_terms[valid_h])
 39:     h_dense: Tensor = flat_h.view(n_vars, n_vars, POSE_DIM, POSE_DIM).permute(0, 2, 1, 3).reshape(n_vars * POSE_DIM, n_vars * POSE_DIM)
 40: 
 41:     b_dense: Tensor = torch.zeros((n_vars, POSE_DIM), device=device, dtype=gs.dtype)
 42:     rhs_terms: Tensor = torch.cat((gs[0], gs[1]), dim=0)
 43:     rhs_rows: Tensor = torch.cat((ii_opt, jj_opt), dim=0)
 44:     valid_b: Tensor = rhs_rows >= 0
 45:     if bool(valid_b.any()):
 46:         b_dense.index_add_(0, rhs_rows[valid_b], rhs_terms[valid_b])
 47: 
 48:     return h_dense, b_dense
 49: 
 50: 
 51: def solve_dense_system(h_dense: Tensor, b_dense: Tensor, n_vars: int) -> Tensor:
 52:     if n_vars <= 0:
 53:         return torch.zeros((0, POSE_DIM), device=h_dense.device, dtype=h_dense.dtype)
 54: 
 55:     rhs: Tensor = -b_dense.reshape(n_vars * POSE_DIM, 1)
 56:     eye: Tensor = torch.eye(n_vars * POSE_DIM, device=h_dense.device, dtype=h_dense.dtype)
 57:     chol_h: Tensor = h_dense + 1e-9 * eye
 58:     l_factor, info = torch.linalg.cholesky_ex(chol_h, upper=False)
 59:     if int(info.max().item()) != 0:
 60:         return torch.zeros((n_vars, POSE_DIM), device=h_dense.device, dtype=h_dense.dtype)
 61:     dx_vec: Tensor = torch.cholesky_solve(rhs, l_factor, upper=False)
 62:     return dx_vec.view(n_vars, POSE_DIM)
