# Patch: Create setup.py with multi-source package discovery (upstream has none)
#
# This is the companion to add-pyproject-toml.patch. We need a setup.py
# because the package layout is unusual — three repos nested together:
#
#   ./mast3r/          ← naver/mast3r Python package
#   ./dust3r/dust3r/   ← naver/dust3r Python package (repo root has non-package files)
#   ./dust3r/croco/models/ ← naver/croco CroCo model code (used by dust3r encoder)
#
# find_packages() is called three times with different `where` roots to
# discover packages in each location. package_dir maps the top-level
# package names to their actual filesystem paths so setuptools can find them.
--- /dev/null
+++ b/setup.py
@@ -0,0 +1,14 @@
+from setuptools import setup, find_packages
+
+setup(
+    packages=(
+        find_packages(where=".", include=["mast3r", "mast3r.*"])
+        + find_packages(where="dust3r", include=["dust3r", "dust3r.*"])
+        + find_packages(where="dust3r/croco", include=["models", "models.*"])
+    ),
+    package_dir={
+        "mast3r": "mast3r",
+        "dust3r": "dust3r/dust3r",
+        "models": "dust3r/croco/models",
+    },
+)
